  "output": "## Test Coverage Analysis\n\n**Bottom line: Zero test coverage across all 63 source files.** No test framework is installed. Here's the prioritised gap analysis with skeletons.\n\n---\n\n## Setup Required First\n\n```bash\nnpm install --save-dev jest @testing-library/react @testing-library/jest-dom jest-environment-jsdom\n```\n\nAdd to `package.json`:\n```json\n\"test\": \"jest\",\n\"jest\": { \"testEnvironment\": \"jsdom\", \"testMatch\": [\"**/tests/**/*.test.js\"] }\n```\n\n---\n\n## Tier 1 — Critical Architecture (Core Layer)\n\n### 1. `HistoryOfThought.js` — Untested entirely\n\n**Gaps:** All crypto paths — `deriveKey`, `encryptPayload`, `decryptPayload`, `unlockWithPassphrase`, `appendEvent`, `generateAuthenticityReport`, `lockSession`.\n\n**Key edge cases missing:**\n- Short passphrase (< 4 chars)\n- Decryption of corrupted ciphertext\n- Crypto API unavailable\n- IndexedDB quota exceeded\n\n```js\n// tests/core/HistoryOfThought.test.js\nimport { unlockWithPassphrase, lockSession, appendEvent, listEvents, generateAuthenticityReport } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought — crypto pipeline', () => {\n  beforeEach(() => lockSession());\n\n  test('unlockWithPassphrase derives key and sets locked=false', async () => {\n    await unlockWithPassphrase('strongPass123');\n    // assert vault is unlocked\n  });\n\n  test('rejects passphrase shorter than 4 characters', async () => {\n    await expect(unlockWithPassphrase('ab')).rejects.toThrow();\n  });\n\n  test('appendEvent encrypts and stores event; listEvents returns it', async () => {\n    await unlockWithPassphrase('strongPass123');\n    await appendEvent({ type: 'text_edit', payload: { chars: 100 } });\n    const events = await listEvents();\n    expect(events).toHaveLength(1);\n    expect(events[0].type).toBe('text_edit');\n  });\n\n  test('appendEvent is a no-op (silent drop) when vault is locked', async () => {\n    // vault stays locked — no throw, no event stored\n    await appendEvent({ type: 'text_edit', payload: {} });\n    await unlockWithPassphrase('strongPass123');\n    expect(await listEvents()).toHaveLength(0);\n  });\n\n  test('decryption fails gracefully on corrupted envelope', async () => {\n    await unlockWithPassphrase('strongPass123');\n    // manually inject corrupted record into IndexedDB\n    await expect(listEvents()).resolves.toBeDefined(); // doesn't crash\n  });\n\n  test('generateAuthenticityReport aggregates event counts correctly', async () => {\n    await unlockWithPassphrase('pass');\n    await appendEvent({ type: 'focus_start' });\n    await appendEvent({ type: 'text_edit' });\n    await appendEvent({ type: 'focus_start' });\n    const report = await generateAuthenticityReport();\n    expect(report.counts.focus_start).toBe(2);\n    expect(report.counts.text_edit).toBe(1);\n  });\n\n  test('lockSession zeroes the key; appendEvent silently drops after lock', async () => {\n    await unlockWithPassphrase('pass');\n    lockSession();\n    await appendEvent({ type: 'text_edit' });\n    await unlockWithPassphrase('pass');\n    expect(await listEvents()).toHaveLength(0);\n  });\n});\n```\n\n---\n\n### 2. `EventBus.js` — Untested entirely\n\n**Gaps:** `startEventBus`, `stopEventBus`, `safeAppend`, `pickSafePayload`, double-registration guard.\n\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus } from '../../src/core/EventBus';\n\ndescribe('EventBus', () => {\n  let getContext;\n\n  beforeEach(() => {\n    getContext = jest.fn(() => ({ userId: 'u1', sessionId: 's1' }));\n    startEventBus(getContext);\n  });\n\n  afterEach(() => stopEventBus());\n\n  test('dispatching sovereign:text_edit triggers safeAppend with correct payload', async () => {\n    const appendSpy = jest.fn();\n    // inject mock for HistoryOfThought.appendEvent\n    window.dispatchEvent(new CustomEvent('sovereign:text_edit', { detail: { chars: 42 } }));\n    await Promise.resolve(); // flush microtasks\n    expect(appendSpy).toHaveBeenCalledWith(expect.objectContaining({ type: 'text_edit' }));\n  });\n\n  test('safeAppend silently drops event when vault is locked (no throw)', () => {\n    expect(() => {\n      window.dispatchEvent(new CustomEvent('sovereign:text_edit', { detail: {} }));\n    }).not.toThrow();\n  });\n\n  test('getContext returning null does not crash the bus', () => {\n    stopEventBus();\n    startEventBus(() => null);\n    expect(() => {\n      window.dispatchEvent(new CustomEvent('sovereign:text_edit', { detail: {} }));\n    }).not.toThrow();\n  });\n\n  test('stopEventBus removes all listeners — events no longer processed', () => {\n    const spy = jest.spyOn(global.console, 'error');\n    stopEventBus();\n    window.dispatchEvent(new CustomEvent('sovereign:text_edit', { detail: {} }));\n    expect(spy).not.toHaveBeenCalled();\n  });\n\n  test('calling startEventBus twice does not register duplicate listeners', () => {\n    startEventBus(getContext); // second call\n    window.dispatchEvent(new CustomEvent('sovereign:focus_start', {}));\n    // assert handler fired exactly once (inspect call count on safeAppend mock)\n  });\n});\n```\n\n---\n\n### 3. `ExecutiveSpine.js` — Untested entirely\n\n**Gaps:** `startFocusSession`/`endFocusSession` lifecycle, `setSectionHealth` threshold crossing, `grantPlayTime`, credit ledger, idle detection.\n\n```js\n// tests/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  setSectionHealth, grantPlayTime, isPlayTimeActive,\n  earnCredits, spendCredits, getCredits, configureSpine\n} from '../../src/core/ExecutiveSpine';\n\nbeforeEach(() => {\n  localStorage.clear();\n  jest.useFakeTimers();\n});\n\nafterEach(() => jest.useRealTimers());\n\ndescribe('Focus sessions', () => {\n  test('startFocusSession sets active session with correct duration', () => {\n    startFocusSession(25);\n    expect(isFocusActive()).toBe(true);\n    const session = getFocusSession();\n    expect(session.durationMinutes).toBe(25);\n  });\n\n  test('session expires after duration elapses', () => {\n    startFocusSession(25);\n    jest.advanceTimersByTime(25 * 60 * 1000 + 1);\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('endFocusSession before expiry marks session terminated', () => {\n    startFocusSession(25);\n    endFocusSession();\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('getFocusSession returns null when no session started', () => {\n    expect(getFocusSession()).toBeNull();\n  });\n\n  test('rapid start/end/start does not leave dangling timer', () => {\n    startFocusSession(10);\n    endFocusSession();\n    startFocusSession(10);\n    expect(isFocusActive()).toBe(true);\n  });\n\n  test('corrupted localStorage JSON does not crash getFocusSession', () => {\n    localStorage.setItem('FOCUS_KEY', '{invalid json}');\n    expect(() => getFocusSession()).not.toThrow();\n    expect(getFocusSession()).toBeNull();\n  });\n});\n\ndescribe('Section health & playtime', () => {\n  test('setSectionHealth below threshold does not grant playtime', () => {\n    configureSpine({ healthThreshold: 4 });\n    setSectionHealth(3);\n    expect(isPlayTimeActive()).toBe(false);\n  });\n\n  test('setSectionHealth at threshold grants playtime', () => {\n    configureSpine({ healthThreshold: 4 });\n    setSectionHealth(4);\n    expect(isPlayTimeActive()).toBe(true);\n  });\n\n  test('playtime expires after configured window', () => {\n    configureSpine({ healthThreshold: 4, playTimeMinutes: 5 });\n    setSectionHealth(4);\n    jest.advanceTimersByTime(5 * 60 * 1000 + 1);\n    expect(isPlayTimeActive()).toBe(false);\n  });\n});\n\ndescribe('Sovereign credit ledger', () => {\n  test('earnCredits increases balance', () => {\n    earnCredits(10);\n    expect(getCredits()).toBe(10);\n  });\n\n  test('spendCredits decreases balance; cannot go below zero', () => {\n    earnCredits(5);\n    spendCredits(3);\n    expect(getCredits()).toBe(2);\n    spendCredits(99);\n    expect(getCredits()).toBe(0);\n  });\n\n  test('NaN in localStorage treated as zero', () => {\n    localStorage.setItem('SOVEREIGN_CREDITS', 'not-a-number');\n    expect(getCredits()).toBe(0);\n  });\n});\n```\n\n---\n\n### 4. `SovereignRouter.js` — Untested entirely\n\n**Gaps:** `hydrate`, `streamFromLevel`, `applyTheme`, `isValidStream`.\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { hydrate, streamFromLevel, isValidStream, applyTheme } from '../../src/core/SovereignRouter';\n\ndescribe('SovereignRouter', () => {\n  test('hydrate returns profile with stream, theme, and capabilities for valid session', () => {\n    const profile = hydrate({ level: 'tertiary', userId: 'u1' });\n    expect(profile.stream).toBeDefined();\n    expect(profile.theme).toBeDefined();\n    expect(Array.isArray(profile.capabilities)).toBe(true);\n  });\n\n  test('hydrate handles missing capabilities array in profile gracefully', () => {\n    expect(() => hydrate({ level: 'unknown_level' })).not.toThrow();\n  });\n\n  test.each([\n    ['Year 7', 'secondary'], ['Bachelor', 'tertiary'], ['TAFE Cert III', 'tafe'],\n    ['Homeschool Year 4', 'homeschool'], ['MRes', 'primary']\n  ])('streamFromLevel(%s) maps to %s stream', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('isValidStream rejects unknown stream IDs', () => {\n    expect(isValidStream('foo')).toBe(false);\n    expect(isValidStream('tertiary')).toBe(true);\n  });\n\n  test('applyTheme sets CSS custom properties on document root', () => {\n    applyTheme({ '--primary': '#ff0000', '--bg': '#ffffff' });\n    expect(document.documentElement.style.getPropertyValue('--primary')).toBe('#ff0000');\n  });\n\n  test('applyTheme with invalid CSS value does not throw', () => {\n    expect(() => applyTheme({ '--primary': null })).not.toThrow();\n  });\n});\n```\n\n---\n\n## Tier 2 — Services\n\n### 5. `SovereignReconciler.js` — Untested entirely\n\n**Gaps:** Fuzzy title clustering, `normaliseTitle`, `tokenSimilarity`, conflict resolution logic.\n\n```js\n// tests/services/SovereignReconciler.test.js\nimport { reconcile, normaliseTitle, tokenSimilarity } from '../../src/services/SovereignReconciler';\n\ndescribe('SovereignReconciler', () => {\n  test('reconcile clusters fuzzy-matching titles into one section', () => {\n    const briefs = [\n      { title: 'Literature Review', wordGoal: 500 },\n      { title: 'Lit Review Part A', wordGoal: 600 },\n      { title: 'Lit Rev I', wordGoal: 400 }\n    ];\n    const result = reconcile(briefs);\n    expect(result).toHaveLength(1);\n    expect(result[0].wordGoal).toBe(600); // highest wins\n  });\n\n  test('reconcile keeps distinct sections separate', () => {\n    const briefs = [\n      { title: 'Introduction', wordGoal: 200 },\n      { title: 'Methodology', wordGoal: 400 }\n    ];\n    expect(reconcile(briefs)).toHaveLength(2);\n  });\n\n  test('normaliseTitle converts Roman numerals and expands abbreviations', () => {\n    expect(normaliseTitle('Lit Rev III')).toContain('3');\n  });\n\n  test('tokenSimilarity returns 1.0 for identical strings', () => {\n    expect(tokenSimilarity('literature review', 'literature review')).toBe(1.0);\n  });\n\n  test('tokenSimilarity returns 0 for completely different strings', () => {\n    expect(tokenSimilarity('methodology', 'appendix')).toBe(0);\n  });\n\n  test('handles empty brief array', () => {\n    expect(reconcile([])).toEqual([]);\n  });\n});\n```\n\n---\n\n### 6. `BriefService.js` — Untested entirely\n\n**Gaps:** `extractEvidenceFormula` regex fragility, `mapToWorkspace` level mappings, `extractDynamicThemes`.\n\n```js\n// tests/services/BriefService.test.js\nimport { mapToWorkspace, extractEvidenceFormula } from '../../src/services/BriefService';\n\ndescribe('BriefService — extractEvidenceFormula', () => {\n  test.each([\n    ['Include two primary sources', { primary: 2 }],\n    ['Include 2 primary sources', { primary: 2 }],\n    ['3 primary AND 2 review sources required', { primary: 3, review: 2 }],\n  ])('parses \"%s\" correctly', (text, expected) => {\n    expect(extractEvidenceFormula(text)).toMatchObject(expected);\n  });\n\n  test('does not misparse numbered list items as evidence counts', () => {\n    const text = '1. Introduction\\n2. Methods\\n3. Results';\n    const result = extractEvidenceFormula(text);\n    expect(result.primary).toBeUndefined();\n  });\n\n  test('returns empty object for text with no evidence requirements', () => {\n    expect(extractEvidenceFormula('Write a reflective essay.')).toEqual({});\n  });\n});\n\ndescribe('BriefService — mapToWorkspace', () => {\n  test('maps tertiary brief text to expected section keys', async () => {\n    const sections = await mapToWorkspace('Literature review and methodology required', 'tertiary');\n    expect(sections.some(s => /lit/i.test(s.title))).toBe(true);\n  });\n\n  test('handles empty text without throwing', async () => {\n    await expect(mapToWorkspace('', 'tertiary')).resolves.toBeDefined();\n  });\n});\n```\n\n---\n\n### 7. `ChatService.js` / `MicroStepService.js` — Network error handling\n\n**Gaps:** Ollama unreachable, partial JSON response, steering dials not applied.\n\n```js\n// tests/services/ChatService.test.js\nimport { getAuraResponse } from '../../src/services/ChatService';\n\nglobal.fetch = jest.fn();\n\nafterEach(() => fetch.mockReset());\n\ndescribe('ChatService — Ollama error handling', () => {\n  test('returns fallback message when Ollama is unreachable', async () => {\n    fetch.mockRejectedValueOnce(new Error('fetch failed'));\n    const result = await getAuraResponse('hello', {});\n    expect(result).toBeTruthy(); // graceful fallback, not thrown\n  });\n\n  test('handles non-JSON response body from Ollama', async () => {\n    fetch.mockResolvedValueOnce({ ok: false, text: () => '<html>503</html>' });\n    await expect(getAuraResponse('hello', {})).resolves.toBeDefined();\n  });\n\n  test('buildSteeringBlock includes all four dials', () => {\n    // inject localStorage dials\n    localStorage.setItem('STEERING_PERSONA', 'literal');\n    localStorage.setItem('STEERING_SCAFFOLDING', 'heavy');\n    // import and call buildSteeringBlock directly\n    // assert output string contains all four dial values\n  });\n});\n```\n\n---\n\n## Tier 3 — Integration Test Gaps\n\n### Gap 1: Full Audit Trail Flow\n\n```js\n// tests/integration/auditTrail.test.js\n// EventBus → HistoryOfThought → generateAuthenticityReport\n\ntest('10 events dispatched through window arrive in authenticity report', async () => {\n  await unlockWithPassphrase('testPass');\n  startEventBus(() => ({ userId: 'u1' }));\n\n  const eventTypes = ['focus_start', 'text_edit', 'text_edit', 'idle', 'focus_end',\n                      'citation_add', 'text_edit', 'section_health_change', 'playtime_granted', 'focus_start'];\n  eventTypes.forEach(type => window.dispatchEvent(new CustomEvent(`sovereign:${type}`, { detail: {} })));\n\n  await new Promise(r => setTimeout(r, 50)); // flush async appends\n\n  const report = await generateAuthenticityReport();\n  expect(report.counts.text_edit).toBe(3);\n  expect(report.counts.focus_start).toBe(2);\n  expect(report.totalEvents).toBe(10);\n});\n```\n\n### Gap 2: Stream Profile → Steering → Service Output\n\n```js\n// tests/integration/steeringPipeline.test.js\n// SovereignRouter hydrate → steering dials → MicroStepService output shape\n\ntest('literal mode steering transforms microstep output vocabulary', async () => {\n  hydrate({ level: 'tertiary' });\n  localStorage.setItem('STEERING_PERSONA', 'literal');\n  localStorage.setItem('STEERING_SCAFFOLDING', 'heavy');\n\n  fetch.mockResolvedValueOnce({ ok: true, json: () => ({ message: { content: '[\"Step 1\",\"Step 2\"]' } }) });\n\n  const steps = await generateSteps({ rubricText: 'Write a literature review' });\n  // steps should be plain English (LiteralMode applied)\n  expect(steps[0]).not.toMatch(/thematic synthesis|epistemological/i);\n});\n```\n\n### Gap 3: PDF → Reconcile → Canvas Sections\n\n```js\n// tests/integration/pdfToCanvas.test.js\n// DocumentAIService → BriefService → SovereignReconciler\n\ntest('extracted PDF text maps to reconciled sections with word targets', async () => {\n  jest.mock('../../src/services/DocumentAIService', () => ({\n    extractText: jest.fn().mockResolvedValue('Literature Review (500 words)\\nMethodology (300 words)')\n  }));\n\n  const text = await extractText(new Blob(['mock pdf']));\n  const sections = await mapToWorkspace(text, 'tertiary');\n  const reconciled = reconcile(sections);\n\n  expect(reconciled.find(s => /lit/i.test(s.title))?.wordGoal).toBe(500);\n  expect(reconciled.find(s => /method/i.test(s.title))?.wordGoal).toBe(300);\n});\n```\n\n---\n\n## Summary\n\n| Priority | Scope | Files | Coverage |\n|----------|-------|-------|----------|\n| P0 — Now | Core crypto + EventBus | `HistoryOfThought`, `EventBus` | 0% → target 80% |\n| P1 — Next | Executive layer | `ExecutiveSpine`, `SovereignRouter` | 0% → target 80% |\n| P2 — Then | Services | `SovereignReconciler`, `BriefService`, `ChatService` | 0% → target 70% |\n| P3 — Later | Integration flows | 3 flows above | 0% → target 60% |\n| P4 — Future | Frontend components | 32 components | 0% → target 50% |\n\nThe crypto and audit trail code (`HistoryOfThought` + `EventBus`) is the highest risk with zero coverage — a silent encryption bug there destroys the entire authenticity model. Start there.\n",
