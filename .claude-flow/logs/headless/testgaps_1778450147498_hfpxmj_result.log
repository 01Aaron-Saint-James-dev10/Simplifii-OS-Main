      {
        "title": "5. `SovereignReconciler.js` — Untested entirely",
        "content": "\n**Gaps:** Fuzzy title clustering, `normaliseTitle`, `tokenSimilarity`, conflict resolution logic.\n\n```js\n// tests/services/SovereignReconciler.test.js\nimport { reconcile, normaliseTitle, tokenSimilarity } from '../../src/services/SovereignReconciler';\n\ndescribe('SovereignReconciler', () => {\n  test('reconcile clusters fuzzy-matching titles into one section', () => {\n    const briefs = [\n      { title: 'Literature Review', wordGoal: 500 },\n      { title: 'Lit Review Part A', wordGoal: 600 },\n      { title: 'Lit Rev I', wordGoal: 400 }\n    ];\n    const result = reconcile(briefs);\n    expect(result).toHaveLength(1);\n    expect(result[0].wordGoal).toBe(600); // highest wins\n  });\n\n  test('reconcile keeps distinct sections separate', () => {\n    const briefs = [\n      { title: 'Introduction', wordGoal: 200 },\n      { title: 'Methodology', wordGoal: 400 }\n    ];\n    expect(reconcile(briefs)).toHaveLength(2);\n  });\n\n  test('normaliseTitle converts Roman numerals and expands abbreviations', () => {\n    expect(normaliseTitle('Lit Rev III')).toContain('3');\n  });\n\n  test('tokenSimilarity returns 1.0 for identical strings', () => {\n    expect(tokenSimilarity('literature review', 'literature review')).toBe(1.0);\n  });\n\n  test('tokenSimilarity returns 0 for completely different strings', () => {\n    expect(tokenSimilarity('methodology', 'appendix')).toBe(0);\n  });\n\n  test('handles empty brief array', () => {\n    expect(reconcile([])).toEqual([]);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "6. `BriefService.js` — Untested entirely",
        "content": "\n**Gaps:** `extractEvidenceFormula` regex fragility, `mapToWorkspace` level mappings, `extractDynamicThemes`.\n\n```js\n// tests/services/BriefService.test.js\nimport { mapToWorkspace, extractEvidenceFormula } from '../../src/services/BriefService';\n\ndescribe('BriefService — extractEvidenceFormula', () => {\n  test.each([\n    ['Include two primary sources', { primary: 2 }],\n    ['Include 2 primary sources', { primary: 2 }],\n    ['3 primary AND 2 review sources required', { primary: 3, review: 2 }],\n  ])('parses \"%s\" correctly', (text, expected) => {\n    expect(extractEvidenceFormula(text)).toMatchObject(expected);\n  });\n\n  test('does not misparse numbered list items as evidence counts', () => {\n    const text = '1. Introduction\\n2. Methods\\n3. Results';\n    const result = extractEvidenceFormula(text);\n    expect(result.primary).toBeUndefined();\n  });\n\n  test('returns empty object for text with no evidence requirements', () => {\n    expect(extractEvidenceFormula('Write a reflective essay.')).toEqual({});\n  });\n});\n\ndescribe('BriefService — mapToWorkspace', () => {\n  test('maps tertiary brief text to expected section keys', async () => {\n    const sections = await mapToWorkspace('Literature review and methodology required', 'tertiary');\n    expect(sections.some(s => /lit/i.test(s.title))).toBe(true);\n  });\n\n  test('handles empty text without throwing', async () => {\n    await expect(mapToWorkspace('', 'tertiary')).resolves.toBeDefined();\n  });\n});\n```\n\n---\n\n",
        "level": 3
