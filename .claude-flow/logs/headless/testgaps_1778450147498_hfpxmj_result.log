        "language": "js",
        "code": "// tests/core/HistoryOfThought.test.js\nimport { unlockWithPassphrase, lockSession, appendEvent, listEvents, generateAuthenticityReport } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought — crypto pipeline', () => {\n  beforeEach(() => lockSession());\n\n  test('unlockWithPassphrase derives key and sets locked=false', async () => {\n    await unlockWithPassphrase('strongPass123');\n    // assert vault is unlocked\n  });\n\n  test('rejects passphrase shorter than 4 characters', async () => {\n    await expect(unlockWithPassphrase('ab')).rejects.toThrow();\n  });\n\n  test('appendEvent encrypts and stores event; listEvents returns it', async () => {\n    await unlockWithPassphrase('strongPass123');\n    await appendEvent({ type: 'text_edit', payload: { chars: 100 } });\n    const events = await listEvents();\n    expect(events).toHaveLength(1);\n    expect(events[0].type).toBe('text_edit');\n  });\n\n  test('appendEvent is a no-op (silent drop) when vault is locked', async () => {\n    // vault stays locked — no throw, no event stored\n    await appendEvent({ type: 'text_edit', payload: {} });\n    await unlockWithPassphrase('strongPass123');\n    expect(await listEvents()).toHaveLength(0);\n  });\n\n  test('decryption fails gracefully on corrupted envelope', async () => {\n    await unlockWithPassphrase('strongPass123');\n    // manually inject corrupted record into IndexedDB\n    await expect(listEvents()).resolves.toBeDefined(); // doesn't crash\n  });\n\n  test('generateAuthenticityReport aggregates event counts correctly', async () => {\n    await unlockWithPassphrase('pass');\n    await appendEvent({ type: 'focus_start' });\n    await appendEvent({ type: 'text_edit' });\n    await appendEvent({ type: 'focus_start' });\n    const report = await generateAuthenticityReport();\n    expect(report.counts.focus_start).toBe(2);\n    expect(report.counts.text_edit).toBe(1);\n  });\n\n  test('lockSession zeroes the key; appendEvent silently drops after lock', async () => {\n    await unlockWithPassphrase('pass');\n    lockSession();\n    await appendEvent({ type: 'text_edit' });\n    await unlockWithPassphrase('pass');\n    expect(await listEvents()).toHaveLength(0);\n  });\n});"
      },
