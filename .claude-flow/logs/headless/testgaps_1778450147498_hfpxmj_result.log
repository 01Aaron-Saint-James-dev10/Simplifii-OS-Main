      {
        "title": "7. `ChatService.js` / `MicroStepService.js` — Network error handling",
        "content": "\n**Gaps:** Ollama unreachable, partial JSON response, steering dials not applied.\n\n```js\n// tests/services/ChatService.test.js\nimport { getAuraResponse } from '../../src/services/ChatService';\n\nglobal.fetch = jest.fn();\n\nafterEach(() => fetch.mockReset());\n\ndescribe('ChatService — Ollama error handling', () => {\n  test('returns fallback message when Ollama is unreachable', async () => {\n    fetch.mockRejectedValueOnce(new Error('fetch failed'));\n    const result = await getAuraResponse('hello', {});\n    expect(result).toBeTruthy(); // graceful fallback, not thrown\n  });\n\n  test('handles non-JSON response body from Ollama', async () => {\n    fetch.mockResolvedValueOnce({ ok: false, text: () => '<html>503</html>' });\n    await expect(getAuraResponse('hello', {})).resolves.toBeDefined();\n  });\n\n  test('buildSteeringBlock includes all four dials', () => {\n    // inject localStorage dials\n    localStorage.setItem('STEERING_PERSONA', 'literal');\n    localStorage.setItem('STEERING_SCAFFOLDING', 'heavy');\n    // import and call buildSteeringBlock directly\n    // assert output string contains all four dial values\n  });\n});\n```\n\n---\n\n",
