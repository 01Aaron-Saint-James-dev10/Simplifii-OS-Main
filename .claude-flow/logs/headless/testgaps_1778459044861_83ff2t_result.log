        "code": "// tests/core/HistoryOfThought.test.js\n// Requires jest-environment-jsdom with Web Crypto + fake-indexeddb\n\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport,\n  enableCloudSync, EVENT_TYPES\n} from '../../src/core/HistoryOfThought';\n\ndescribe('unlockWithPassphrase — validation', () => {\n  afterEach(() => lockSession());\n\n  test('throws for passphrase shorter than 4 chars', async () => {\n    await expect(unlockWithPassphrase('ab')).rejects.toThrow('at least 4 characters');\n  });\n  test('throws for empty passphrase', async () => {\n    await expect(unlockWithPassphrase('')).rejects.toThrow();\n  });\n  test('throws for non-string passphrase', async () => {\n    await expect(unlockWithPassphrase(1234)).rejects.toThrow();\n  });\n  test('resolves to true for valid passphrase', async () => {\n    const result = await unlockWithPassphrase('correct-passphrase');\n    expect(result).toBe(true);\n  });\n});\n\ndescribe('isUnlocked / lockSession', () => {\n  test('is false before unlock', () => {\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n  test('is true after unlock', async () => {\n    await unlockWithPassphrase('test-pass-1');\n    expect(isUnlocked()).toBe(true);\n    lockSession();\n  });\n  test('is false after lockSession', async () => {\n    await unlockWithPassphrase('test-pass-2');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('appendEvent', () => {\n  afterEach(() => lockSession());\n\n  test('returns null silently when vault is locked', async () => {\n    lockSession();\n    const result = await appendEvent({ event_type: 'text_edit', payload: {} });\n    expect(result).toBeNull();\n  });\n  test('throws for unknown event_type', async () => {\n    await unlockWithPassphrase('test-pass-3');\n    await expect(\n      appendEvent({ event_type: 'INVALID_TYPE', payload: {} })\n    ).rejects.toThrow('Unknown event_type');\n  });\n});\n\ndescribe('enableCloudSync', () => {\n  test('always throws — transport not wired', () => {\n    expect(() => enableCloudSync()).toThrow();\n  });\n});\n\ndescribe('generateAuthenticityReport — locked vault', () => {\n  test('throws when vault is locked', async () => {\n    lockSession();\n    await expect(generateAuthenticityReport()).rejects.toThrow('Vault locked');\n  });\n});\n\ndescribe('EVENT_TYPES', () => {\n  test('is frozen', () => {\n    expect(Object.isFrozen(EVENT_TYPES)).toBe(true);\n  });\n  test('contains expected types', () => {\n    expect(EVENT_TYPES).toContain('text_edit');\n    expect(EVENT_TYPES).toContain('focus_session_start');\n  });\n});\n\n// Integration: full round-trip\ndescribe('round-trip: unlock → append → list → report', () => {\n  beforeAll(() => lockSession());\n  afterAll(() => lockSession());\n\n  test('appended event appears in listEvents and report', async () => {\n    await unlockWithPassphrase('integration-pass');\n    await appendEvent({\n      user_id: 'test-user',\n      stream_id: 'tertiary',\n      event_type: 'text_edit',\n      payload: { sectionId: 'intro', wordsAfter: 100 }\n    });\n    const events = await listEvents({ user_id: 'test-user' });\n    expect(events.length).toBeGreaterThan(0);\n    const report = await generateAuthenticityReport({ user_id: 'test-user' });\n    expect(report.totalEvents).toBeGreaterThan(0);\n    expect(report.countsByType.text_edit).toBeGreaterThanOrEqual(1);\n  });\n});"
