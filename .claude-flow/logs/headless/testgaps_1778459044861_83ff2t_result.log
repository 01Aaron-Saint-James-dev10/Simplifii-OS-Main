        "title": "2. `SovereignRouter.js` — Pure logic, easy to test",
        "content": "\n**Gaps:**\n- No test for `streamFromLevel` with every `LEVEL_TO_STREAM` key\n- No test for unmapped / garbage level values defaulting to `'tertiary'`\n- No test for `isValidStream` with valid and invalid IDs\n- No test for `hydrate` with no session (should default to tertiary)\n- No test for `hydrate` with explicit `streamId` bypassing level lookup\n- No test for `hydrate.canAccess` returning false for unlisted modules\n- No test for `applyTheme` in a non-browser environment (no-op guard)\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, __internals } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  const cases = [\n    ['primary', 'primary'],\n    ['secondary', 'secondary'],\n    ['highschool', 'secondary'],\n    ['tafe', 'tafe'],\n    ['homeschool', 'homeschool'],\n    ['university', 'tertiary'],\n    ['undergrad', 'tertiary'],\n    ['honours', 'tertiary'],\n    ['mres', 'tertiary'],\n    ['phd', 'tertiary'],\n  ];\n  test.each(cases)('level \"%s\" → stream \"%s\"', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('unmapped level defaults to tertiary', () => {\n    expect(streamFromLevel('unknown-level')).toBe('tertiary');\n  });\n  test('null/undefined defaults to tertiary', () => {\n    expect(streamFromLevel(null)).toBe('tertiary');\n    expect(streamFromLevel(undefined)).toBe('tertiary');\n  });\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('UNIVERSITY')).toBe('tertiary');\n    expect(streamFromLevel('Primary')).toBe('primary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('valid stream IDs return true', () => {\n    ['primary', 'secondary', 'tertiary', 'tafe', 'homeschool'].forEach(id => {\n      expect(isValidStream(id)).toBe(true);\n    });\n  });\n  test('invalid stream ID returns false', () => {\n    expect(isValidStream('postgrad')).toBe(false);\n    expect(isValidStream('')).toBe(false);\n    expect(isValidStream(null)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('empty session defaults to tertiary', () => {\n    const result = hydrate({});\n    expect(result.streamId).toBe('tertiary');\n  });\n  test('explicit valid streamId is honoured', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.streamId).toBe('primary');\n  });\n  test('invalid streamId falls back via level', () => {\n    const result = hydrate({ streamId: 'bogus', profile: { level: 'tafe' } });\n    expect(result.streamId).toBe('tafe');\n  });\n  test('returns canAccess function', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.canAccess).toBe('function');\n  });\n  test('canAccess returns false for unknown module', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(result.canAccess('__nonexistent_module__')).toBe(false);\n  });\n  test('getDefaultLanding returns a string', () => {\n    const result = hydrate({});\n    expect(typeof result.getDefaultLanding()).toBe('string');\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "3. `ExecutiveSpine.js` — localStorage + timer logic",
        "content": "\n**Gaps:**\n- No test for `configureSpine` clamping threshold to [1,5] and minutes to [1,60]\n- No test for `startFocusSession` writing to localStorage\n- No test for `endFocusSession` when no session exists (returns null)\n- No test for `getFocusSession` returning null after session expires\n- No test for `isFocusActive` toggling correctly\n- No test for `setSectionHealth` clamping to [0,5]\n- No test for `setSectionHealth` NOT dispatching event when value is unchanged\n- No test for PlayTime auto-grant when health crosses `__unlockThreshold`\n- No test for `earnCredits` with zero or negative input\n- No test for `spendCredits` when amount exceeds balance (returns current balance unchanged)\n- No test for `__nativeBlockingDoesNotExist` always returning true\n\n```js\n// tests/core/ExecutiveSpine.test.js\nimport {\n  configureSpine,\n  startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  getSectionHealth, setSectionHealth,\n  grantPlayTime, isPlayTimeActive,\n  getCredits, earnCredits, spendCredits,\n  __nativeBlockingDoesNotExist,\n  __internals\n} from '../../src/core/ExecutiveSpine';\n\n// localStorage mock is provided by jsdom in jest\n\nbeforeEach(() => {\n  localStorage.clear();\n  jest.useFakeTimers();\n  // Reset module-level state between tests by clearing LS keys\n  Object.values(__internals).forEach(k => localStorage.removeItem(k));\n});\n\nafterEach(() => {\n  jest.useRealTimers();\n});\n\ndescribe('configureSpine', () => {\n  test('clamps threshold below 1 to 1', () => {\n    configureSpine({ sectionHealthUnlockThreshold: -5 });\n    // Verify indirectly: health at 1 should fire playtime\n    setSectionHealth('s1', 1); // threshold is now 1, so 0→1 should grant\n    expect(localStorage.getItem(__internals.PLAYTIME_KEY)).toBeTruthy();\n  });\n  test('clamps playtime minutes above 60 to 60', () => {\n    configureSpine({ defaultPlaytimeMinutes: 999 });\n    const until = grantPlayTime({ minutes: 999 });\n    expect(until - Date.now()).toBeLessThanOrEqual(60 * 60 * 1000 + 500);\n  });\n});\n\ndescribe('FocusSession', () => {\n  test('startFocusSession writes to localStorage', () => {\n    startFocusSession({ taskId: 'task-1', durationMinutes: 25 });\n    const raw = localStorage.getItem(__internals.FOCUS_KEY);\n    expect(JSON.parse(raw).taskId).toBe('task-1');\n  });\n  test('isFocusActive returns true after start', () => {\n    startFocusSession({ durationMinutes: 25 });\n    expect(isFocusActive()).toBe(true);\n  });\n  test('endFocusSession returns session and clears storage', () => {\n    startFocusSession({ taskId: 'task-2', durationMinutes: 25 });\n    const result = endFocusSession({ reason: 'manual' });\n    expect(result.taskId).toBe('task-2');\n    expect(result.reason).toBe('manual');\n    expect(isFocusActive()).toBe(false);\n  });\n  test('endFocusSession with no active session returns null', () => {\n    expect(endFocusSession()).toBeNull();\n  });\n  test('getFocusSession returns null after session expires', () => {\n    startFocusSession({ durationMinutes: 1 });\n    // Fast-forward past expiry\n    jest.advanceTimersByTime(2 * 60 * 1000);\n    expect(getFocusSession()).toBeNull();\n  });\n});\n\ndescribe('SectionHealth', () => {\n  test('returns 0 for unknown sectionId', () => {\n    expect(getSectionHealth('unknown')).toBe(0);\n  });\n  test('setSectionHealth clamps above 5 to 5', () => {\n    expect(setSectionHealth('s1', 10)).toBe(5);\n  });\n  test('setSectionHealth clamps below 0 to 0', () => {\n    expect(setSectionHealth('s1', -3)).toBe(0);\n  });\n  test('setSectionHealth returns same value without dispatching when unchanged', () => {\n    setSectionHealth('s1', 3);\n    const dispatchSpy = jest.spyOn(window, 'dispatchEvent');\n    setSectionHealth('s1', 3); // same value\n    expect(dispatchSpy).not.toHaveBeenCalled();\n  });\n});\n\ndescribe('SovereignCredits', () => {\n  test('getCredits returns 0 on fresh state', () => {\n    expect(getCredits()).toBe(0);\n  });\n  test('earnCredits increases balance', () => {\n    const balance = earnCredits(10, 'test');\n    expect(balance).toBe(10);\n    expect(getCredits()).toBe(10);\n  });\n  test('earnCredits with 0 is a no-op', () => {\n    earnCredits(5);\n    const before = getCredits();\n    earnCredits(0);\n    expect(getCredits()).toBe(before);\n  });\n  test('spendCredits reduces balance', () => {\n    earnCredits(20);\n    const remaining = spendCredits(5);\n    expect(remaining).toBe(15);\n  });\n  test('spendCredits with amount exceeding balance returns current balance', () => {\n    earnCredits(5);\n    const remaining = spendCredits(100);\n    expect(remaining).toBe(5); // unchanged\n  });\n});\n\ndescribe('Blueprint guard', () => {\n  test('__nativeBlockingDoesNotExist always returns true', () => {\n    expect(__nativeBlockingDoesNotExist()).toBe(true);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "4. `EventBus.js` — Event wiring + vault-locked drop",
        "content": "\n**Gaps:**\n- No test that events are silently dropped when vault is locked\n- No test that `stopEventBus` removes all listeners\n- No test that re-calling `startEventBus` doesn't double-register listeners\n- No test for `recordTextEdit` with vault locked (no-op)\n- No test for `recordCitation` with `added: false` emitting `citation_removed`\n- No test for `pickSafePayload` stripping unexpected fields\n\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../src/core/EventBus';\nimport * as HoT from '../../src/core/HistoryOfThought';\n\njest.mock('../../src/core/HistoryOfThought', () => ({\n  isUnlocked: jest.fn(() => false),\n  appendEvent: jest.fn(() => Promise.resolve()),\n  EVENT_TYPES: ['focus_session_start', 'focus_session_end', 'nudge_triggered',\n    'section_health_change', 'playtime_granted', 'playtime_expired',\n    'ai_assist_invoked', 'text_edit', 'citation_added', 'citation_removed']\n}));\n\nafterEach(() => {\n  stopEventBus();\n  jest.clearAllMocks();\n});\n\ndescribe('recordTextEdit — vault locked', () => {\n  test('does not call appendEvent when vault is locked', async () => {\n    HoT.isUnlocked.mockReturnValue(false);\n    await recordTextEdit({ sectionId: 'intro', wordsAfter: 50 });\n    expect(HoT.appendEvent).not.toHaveBeenCalled();\n  });\n});\n\ndescribe('recordTextEdit — vault unlocked', () => {\n  test('calls appendEvent with sanitised payload', async () => {\n    HoT.isUnlocked.mockReturnValue(true);\n    await recordTextEdit({ sectionId: 'intro', wordsAfter: 50, debounceWindowMs: 300 });\n    expect(HoT.appendEvent).toHaveBeenCalledWith(expect.objectContaining({\n      event_type: 'text_edit',\n      payload: expect.objectContaining({ sectionId: 'intro', wordsAfter: 50 })\n    }));\n  });\n});\n\ndescribe('recordCitation', () => {\n  test('citation_added when added: true', async () => {\n    HoT.isUnlocked.mockReturnValue(true);\n    await recordCitation({ added: true, source: 'Smith 2020', sourceId: 'ref-1' });\n    expect(HoT.appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'citation_added' }));\n  });\n  test('citation_removed when added: false', async () => {\n    HoT.isUnlocked.mockReturnValue(true);\n    await recordCitation({ added: false, source: 'Smith 2020', sourceId: 'ref-1' });\n    expect(HoT.appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'citation_removed' }));\n  });\n});\n\ndescribe('startEventBus / stopEventBus', () => {\n  test('double start does not attach listeners twice', () => {\n    const spy = jest.spyOn(window, 'addEventListener');\n    startEventBus();\n    const countAfterFirst = spy.mock.calls.length;\n    startEventBus(); // second call — should stop first, then re-register\n    const countAfterSecond = spy.mock.calls.length;\n    expect(countAfterSecond - countAfterFirst).toBe(countAfterFirst); // same delta\n    spy.mockRestore();\n  });\n  test('stopEventBus removes all registered listeners', () => {\n    const spy = jest.spyOn(window, 'removeEventListener');\n    startEventBus();\n    stopEventBus();\n    // 8 SPINE_TO_HOT entries should be removed\n    expect(spy.mock.calls.length).toBeGreaterThanOrEqual(8);\n    spy.mockRestore();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "5. `HistoryOfThought.js` — Crypto + IndexedDB",
        "content": "\n**Gaps:**\n- No test for `unlockWithPassphrase` rejecting passphrases shorter than 4 chars\n- No test for `isUnlocked` toggling after unlock/lock\n- No test for `appendEvent` with an unknown event_type throwing\n- No test for `appendEvent` silently returning null when vault is locked\n- No test for `enableCloudSync` always throwing\n- No test for `generateAuthenticityReport` throwing when vault is locked\n- Integration gap: full round-trip (unlock → append → listEvents → report) never tested\n\n```js\n// tests/core/HistoryOfThought.test.js\n// Requires jest-environment-jsdom with Web Crypto + fake-indexeddb\n\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport,\n  enableCloudSync, EVENT_TYPES\n} from '../../src/core/HistoryOfThought';\n\ndescribe('unlockWithPassphrase — validation', () => {\n  afterEach(() => lockSession());\n\n  test('throws for passphrase shorter than 4 chars', async () => {\n    await expect(unlockWithPassphrase('ab')).rejects.toThrow('at least 4 characters');\n  });\n  test('throws for empty passphrase', async () => {\n    await expect(unlockWithPassphrase('')).rejects.toThrow();\n  });\n  test('throws for non-string passphrase', async () => {\n    await expect(unlockWithPassphrase(1234)).rejects.toThrow();\n  });\n  test('resolves to true for valid passphrase', async () => {\n    const result = await unlockWithPassphrase('correct-passphrase');\n    expect(result).toBe(true);\n  });\n});\n\ndescribe('isUnlocked / lockSession', () => {\n  test('is false before unlock', () => {\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n  test('is true after unlock', async () => {\n    await unlockWithPassphrase('test-pass-1');\n    expect(isUnlocked()).toBe(true);\n    lockSession();\n  });\n  test('is false after lockSession', async () => {\n    await unlockWithPassphrase('test-pass-2');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('appendEvent', () => {\n  afterEach(() => lockSession());\n\n  test('returns null silently when vault is locked', async () => {\n    lockSession();\n    const result = await appendEvent({ event_type: 'text_edit', payload: {} });\n    expect(result).toBeNull();\n  });\n  test('throws for unknown event_type', async () => {\n    await unlockWithPassphrase('test-pass-3');\n    await expect(\n      appendEvent({ event_type: 'INVALID_TYPE', payload: {} })\n    ).rejects.toThrow('Unknown event_type');\n  });\n});\n\ndescribe('enableCloudSync', () => {\n  test('always throws — transport not wired', () => {\n    expect(() => enableCloudSync()).toThrow();\n  });\n});\n\ndescribe('generateAuthenticityReport — locked vault', () => {\n  test('throws when vault is locked', async () => {\n    lockSession();\n    await expect(generateAuthenticityReport()).rejects.toThrow('Vault locked');\n  });\n});\n\ndescribe('EVENT_TYPES', () => {\n  test('is frozen', () => {\n    expect(Object.isFrozen(EVENT_TYPES)).toBe(true);\n  });\n  test('contains expected types', () => {\n    expect(EVENT_TYPES).toContain('text_edit');\n    expect(EVENT_TYPES).toContain('focus_session_start');\n  });\n});\n\n// Integration: full round-trip\ndescribe('round-trip: unlock → append → list → report', () => {\n  beforeAll(() => lockSession());\n  afterAll(() => lockSession());\n\n  test('appended event appears in listEvents and report', async () => {\n    await unlockWithPassphrase('integration-pass');\n    await appendEvent({\n      user_id: 'test-user',\n      stream_id: 'tertiary',\n      event_type: 'text_edit',\n      payload: { sectionId: 'intro', wordsAfter: 100 }\n    });\n    const events = await listEvents({ user_id: 'test-user' });\n    expect(events.length).toBeGreaterThan(0);\n    const report = await generateAuthenticityReport({ user_id: 'test-user' });\n    expect(report.totalEvents).toBeGreaterThan(0);\n    expect(report.countsByType.text_edit).toBeGreaterThanOrEqual(1);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Setup Required",
        "content": "\nBefore any tests run, add to `package.json`:\n\n```json\n{\n  \"devDependencies\": {\n    \"@jest/globals\": \"^29\",\n    \"jest\": \"^29\",\n    \"jest-environment-jsdom\": \"^29\",\n    \"fake-indexeddb\": \"^5\"\n  },\n  \"scripts\": {\n    \"test\": \"jest\"\n  },\n  \"jest\": {\n    \"testEnvironment\": \"jsdom\",\n    \"setupFiles\": [\"fake-indexeddb/auto\"]\n  }\n}\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "Summary of Gaps",
        "content": "| Module | Untested functions | Highest-risk gap |\n|---|---|---|\n| `LiteralMode` | All 15 patterns, both exports | Wrong substitution silently corrupts student output |\n| `SovereignRouter` | All 4 exports | Invalid streamId could expose wrong capability set |\n| `ExecutiveSpine` | All 13 exports | Credits/playtime persist across tests — no isolation |\n| `EventBus` | All 4 exports | Vault-locked events must drop silently — Blueprint hard rule |\n| `HistoryOfThought` | All 6 exports | Encryption round-trip failure = silent data loss |\n\nThe highest-priority test to write first is `HistoryOfThought` because a regression there causes silent event loss with no UI indicator — and that directly undermines the Authenticity Report that is the student's marker-defensible proof of authorship.",
        "level": 2
      }
    ],
    "codeBlocks": [
      {
        "language": "js",
        "code": "// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../../src/core/LiteralMode';\n\ndescribe('sanitiseDashes', () => {\n  const { sanitiseDashes } = __internals;\n\n  test('replaces em-dash with comma', () => {\n    expect(sanitiseDashes('foo\\u2014bar')).toBe('foo,bar');\n  });\n  test('replaces en-dash with comma', () => {\n    expect(sanitiseDashes('foo\\u2013bar')).toBe('foo,bar');\n  });\n  test('passes through plain string unchanged', () => {\n    expect(sanitiseDashes('hello world')).toBe('hello world');\n  });\n});\n\ndescribe('literalise — non-string passthrough', () => {\n  test('returns null unchanged', () => expect(literalise(null)).toBeNull());\n  test('returns undefined unchanged', () => expect(literalise(undefined)).toBeUndefined());\n  test('returns empty string unchanged', () => expect(literalise('')).toBe(''));\n  test('returns number unchanged', () => expect(literalise(42)).toBe(42));\n});\n\ndescribe('literalise — pattern substitutions', () => {\n  test('consider revising → change', () => {\n    expect(literalise('Consider revising your introduction.')).toContain('change');\n  });\n  test('in order to → to', () => {\n    expect(literalise('in order to pass you must')).toContain('to pass');\n  });\n  test('synthesise → combine ideas from', () => {\n    expect(literalise('You should synthesise the literature.')).toContain('combine ideas from');\n  });\n  test('furthermore → also', () => {\n    expect(literalise('Furthermore, the data shows')).toContain('also');\n  });\n  test('should be revised → rewrite this', () => {\n    expect(literalise('This section should be revised.')).toContain('rewrite this');\n  });\n  test('are required to → must', () => {\n    expect(literalise('Students are required to submit by Friday.')).toContain('must');\n  });\n});\n\ndescribe('literalise — splitClauses', () => {\n  test('splits on semicolon by default', () => {\n    const out = literalise('Write the intro; revise the body');\n    expect(out).toContain('. ');\n  });\n  test('does NOT split when splitClauses: false', () => {\n    const out = literalise('Write the intro; revise the body', { splitClauses: false });\n    expect(out).toContain(';');\n  });\n});\n\ndescribe('literalise — capitalisation after deletion', () => {\n  test('capitalises first word after going-forward deletion', () => {\n    const out = literalise('Going forward, write clearly.');\n    expect(out[0]).toBe(out[0].toUpperCase());\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('userPreference: true always returns true', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true);\n  });\n  test('userPreference: false always returns false', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false);\n  });\n  test('falls back to streamProfile when preference is null', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n  });\n  test('returns false when profile is undefined and preference is null', () => {\n    expect(shouldLiteralise(undefined, null)).toBe(false);\n  });\n});"
      },
