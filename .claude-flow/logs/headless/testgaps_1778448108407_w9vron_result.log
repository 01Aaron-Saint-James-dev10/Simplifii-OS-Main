        "title": "F. SovereignReconciler.js — Fuzzy Clustering",
        "content": "```js\n// tests/services/SovereignReconciler.test.js\nimport { reconcile, normaliseTitle, tokenSimilarity } from '../../src/services/SovereignReconciler';\n\ndescribe('normaliseTitle', () => {\n  it('lowercases and strips weight suffixes', () => {\n    expect(normaliseTitle('Essay (30%)')).not.toContain('30%');\n    expect(normaliseTitle('ESSAY (30%)')).toEqual(normaliseTitle('essay'));\n  });\n\n  it('converts roman numerals to arabic', () => {\n    const t = normaliseTitle('Assignment ii');\n    expect(t).toContain('2');\n  });\n\n  it('handles empty string', () => {\n    expect(() => normaliseTitle('')).not.toThrow();\n  });\n});\n\ndescribe('tokenSimilarity', () => {\n  it('returns 1.0 for identical sets', () => {\n    expect(tokenSimilarity(['a', 'b'], ['a', 'b'])).toBe(1.0);\n  });\n\n  it('returns 0 for disjoint sets', () => {\n    expect(tokenSimilarity(['a', 'b'], ['c', 'd'])).toBe(0);\n  });\n\n  it('returns 0 for empty arrays', () => {\n    expect(tokenSimilarity([], [])).toBe(0);\n  });\n\n  it('handles threshold boundary (0.6)', () => {\n    // 2 shared of 4 total unique = Jaccard 0.5 — below threshold\n    const a = ['research', 'essay'];\n    const b = ['research', 'report'];\n    expect(tokenSimilarity(a, b)).toBeLessThan(0.6);\n  });\n});\n\ndescribe('reconcile', () => {\n  it('returns empty array for empty input', () => {\n    expect(reconcile([])).toEqual([]);\n  });\n\n  it('returns empty array for null input', () => {\n    expect(reconcile(null)).toEqual([]);\n  });\n\n  it('deduplicates equivalent assessment titles', () => {\n    const briefs = [\n      { title: 'Research Essay (30%)', source: 'docA' },\n      { title: 'Research Essay 30', source: 'docB' },\n    ];\n    const result = reconcile(briefs);\n    expect(result.length).toBe(1);\n  });\n\n  it('assigns canonical IDs (assessment_alpha pattern)', () => {\n    const briefs = [{ title: 'Essay', source: 'docA' }];\n    const result = reconcile(briefs);\n    expect(result[0].canonicalId).toMatch(/^assessment_/);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "G. ChatService.js / RewriteService.js — Ollama Network Layer",
        "content": "```js\n// tests/services/ChatService.test.js\nimport { askAura } from '../../src/services/ChatService';\n\nglobal.fetch = jest.fn();\n\nafterEach(() => jest.resetAllMocks());\n\ndescribe('askAura', () => {\n  it('throws on empty message', async () => {\n    await expect(askAura('', {}, [])).rejects.toThrow();\n  });\n\n  it('throws on network failure', async () => {\n    fetch.mockRejectedValueOnce(new Error('Network Error'));\n    await expect(askAura('Hello', {}, [])).rejects.toThrow('Network Error');\n  });\n\n  it('throws on non-2xx HTTP status', async () => {\n    fetch.mockResolvedValueOnce({ ok: false, status: 500, json: async () => ({}) });\n    await expect(askAura('Hello', {}, [])).rejects.toThrow();\n  });\n\n  it('surfaces model-not-found error for 404', async () => {\n    fetch.mockResolvedValueOnce({ ok: false, status: 404, json: async () => ({}) });\n    await expect(askAura('Hello', {}, [])).rejects.toThrow(/model/i);\n  });\n\n  it('returns cleaned string on success', async () => {\n    fetch.mockResolvedValueOnce({\n      ok: true,\n      json: async () => ({ message: { content: 'Here is your answer.' } }),\n    });\n    const result = await askAura('Hello', {}, []);\n    expect(typeof result).toBe('string');\n    expect(result.length).toBeGreaterThan(0);\n  });\n\n  it('slices history to last 6 entries', async () => {\n    fetch.mockResolvedValueOnce({\n      ok: true,\n      json: async () => ({ message: { content: 'ok' } }),\n    });\n    const longHistory = Array(20).fill({ role: 'user', content: 'msg' });\n    await askAura('Hello', {}, longHistory);\n    const body = JSON.parse(fetch.mock.calls[0][1].body);\n    // system prompt + last 6 history + current = ≤8 messages\n    expect(body.messages.length).toBeLessThanOrEqual(8);\n  });\n});\n```\n\n---\n\n",
