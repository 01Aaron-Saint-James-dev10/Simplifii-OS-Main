        "content": "```js\n// tests/core/ExecutiveSpine.test.js\nimport { ExecutiveSpine } from '../../src/core/ExecutiveSpine';\n\nbeforeEach(() => localStorage.clear());\n\ndescribe('FocusSession', () => {\n  it('starts a session and persists it to localStorage', () => {\n    const spine = new ExecutiveSpine();\n    spine.startFocusSession({ taskId: 'task-1', durationMinutes: 25 });\n    expect(spine.isFocusActive()).toBe(true);\n  });\n\n  it('returns null for expired session', () => {\n    const spine = new ExecutiveSpine();\n    spine.startFocusSession({ taskId: 'task-1', durationMinutes: 0.001 });\n    // Fast-forward time by manipulating stored endsAt\n    const stored = JSON.parse(localStorage.getItem('exec_focus_session'));\n    stored.endsAt = Date.now() - 1;\n    localStorage.setItem('exec_focus_session', JSON.stringify(stored));\n    expect(spine.getFocusSession()).toBeNull();\n  });\n\n  it('handles missing taskId by defaulting to \"unscoped\"', () => {\n    const spine = new ExecutiveSpine();\n    spine.startFocusSession({ durationMinutes: 25 });\n    expect(spine.getFocusSession().taskId).toBe('unscoped');\n  });\n\n  it('endFocusSession is safe when no session is active', () => {\n    const spine = new ExecutiveSpine();\n    expect(() => spine.endFocusSession({ reason: 'manual' })).not.toThrow();\n  });\n\n  it('replaces existing session on repeated startFocusSession calls', () => {\n    const spine = new ExecutiveSpine();\n    spine.startFocusSession({ taskId: 'first', durationMinutes: 25 });\n    spine.startFocusSession({ taskId: 'second', durationMinutes: 10 });\n    expect(spine.getFocusSession().taskId).toBe('second');\n  });\n});\n\ndescribe('SectionHealth', () => {\n  it('clamps dots to 0-5 range', () => {\n    const spine = new ExecutiveSpine();\n    spine.setSectionHealth('sec-1', 10);\n    expect(spine.getSectionHealth('sec-1')).toBe(5);\n    spine.setSectionHealth('sec-1', -3);\n    expect(spine.getSectionHealth('sec-1')).toBe(0);\n  });\n\n  it('returns 0 for unknown sectionId', () => {\n    const spine = new ExecutiveSpine();\n    expect(spine.getSectionHealth('nonexistent')).toBe(0);\n  });\n\n  it('handles corrupted localStorage gracefully', () => {\n    localStorage.setItem('exec_section_health', 'NOT_JSON');\n    const spine = new ExecutiveSpine();\n    expect(() => spine.getSectionHealth('any')).not.toThrow();\n  });\n});\n\ndescribe('SovereignCredits', () => {\n  it('starts at 0', () => {\n    const spine = new ExecutiveSpine();\n    expect(spine.getCredits()).toBe(0);\n  });\n\n  it('earns credits correctly', () => {\n    const spine = new ExecutiveSpine();\n    spine.earnCredits(10, 'test');\n    expect(spine.getCredits()).toBe(10);\n  });\n\n  it('does not earn negative credits', () => {\n    const spine = new ExecutiveSpine();\n    spine.earnCredits(-5, 'cheat');\n    expect(spine.getCredits()).toBe(0);\n  });\n\n  it('spend does not go below zero', () => {\n    const spine = new ExecutiveSpine();\n    spine.earnCredits(5, 'test');\n    spine.spendCredits(100, 'overspend');\n    expect(spine.getCredits()).toBe(0);\n  });\n\n  it('spend boundary: exact balance', () => {\n    const spine = new ExecutiveSpine();\n    spine.earnCredits(10, 'test');\n    spine.spendCredits(10, 'exact');\n    expect(spine.getCredits()).toBe(0);\n  });\n});\n\ndescribe('configureSpine', () => {\n  it('accepts valid configuration', () => {\n    const spine = new ExecutiveSpine();\n    expect(() => spine.configureSpine({ idleThresholdMs: 60000, playtimeCapMinutes: 30 })).not.toThrow();\n  });\n\n  it('ignores invalid threshold values', () => {\n    const spine = new ExecutiveSpine();\n    spine.configureSpine({ idleThresholdMs: -1 }); // should use default\n    expect(() => spine.startIdleDetection({ thresholdMs: -1 })).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "C. EventBus.js — Event Flow",
        "content": "```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../src/core/EventBus';\n\nconst mockContext = () => ({ userId: 'u1', streamId: 's1' });\n\nafterEach(() => stopEventBus());\n\ndescribe('startEventBus / stopEventBus', () => {\n  it('attaches and removes listeners without errors', () => {\n    expect(() => startEventBus(mockContext)).not.toThrow();\n    expect(() => stopEventBus()).not.toThrow();\n  });\n\n  it('is safe to call stopEventBus when not started', () => {\n    expect(() => stopEventBus()).not.toThrow();\n  });\n\n  it('survives multiple start calls (idempotent)', () => {\n    startEventBus(mockContext);\n    expect(() => startEventBus(mockContext)).not.toThrow();\n  });\n});\n\ndescribe('recordTextEdit', () => {\n  it('handles null sectionId gracefully', () => {\n    startEventBus(mockContext);\n    expect(() => recordTextEdit({ sectionId: null, wordsAfter: 50 })).not.toThrow();\n  });\n\n  it('handles negative wordsAfter', () => {\n    startEventBus(mockContext);\n    expect(() => recordTextEdit({ sectionId: 'sec-1', wordsAfter: -10 })).not.toThrow();\n  });\n});\n\ndescribe('recordCitation', () => {\n  it('routes added=true to citation_added', () => {\n    startEventBus(mockContext);\n    const spy = jest.spyOn(window, 'dispatchEvent');\n    recordCitation({ added: true, source: 'Smith 2020', sourceId: 'ref-1' });\n    expect(spy).toHaveBeenCalled();\n  });\n\n  it('truncates source to 120 chars', () => {\n    startEventBus(mockContext);\n    const longSource = 'A'.repeat(200);\n    expect(() => recordCitation({ added: true, source: longSource })).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "D. LiteralMode.js — Vocab Transformer",
        "content": "```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('literalise', () => {\n  it('returns empty string unchanged', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  it('returns non-string input unchanged', () => {\n    expect(literalise(null)).toBeNull();\n    expect(literalise(42)).toBe(42);\n  });\n\n  it('replaces \"consider revising\" (case-insensitive)', () => {\n    expect(literalise('Consider Revising your argument.')).not.toContain('Consider Revising');\n  });\n\n  it('replaces multiple patterns in one pass', () => {\n    const input = 'It is recommended that you consider revising your argument.';\n    const output = literalise(input);\n    expect(output).not.toContain('It is recommended that');\n    expect(output).not.toContain('consider revising');\n  });\n\n  it('splits on semicolons when splitClauses=true (default)', () => {\n    const output = literalise('Write the intro; then add evidence');\n    expect(output).not.toContain(';');\n  });\n\n  it('preserves semicolons when splitClauses=false', () => {\n    const output = literalise('Write; then add', { splitClauses: false });\n    expect(output).toContain(';');\n  });\n\n  it('handles text with only whitespace', () => {\n    expect(literalise('   ')).toBeDefined();\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  it('returns false when streamProfile is null', () => {\n    expect(shouldLiteralise(null, null)).toBe(false);\n  });\n\n  it('uses stream default when userPreference is null', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n\n  it('overrides stream default with explicit userPreference', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true);\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "E. SovereignRouter.js — Stream Resolution",
        "content": "```js\n// tests/core/SovereignRouter.test.js\nimport { SovereignRouter } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  it('maps known levels to correct stream IDs', () => {\n    const r = new SovereignRouter();\n    expect(r.streamFromLevel('undergraduate')).toBe('tertiary');\n    expect(r.streamFromLevel('primary')).toBe('primary');\n  });\n\n  it('returns null/undefined for unknown level', () => {\n    const r = new SovereignRouter();\n    const result = r.streamFromLevel('notastream');\n    expect(result == null || typeof result === 'string').toBe(true);\n  });\n});\n\ndescribe('hydrate', () => {\n  it('falls back to tertiary for invalid streamId', () => {\n    const r = new SovereignRouter();\n    const result = r.hydrate({ streamId: 'INVALID_ID' });\n    expect(result.stream.id).toBe('tertiary');\n  });\n\n  it('handles null session gracefully', () => {\n    const r = new SovereignRouter();\n    expect(() => r.hydrate(null)).not.toThrow();\n  });\n\n  it('includes capabilities array', () => {\n    const r = new SovereignRouter();\n    const result = r.hydrate({ streamId: 'tertiary' });\n    expect(Array.isArray(result.capabilities)).toBe(true);\n  });\n});\n\ndescribe('canAccess', () => {\n  it('returns false for unknown module', () => {\n    const r = new SovereignRouter();\n    const ctx = r.hydrate({ streamId: 'tertiary' });\n    expect(r.canAccess(ctx, 'NON_EXISTENT_MODULE')).toBe(false);\n  });\n});\n\ndescribe('applyTheme', () => {\n  it('does not throw when document is available', () => {\n    const r = new SovereignRouter();\n    const ctx = r.hydrate({ streamId: 'tertiary' });\n    expect(() => r.applyTheme(ctx.stream)).not.toThrow();\n  });\n\n  it('is idempotent on repeated calls', () => {\n    const r = new SovereignRouter();\n    const ctx = r.hydrate({ streamId: 'tertiary' });\n    r.applyTheme(ctx.stream);\n    expect(() => r.applyTheme(ctx.stream)).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
