        "language": "js",
        "code": "// tests/core/HistoryOfThought.test.js\nimport { HistoryOfThought } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought – salt management', () => {\n  it('generates a 16-byte salt when none exists', async () => {\n    localStorage.clear();\n    const hot = new HistoryOfThought();\n    const salt = await hot.ensureSalt();\n    expect(salt).toBeInstanceOf(Uint8Array);\n    expect(salt.length).toBeGreaterThanOrEqual(16);\n  });\n\n  it('returns the same salt on repeated calls', async () => {\n    const hot = new HistoryOfThought();\n    const s1 = await hot.ensureSalt();\n    const s2 = await hot.ensureSalt();\n    expect(s1).toEqual(s2);\n  });\n\n  it('handles corrupted base64 in localStorage gracefully', async () => {\n    localStorage.setItem('hot_salt', '!!!not-base64!!!');\n    const hot = new HistoryOfThought();\n    await expect(hot.ensureSalt()).resolves.toBeInstanceOf(Uint8Array);\n  });\n});\n\ndescribe('HistoryOfThought – key derivation & unlock', () => {\n  it('rejects passphrase shorter than 4 chars', async () => {\n    const hot = new HistoryOfThought();\n    await expect(hot.unlockWithPassphrase('abc')).rejects.toThrow();\n  });\n\n  it('derives a CryptoKey from a valid passphrase', async () => {\n    const hot = new HistoryOfThought();\n    const key = await hot.unlockWithPassphrase('correct-passphrase');\n    expect(key).toBeDefined();\n  });\n});\n\ndescribe('HistoryOfThought – encrypt / decrypt round-trip', () => {\n  it('encrypts then decrypts payload identically', async () => {\n    const hot = new HistoryOfThought();\n    await hot.unlockWithPassphrase('test-passphrase-ok');\n    const original = { event: 'test', value: 42 };\n    const envelope = await hot.encryptPayload(original);\n    const decrypted = await hot.decryptPayload(envelope);\n    expect(decrypted).toEqual(original);\n  });\n\n  it('rejects tampered ciphertext (AES-GCM auth tag)', async () => {\n    const hot = new HistoryOfThought();\n    await hot.unlockWithPassphrase('test-passphrase-ok');\n    const envelope = await hot.encryptPayload({ x: 1 });\n    envelope.ct = envelope.ct.slice(0, -4) + 'AAAA'; // tamper\n    await expect(hot.decryptPayload(envelope)).rejects.toThrow();\n  });\n\n  it('rejects decryption with a different key', async () => {\n    const hot1 = new HistoryOfThought();\n    await hot1.unlockWithPassphrase('passphrase-A');\n    const envelope = await hot1.encryptPayload({ secret: true });\n\n    const hot2 = new HistoryOfThought();\n    await hot2.unlockWithPassphrase('passphrase-B');\n    await expect(hot2.decryptPayload(envelope)).rejects.toThrow();\n  });\n});\n\ndescribe('HistoryOfThought – appendEvent', () => {\n  it('soft-drops events when vault is locked', async () => {\n    const hot = new HistoryOfThought(); // not unlocked\n    await expect(hot.appendEvent('focus_session_start', {}, 'u1', 's1')).resolves.toBeUndefined();\n  });\n\n  it('rejects invalid event_type', async () => {\n    const hot = new HistoryOfThought();\n    await hot.unlockWithPassphrase('test-passphrase-ok');\n    await expect(hot.appendEvent('NOT_A_REAL_TYPE', {}, 'u1', 's1')).rejects.toThrow();\n  });\n\n  it('stores and retrieves an event', async () => {\n    const hot = new HistoryOfThought();\n    await hot.unlockWithPassphrase('test-passphrase-ok');\n    await hot.appendEvent('focus_session_start', { taskId: 't1' }, 'user1', 'stream1');\n    const events = await hot.listEvents('user1');\n    expect(events.length).toBe(1);\n  });\n});\n\ndescribe('HistoryOfThought – generateAuthenticityReport', () => {\n  it('throws when vault is locked', async () => {\n    const hot = new HistoryOfThought();\n    await expect(hot.generateAuthenticityReport('u1')).rejects.toThrow();\n  });\n\n  it('returns empty report when no events exist', async () => {\n    const hot = new HistoryOfThought();\n    await hot.unlockWithPassphrase('test-passphrase-ok');\n    const report = await hot.generateAuthenticityReport('no-such-user');\n    expect(report.totalEvents).toBe(0);\n  });\n});"
      },
