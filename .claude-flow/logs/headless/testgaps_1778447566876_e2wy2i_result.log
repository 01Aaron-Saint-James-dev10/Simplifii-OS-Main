        "content": "\n**Untested:** all 26 patterns, dash sanitisation, clause splitting, `dropEmpty` capitalisation, `shouldLiteralise()`.\n\n```js\n// src/core/__tests__/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../LiteralMode';\n\ndescribe('literalise – vague advisory → imperative', () => {\n  test('\"consider revising\" → \"change\"', () =>\n    expect(literalise('You should consider revising this section.')).toContain('change'));\n\n  test('\"it is recommended that\" → \"do this:\"', () =>\n    expect(literalise('It is recommended that you cite sources.')).toContain('do this:'));\n\n  test('\"going forward\" is deleted', () =>\n    expect(literalise('Going forward, focus on structure.')).not.toContain('Going forward'));\n\n  test('\"in order to\" → \"to\"', () =>\n    expect(literalise('Rewrite in order to improve clarity.')).toContain(' to improve'));\n\n  test('\"please ensure that\" → \"make sure\"', () =>\n    expect(literalise('Please ensure that all claims are cited.')).toContain('make sure'));\n\n  test('\"it may be helpful to\" → \"try to\"', () =>\n    expect(literalise('It may be helpful to outline first.')).toContain('try to'));\n});\n\ndescribe('literalise – academic verbs → plain verbs', () => {\n  test('\"synthesise\" → \"combine ideas from\"', () =>\n    expect(literalise('You need to synthesise the literature.')).toContain('combine ideas from'));\n\n  test('\"synthesize\" (US spelling) also converts', () =>\n    expect(literalise('Synthesize the arguments.')).toContain('combine ideas from'));\n\n  test('\"demonstrates\" → \"shows\"', () =>\n    expect(literalise('This demonstrates critical thinking.')).toContain('shows'));\n\n  test('\"articulate\" → \"say\"', () =>\n    expect(literalise('You must articulate your position.')).toContain('say'));\n\n  test('\"engage with\" → \"read\"', () =>\n    expect(literalise('You are expected to engage with the readings.')).toContain('read'));\n\n  test('\"furthermore\" → \"also\"', () =>\n    expect(literalise('Furthermore, the evidence shows...')).toContain('also'));\n\n  test('\"notwithstanding\" → \"even so\"', () =>\n    expect(literalise('Notwithstanding the findings, proceed.')).toContain('even so'));\n\n  test('\"consequently\" → \"so\"', () =>\n    expect(literalise('Consequently, revise the draft.')).toContain('so'));\n});\n\ndescribe('literalise – passive → active', () => {\n  test('\"should be revised\" → \"rewrite this\"', () =>\n    expect(literalise('This paragraph should be revised.')).toContain('rewrite this'));\n\n  test('\"must be demonstrated\" → \"show this\"', () =>\n    expect(literalise('Competency must be demonstrated.')).toContain('show this'));\n\n  test('\"is to be considered\" → \"think about\"', () =>\n    expect(literalise('This is to be considered carefully.')).toContain('think about'));\n\n  test('\"are required to\" → \"must\"', () =>\n    expect(literalise('Students are required to submit.')).toContain('must'));\n});\n\ndescribe('literalise – dash sanitisation', () => {\n  test('em-dash (\\\\u2014) is replaced with comma', () =>\n    expect(literalise('Revise this\\u2014rewrite that')).toContain(','));\n\n  test('en-dash (\\\\u2013) is replaced with comma', () =>\n    expect(literalise('Section 1\\u20132 needs work')).toContain(','));\n});\n\ndescribe('literalise – clause splitting (splitClauses: true default)', () => {\n  test('semicolons split into sentences', () => {\n    const result = literalise('Write the intro; revise the conclusion.');\n    expect(result).toContain('. ');\n  });\n\n  test('\", and \" splits into sentences', () => {\n    const result = literalise('Read the text, and summarise it.');\n    expect(result).toContain('. ');\n  });\n\n  test('splitClauses: false preserves semicolons', () => {\n    const result = literalise('Write the intro; keep going.', { splitClauses: false });\n    expect(result).toContain(';');\n  });\n});\n\ndescribe('literalise – edge cases', () => {\n  test('empty string returns empty string', () =>\n    expect(literalise('')).toBe(''));\n\n  test('non-string returns value unchanged', () => {\n    expect(literalise(null)).toBe(null);\n    expect(literalise(42)).toBe(42);\n    expect(literalise(undefined)).toBe(undefined);\n  });\n\n  test('dropEmpty: true collapses double spaces', () => {\n    const result = literalise('Going forward, write clearly.');\n    expect(result).not.toMatch(/\\s{2,}/);\n  });\n\n  test('sentence-initial lowercase is capitalised after deletion', () => {\n    const result = literalise('Going forward, revise the draft.');\n    expect(result[0]).toMatch(/[A-Z]/);\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('userPreference true overrides stream default', () =>\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true));\n\n  test('userPreference false overrides stream default', () =>\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false));\n\n  test('null userPreference falls back to stream profile', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n\n  test('undefined userPreference falls back to stream profile', () =>\n    expect(shouldLiteralise({ literalModeDefault: true }, undefined)).toBe(true));\n\n  test('absent stream profile returns false', () =>\n    expect(shouldLiteralise(null, null)).toBe(false));\n});\n```\n\n---\n\n",
