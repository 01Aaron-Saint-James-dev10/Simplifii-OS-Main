        "code": "module.exports = {\n  testEnvironment: 'jsdom',\n  setupFilesAfterFramework: ['@testing-library/jest-dom'],\n  moduleNameMapper: {\n    '\\\\.(json)$': '<rootDir>/src/__mocks__/fileMock.js'\n  }\n};"
