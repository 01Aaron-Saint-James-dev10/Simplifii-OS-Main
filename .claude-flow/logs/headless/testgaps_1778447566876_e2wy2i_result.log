        "language": "js",
        "code": "// src/core/__tests__/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, applyTheme, __internals } from '../SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test.each([\n    ['primary',    'primary'],\n    ['secondary',  'secondary'],\n    ['highschool', 'secondary'],  // alias\n    ['tafe',       'tafe'],\n    ['homeschool', 'homeschool'],\n    ['university', 'tertiary'],\n    ['undergrad',  'tertiary'],\n    ['honours',    'tertiary'],\n    ['mres',       'tertiary'],\n    ['phd',        'tertiary'],\n  ])('maps level \"%s\" → stream \"%s\"', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('unknown level falls back to tertiary', () => {\n    expect(streamFromLevel('mystery')).toBe('tertiary');\n  });\n\n  test('null / undefined / empty string fall back to tertiary', () => {\n    expect(streamFromLevel(null)).toBe('tertiary');\n    expect(streamFromLevel(undefined)).toBe('tertiary');\n    expect(streamFromLevel('')).toBe('tertiary');\n  });\n\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('PRIMARY')).toBe('primary');\n    expect(streamFromLevel('Highschool')).toBe('secondary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('accepts all five known streams', () => {\n    ['primary','secondary','tertiary','tafe','homeschool'].forEach(id =>\n      expect(isValidStream(id)).toBe(true)\n    );\n  });\n\n  test('rejects unknown ids', () => {\n    expect(isValidStream('unknown')).toBe(false);\n    expect(isValidStream('')).toBe(false);\n    expect(isValidStream(null)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('returns correct streamId when explicit valid streamId provided', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.streamId).toBe('primary');\n  });\n\n  test('falls back to level when no streamId', () => {\n    const result = hydrate({ profile: { level: 'tafe' } });\n    expect(result.streamId).toBe('tafe');\n  });\n\n  test('defaults to tertiary when both absent', () => {\n    const result = hydrate({});\n    expect(result.streamId).toBe('tertiary');\n  });\n\n  test('invalid streamId falls back to level-based resolution', () => {\n    const result = hydrate({ streamId: 'bogus', profile: { level: 'primary' } });\n    expect(result.streamId).toBe('primary');\n  });\n\n  test('returns profile, vocab, theme, capabilities on result', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(result).toHaveProperty('profile');\n    expect(result).toHaveProperty('vocab');\n    expect(result).toHaveProperty('theme');\n    expect(result).toHaveProperty('capabilities');\n  });\n\n  test('getVocab returns stream vocab key or tertiary fallback', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.getVocab('essay')).toBe('string');\n  });\n\n  test('canAccess returns false for unknown module', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.canAccess('__nonexistent__')).toBe(false);\n  });\n\n  test('getDefaultLanding returns a string', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.getDefaultLanding()).toBe('string');\n  });\n});\n\ndescribe('applyTheme', () => {\n  test('writes CSS custom properties to document root', () => {\n    const stream = { theme: { '--bg': '#000', '--fg': '#fff' } };\n    applyTheme(stream);\n    expect(document.documentElement.style.getPropertyValue('--bg')).toBe('#000');\n    expect(document.documentElement.style.getPropertyValue('--fg')).toBe('#fff');\n  });\n\n  test('ignores non-CSS-variable keys', () => {\n    const stream = { theme: { 'background': 'red', '--valid': 'blue' } };\n    applyTheme(stream);\n    expect(document.documentElement.style.getPropertyValue('--valid')).toBe('blue');\n    // 'background' key without '--' prefix should not be set\n    expect(document.documentElement.style.getPropertyValue('background')).not.toBe('red');\n  });\n\n  test('no-ops when stream or theme is absent', () => {\n    expect(() => applyTheme(null)).not.toThrow();\n    expect(() => applyTheme({})).not.toThrow();\n  });\n});"
      },
      {
        "language": "js",
        "code": "// src/core/__tests__/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../LiteralMode';\n\ndescribe('literalise – vague advisory → imperative', () => {\n  test('\"consider revising\" → \"change\"', () =>\n    expect(literalise('You should consider revising this section.')).toContain('change'));\n\n  test('\"it is recommended that\" → \"do this:\"', () =>\n    expect(literalise('It is recommended that you cite sources.')).toContain('do this:'));\n\n  test('\"going forward\" is deleted', () =>\n    expect(literalise('Going forward, focus on structure.')).not.toContain('Going forward'));\n\n  test('\"in order to\" → \"to\"', () =>\n    expect(literalise('Rewrite in order to improve clarity.')).toContain(' to improve'));\n\n  test('\"please ensure that\" → \"make sure\"', () =>\n    expect(literalise('Please ensure that all claims are cited.')).toContain('make sure'));\n\n  test('\"it may be helpful to\" → \"try to\"', () =>\n    expect(literalise('It may be helpful to outline first.')).toContain('try to'));\n});\n\ndescribe('literalise – academic verbs → plain verbs', () => {\n  test('\"synthesise\" → \"combine ideas from\"', () =>\n    expect(literalise('You need to synthesise the literature.')).toContain('combine ideas from'));\n\n  test('\"synthesize\" (US spelling) also converts', () =>\n    expect(literalise('Synthesize the arguments.')).toContain('combine ideas from'));\n\n  test('\"demonstrates\" → \"shows\"', () =>\n    expect(literalise('This demonstrates critical thinking.')).toContain('shows'));\n\n  test('\"articulate\" → \"say\"', () =>\n    expect(literalise('You must articulate your position.')).toContain('say'));\n\n  test('\"engage with\" → \"read\"', () =>\n    expect(literalise('You are expected to engage with the readings.')).toContain('read'));\n\n  test('\"furthermore\" → \"also\"', () =>\n    expect(literalise('Furthermore, the evidence shows...')).toContain('also'));\n\n  test('\"notwithstanding\" → \"even so\"', () =>\n    expect(literalise('Notwithstanding the findings, proceed.')).toContain('even so'));\n\n  test('\"consequently\" → \"so\"', () =>\n    expect(literalise('Consequently, revise the draft.')).toContain('so'));\n});\n\ndescribe('literalise – passive → active', () => {\n  test('\"should be revised\" → \"rewrite this\"', () =>\n    expect(literalise('This paragraph should be revised.')).toContain('rewrite this'));\n\n  test('\"must be demonstrated\" → \"show this\"', () =>\n    expect(literalise('Competency must be demonstrated.')).toContain('show this'));\n\n  test('\"is to be considered\" → \"think about\"', () =>\n    expect(literalise('This is to be considered carefully.')).toContain('think about'));\n\n  test('\"are required to\" → \"must\"', () =>\n    expect(literalise('Students are required to submit.')).toContain('must'));\n});\n\ndescribe('literalise – dash sanitisation', () => {\n  test('em-dash (\\\\u2014) is replaced with comma', () =>\n    expect(literalise('Revise this\\u2014rewrite that')).toContain(','));\n\n  test('en-dash (\\\\u2013) is replaced with comma', () =>\n    expect(literalise('Section 1\\u20132 needs work')).toContain(','));\n});\n\ndescribe('literalise – clause splitting (splitClauses: true default)', () => {\n  test('semicolons split into sentences', () => {\n    const result = literalise('Write the intro; revise the conclusion.');\n    expect(result).toContain('. ');\n  });\n\n  test('\", and \" splits into sentences', () => {\n    const result = literalise('Read the text, and summarise it.');\n    expect(result).toContain('. ');\n  });\n\n  test('splitClauses: false preserves semicolons', () => {\n    const result = literalise('Write the intro; keep going.', { splitClauses: false });\n    expect(result).toContain(';');\n  });\n});\n\ndescribe('literalise – edge cases', () => {\n  test('empty string returns empty string', () =>\n    expect(literalise('')).toBe(''));\n\n  test('non-string returns value unchanged', () => {\n    expect(literalise(null)).toBe(null);\n    expect(literalise(42)).toBe(42);\n    expect(literalise(undefined)).toBe(undefined);\n  });\n\n  test('dropEmpty: true collapses double spaces', () => {\n    const result = literalise('Going forward, write clearly.');\n    expect(result).not.toMatch(/\\s{2,}/);\n  });\n\n  test('sentence-initial lowercase is capitalised after deletion', () => {\n    const result = literalise('Going forward, revise the draft.');\n    expect(result[0]).toMatch(/[A-Z]/);\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('userPreference true overrides stream default', () =>\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true));\n\n  test('userPreference false overrides stream default', () =>\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false));\n\n  test('null userPreference falls back to stream profile', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n\n  test('undefined userPreference falls back to stream profile', () =>\n    expect(shouldLiteralise({ literalModeDefault: true }, undefined)).toBe(true));\n\n  test('absent stream profile returns false', () =>\n    expect(shouldLiteralise(null, null)).toBe(false));\n});"
      },
      {
        "language": "js",
        "code": "// src/core/__tests__/ExecutiveSpine.test.js\nimport {\n  configureSpine, startFocusSession, endFocusSession,\n  getFocusSession, isFocusActive,\n  getSectionHealth, setSectionHealth,\n  grantPlayTime, isPlayTimeActive,\n  getCredits, earnCredits, spendCredits,\n  __nativeBlockingDoesNotExist, __internals\n} from '../ExecutiveSpine';\n\nbeforeEach(() => {\n  localStorage.clear();\n  // Reset spine to Blueprint defaults\n  configureSpine({ sectionHealthUnlockThreshold: 4, defaultPlaytimeMinutes: 7 });\n  jest.useFakeTimers();\n});\n\nafterEach(() => {\n  jest.useRealTimers();\n  localStorage.clear();\n});\n\n// ---- configureSpine ----\ndescribe('configureSpine', () => {\n  test('clamps unlockThreshold to 1–5', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 0 });\n    // Verify by triggering at threshold 1\n    setSectionHealth('s1', 1);\n    // No error; indirect check via setSectionHealth is sufficient here\n  });\n\n  test('ignores non-finite values', () => {\n    expect(() => configureSpine({ sectionHealthUnlockThreshold: NaN })).not.toThrow();\n    expect(() => configureSpine({ defaultPlaytimeMinutes: Infinity })).not.toThrow();\n  });\n});\n\n// ---- FocusSession ----\ndescribe('startFocusSession / endFocusSession', () => {\n  test('startFocusSession returns session with correct shape', () => {\n    const s = startFocusSession({ taskId: 'task-1', durationMinutes: 25 });\n    expect(s.taskId).toBe('task-1');\n    expect(s.plannedDurationMs).toBe(25 * 60 * 1000);\n    expect(typeof s.startedAt).toBe('number');\n    expect(typeof s.endsAt).toBe('number');\n  });\n\n  test('enforces minimum 60s duration', () => {\n    const s = startFocusSession({ durationMinutes: 0 });\n    expect(s.plannedDurationMs).toBe(60_000);\n  });\n\n  test('sets data-focus-active attribute on documentElement', () => {\n    startFocusSession({ taskId: 't' });\n    expect(document.documentElement.getAttribute('data-focus-active')).toBe('true');\n  });\n\n  test('dispatches simplifii:focus-start event', () => {\n    const handler = jest.fn();\n    window.addEventListener('simplifii:focus-start', handler);\n    startFocusSession({ taskId: 't' });\n    expect(handler).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:focus-start', handler);\n  });\n\n  test('isFocusActive returns true after start', () => {\n    startFocusSession({ taskId: 't', durationMinutes: 25 });\n    expect(isFocusActive()).toBe(true);\n  });\n\n  test('endFocusSession removes attribute and returns result', () => {\n    startFocusSession({ taskId: 't' });\n    const result = endFocusSession({ reason: 'manual' });\n    expect(result.reason).toBe('manual');\n    expect(document.documentElement.hasAttribute('data-focus-active')).toBe(false);\n  });\n\n  test('endFocusSession returns null when no active session', () => {\n    expect(endFocusSession()).toBeNull();\n  });\n\n  test('getFocusSession returns null for expired session', () => {\n    startFocusSession({ taskId: 't', durationMinutes: 1 });\n    // Manually corrupt stored session to simulate past endsAt\n    const key = __internals.FOCUS_KEY;\n    const s = JSON.parse(localStorage.getItem(key));\n    s.endsAt = Date.now() - 1000;\n    localStorage.setItem(key, JSON.stringify(s));\n    expect(getFocusSession()).toBeNull();\n  });\n\n  test('auto-ends after planned duration via timer', () => {\n    const handler = jest.fn();\n    window.addEventListener('simplifii:focus-end', handler);\n    startFocusSession({ taskId: 't', durationMinutes: 25 });\n    jest.runAllTimers();\n    expect(handler).toHaveBeenCalledTimes(1);\n    expect(handler.mock.calls[0][0].detail.reason).toBe('completed');\n    window.removeEventListener('simplifii:focus-end', handler);\n  });\n});\n\n// ---- SectionHealth ----\ndescribe('setSectionHealth / getSectionHealth', () => {\n  test('clamps dots to 0–5', () => {\n    setSectionHealth('s', 10);\n    expect(getSectionHealth('s')).toBe(5);\n    setSectionHealth('s', -3);\n    expect(getSectionHealth('s')).toBe(0);\n  });\n\n  test('rounds non-integer dots', () => {\n    setSectionHealth('s', 2.7);\n    expect(getSectionHealth('s')).toBe(3);\n  });\n\n  test('dispatches section-health event on change', () => {\n    const handler = jest.fn();\n    window.addEventListener('simplifii:section-health', handler);\n    setSectionHealth('s', 3);\n    expect(handler).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:section-health', handler);\n  });\n\n  test('no event dispatched when value unchanged', () => {\n    setSectionHealth('s', 3);\n    const handler = jest.fn();\n    window.addEventListener('simplifii:section-health', handler);\n    setSectionHealth('s', 3); // same value\n    expect(handler).not.toHaveBeenCalled();\n    window.removeEventListener('simplifii:section-health', handler);\n  });\n\n  test('returns 0 for unknown sectionId', () =>\n    expect(getSectionHealth('no-such-section')).toBe(0));\n\n  test('no-ops when sectionId is falsy', () =>\n    expect(setSectionHealth('', 3)).toBe(0));\n\n  test('auto-grants playtime when crossing unlockThreshold (4 → 4)', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 4, defaultPlaytimeMinutes: 7 });\n    const handler = jest.fn();\n    window.addEventListener('simplifii:playtime-granted', handler);\n    setSectionHealth('s', 3);\n    setSectionHealth('s', 4); // crossing upward\n    expect(handler).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:playtime-granted', handler);\n  });\n\n  test('does not re-grant playtime when already above threshold', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 4 });\n    const handler = jest.fn();\n    setSectionHealth('s', 4);\n    window.addEventListener('simplifii:playtime-granted', handler);\n    setSectionHealth('s', 5); // still above, no crossing\n    expect(handler).not.toHaveBeenCalled();\n    window.removeEventListener('simplifii:playtime-granted', handler);\n  });\n});\n\n// ---- PlayTime ----\ndescribe('grantPlayTime / isPlayTimeActive', () => {\n  test('isPlayTimeActive returns true immediately after grant', () => {\n    grantPlayTime({ minutes: 7 });\n    expect(isPlayTimeActive()).toBe(true);\n  });\n\n  test('isPlayTimeActive returns false when not granted', () =>\n    expect(isPlayTimeActive()).toBe(false));\n\n  test('enforces minimum 60s', () => {\n    const until = grantPlayTime({ minutes: 0 });\n    expect(until - Date.now()).toBeGreaterThanOrEqual(59_900);\n  });\n});\n\n// ---- SovereignCredits ----\ndescribe('earnCredits / spendCredits / getCredits', () => {\n  test('earnCredits accumulates', () => {\n    earnCredits(5);\n    earnCredits(3);\n    expect(getCredits()).toBe(8);\n  });\n\n  test('earnCredits ignores zero or negative', () => {\n    earnCredits(0);\n    earnCredits(-10);\n    expect(getCredits()).toBe(0);\n  });\n\n  test('spendCredits deducts correct amount', () => {\n    earnCredits(10);\n    spendCredits(4);\n    expect(getCredits()).toBe(6);\n  });\n\n  test('spendCredits does nothing when insufficient balance', () => {\n    earnCredits(3);\n    const balance = spendCredits(10);\n    expect(balance).toBe(3); // unchanged\n    expect(getCredits()).toBe(3);\n  });\n\n  test('spendCredits ignores zero amount', () => {\n    earnCredits(5);\n    spendCredits(0);\n    expect(getCredits()).toBe(5);\n  });\n\n  test('earnCredits dispatches credits-earned event', () => {\n    const handler = jest.fn();\n    window.addEventListener('simplifii:credits-earned', handler);\n    earnCredits(5, 'micro-step');\n    expect(handler.mock.calls[0][0].detail).toMatchObject({ amount: 5, reason: 'micro-step' });\n    window.removeEventListener('simplifii:credits-earned', handler);\n  });\n});\n\n// ---- Blueprint guard ----\ndescribe('__nativeBlockingDoesNotExist', () => {\n  test('returns true (no external app blocking API present)', () =>\n    expect(__nativeBlockingDoesNotExist()).toBe(true));\n});"
      },
