andler);\n  });\n\n  test('returns 0 for unknown sectionId', () =>\n    expect(getSectionHealth('no-such-section')).toBe(0));\n\n  test('no-ops when sectionId is falsy', () =>\n    expect(setSectionHealth('', 3)).toBe(0));\n\n  test('auto-grants playtime when crossing unlockThreshold (4 → 4)', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 4, defaultPlaytimeMinutes: 7 });\n    const handler = jest.fn();\n    window.addEventListener('simplifii:playtime-granted', handler);\n    setSectionHealth('s', 3);\n    setSectionHealth('s', 4); // crossing upward\n    expect(handler).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:playtime-granted', handler);\n  });\n\n  test('does not re-grant playtime when already above threshold', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 4 });\n    const handler = jest.fn();\n    setSectionHealth('s', 4);\n    window.addEventListener('simplifii:playtime-granted', handler);\n    setSectionHealth('s', 5); // still above, no crossing\n    expect(handler).not.toHaveBeenCalled();\n    window.removeEventListener('simplifii:playtime-granted', handler);\n  });\n});\n\n// ---- PlayTime ----\ndescribe('grantPlayTime / isPlayTimeActive', () => {\n  test('isPlayTimeActive returns true immediately after grant', () => {\n    grantPlayTime({ minutes: 7 });\n    expect(isPlayTimeActive()).toBe(true);\n  });\n\n  test('isPlayTimeActive returns false when not granted', () =>\n    expect(isPlayTimeActive()).toBe(false));\n\n  test('enforces minimum 60s', () => {\n    const until = grantPlayTime({ minutes: 0 });\n    expect(until - Date.now()).toBeGreaterThanOrEqual(59_900);\n  });\n});\n\n// ---- SovereignCredits ----\ndescribe('earnCredits / spendCredits / getCredits', () => {\n  test('earnCredits accumulates', () => {\n    earnCredits(5);\n    earnCredits(3);\n    expect(getCredits()).toBe(8);\n  });\n\n  test('earnCredits ignores zero or negative', () => {\n    earnCredits(0);\n    earnCredits(-10);\n    expect(getCredits()).toBe(0);\n  });\n\n  test('spendCredits deducts correct amount', () => {\n    earnCredits(10);\n    spendCredits(4);\n    expect(getCredits()).toBe(6);\n  });\n\n  test('spendCredits does nothing when insufficient balance', () => {\n    earnCredits(3);\n    const balance = spendCredits(10);\n    expect(balance).toBe(3); // unchanged\n    expect(getCredits()).toBe(3);\n  });\n\n  test('spendCredits ignores zero amount', () => {\n    earnCredits(5);\n    spendCredits(0);\n    expect(getCredits()).toBe(5);\n  });\n\n  test('earnCredits dispatches credits-earned event', () => {\n    const handler = jest.fn();\n    window.addEventListener('simplifii:credits-earned', handler);\n    earnCredits(5, 'micro-step');\n    expect(handler.mock.calls[0][0].detail).toMatchObject({ amount: 5, reason: 'micro-step' });\n    window.removeEventListener('simplifii:credits-earned', handler);\n  });\n});\n\n// ---- Blueprint guard ----\ndescribe('__nativeBlockingDoesNotExist', () => {\n  test('returns true (no external app blocking API present)', () =>\n    expect(__nativeBlockingDoesNotExist()).toBe(true));\n});\n```\n\n---\n\n### 4. `HistoryOfThought` — `src/core/HistoryOfThought.js`\n\n**Untested:** passphrase validation, unlock/lock lifecycle, encryption round-trip, event drop when locked, unknown event_type rejection, `generateAuthenticityReport()` shape, `enableCloudSync()` throws.\n\n```js\n// src/core/__tests__/HistoryOfThought.test.js\nimport 'fake-indexeddb/auto';\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport,\n  enableCloudSync, EVENT_TYPES\n} from '../HistoryOfThought';\n\nbeforeEach(async () => {\n  lockSession();\n  localStorage.clear();\n});\n\ndescribe('unlock / lock', () => {\n  test('isUnlocked is false initially', () =>\n    expect(isUnlocked()).toBe(false));\n\n  test('unlockWithPassphrase resolves to true for valid passphrase', async () => {\n    await expect(unlockWithPassphrase('test-pass')).resolves.toBe(true);\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('lockSession sets isUnlocked to false', async () => {\n    await unlockWithPassphrase('test-pass');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('rejects passphrase shorter than 4 chars', async () => {\n    await expect(unlockWithPassphrase('ab')).rejects.toThrow('at least 4 characters');\n  });\n\n  test('rejects non-string passphrase', async () => {\n    await expect(unlockWithPassphrase(12345)).rejects.toThrow();\n    await expect(unlockWithPassphrase(null)).rejects.toThrow();\n  });\n});\n\ndescribe('appendEvent', () => {\n  test('returns null (soft-fail) when vault is locked', async () => {\n    const result = await appendEvent({ event_type: 'text_edit', payload: {} });\n    expect(result).toBeNull();\n  });\n\n  test('throws for unknown event_type', async () => {\n    await unlockWithPassphrase('pass1234');\n    await expect(appendEvent({ event_type: 'invalid_event' })).rejects.toThrow('Unknown event_type');\n  });\n\n  test('persists event and returns event object when unlocked', async () => {\n    await unlockWithPassphrase('pass1234');\n    const event = await appendEvent({\n      user_id: 'user1', stream_id: 'tertiary',\n      event_type: 'text_edit', payload: { wordsAfter: 100 }\n    });\n    expect(event).toHaveProperty('event_id');\n    expect(event.event_type).toBe('text_edit');\n    expect(event.user_id).toBe('user1');\n  });\n\n  test.each(EVENT_TYPES)('accepts event_type \"%s\"', async (type) => {\n    await unlockWithPassphrase('pass1234');\n    await expect(appendEvent({ event_type: type, payload: {} })).resolves.toBeDefined();\n  });\n});\n\ndescribe('listEvents', () => {\n  test('returns empty array when no events stored', async () => {\n    const events = await listEvents({ user_id: 'nobody' });\n    expect(events).toEqual([]);\n  });\n\n  test('retrieves events for correct user only', async () => {\n    await unlockWithPassphrase('pass1234');\n    await appendEvent({ user_id: 'alice', event_type: 'text_edit', payload: {} });\n    await appendEvent({ user_id: 'bob', event_type: 'text_edit', payload: {} });\n    const aliceEvents = await listEvents({ user_id: 'alice' });\n    expect(aliceEvents).toHaveLength(1);\n    expect(aliceEvents[0].user_id).toBe('alice');\n  });\n\n  test('respects limit parameter', async () => {\n    await unlockWithPassphrase('pass1234');\n    for (let i = 0; i < 5; i++) {\n      await appendEvent({ user_id: 'user1', event_type: 'text_edit', payload: {} });\n    }\n    const events = await listEvents({ user_id: 'user1', limit: 3 });\n    expect(events).toHaveLength(3);\n  });\n});\n\ndescribe('generateAuthenticityReport', () => {\n  test('throws when vault is locked', async () => {\n    await expect(generateAuthenticityReport()).rejects.toThrow('Vault locked');\n  });\n\n  test('returns report with expected shape when unlocked', async () => {\n    await unlockWithPassphrase('pass1234');\n    await appendEvent({ user_id: 'user1', event_type: 'focus_session_start', payload: { taskId: 't1' } });\n    const report = await generateAuthenticityReport({ user_id: 'user1' });\n    expect(report).toHaveProperty('schema_version');\n    expect(report).toHaveProperty('totalEvents');\n    expect(report).toHaveProperty('countsByType');\n    expect(report).toHaveProperty('events');\n    expect(report.totalEvents).toBeGreaterThanOrEqual(1);\n  });\n\n  test('decrypts payloads in report events', async () => {\n    await unlockWithPassphrase('pass1234');\n    await appendEvent({ user_id: 'user1', event_type: 'text_edit', payload: { wordsAfter: 42 } });\n    const report = await generateAuthenticityReport({ user_id: 'user1' });\n    const editEvent = report.events.find(e => e.type === 'text_edit');\n    expect(editEvent.payload).toMatchObject({ wordsAfter: 42 });\n  });\n\n  test('spanDays is 0 when only one event', async () => {\n    await unlockWithPassphrase('pass1234');\n    await appendEvent({ user_id: 'user1', event_type: 'text_edit', payload: {} });\n    const report = await generateAuthenticityReport({ user_id: 'user1' });\n    expect(report.spanDays).toBe(0);\n  });\n});\n\ndescribe('enableCloudSync', () => {\n  test('throws — transport not wired', () =>\n    expect(() => enableCloudSync()).toThrow());\n});\n\ndescribe('encryption round-trip', () => {\n  test('same passphrase can decrypt previously stored event', async () => {\n    await unlockWithPassphrase('my-passphrase');\n    await appendEvent({ user_id: 'user1', event_type: 'citation_added', payload: { source: 'Smith 2020' } });\n    lockSession();\n    await unlockWithPassphrase('my-passphrase');\n    const report = await generateAuthenticityReport({ user_id: 'user1' });\n    expect(report.events[0].payload).toMatchObject({ source: 'Smith 2020' });\n  });\n});\n```\n\n---\n\n### 5. `EventBus` — `src/core/EventBus.js`\n\n**Untested:** `startEventBus` attaches 8 listeners, re-entrant start clears prior listeners, silent drop when vault locked, `stopEventBus` cleans up, `recordTextEdit` / `recordCitation` helpers.\n\n```js\n// src/core/__tests__/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation, __internals } from '../EventBus';\nimport * as HOT from '../HistoryOfThought';\n\njest.mock('../HistoryOfThought', () => ({\n  isUnlocked: jest.fn(() => false),\n  appendEvent: jest.fn(() => Promise.resolve(null)),\n  EVENT_TYPES: [\n    'text_edit','citation_added','citation_removed','ai_assist_invoked',\n    'focus_session_start','focus_session_end','nudge_triggered',\n    'section_health_change','playtime_granted','playtime_expired'\n  ]\n}));\n\nbeforeEach(() => {\n  jest.clearAllMocks();\n  stopEventBus();\n});\n\nafterEach(() => stopEventBus());\n\ndescribe('startEventBus', () => {\n  test('attaches listeners for all 8 spine events', () => {\n    const addSpy = jest.spyOn(window, 'addEventListener');\n    startEventBus();\n    const spineEvents = Object.keys(__internals.SPINE_TO_HOT);\n    spineEvents.forEach(name =>\n      expect(addSpy).toHaveBeenCalledWith(name, expect.any(Function))\n    );\n    addSpy.mockRestore();\n  });\n\n  test('re-entrant call clears prior listeners before re-attaching', () => {\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    startEventBus();\n    startEventBus(); // second call\n    expect(removeSpy).toHaveBeenCalled();\n    removeSpy.mockRestore();\n  });\n\n  test('does not throw in SSR environment (window undefined)', () => {\n    const origWindow = global.window;\n    delete global.window;\n    expect(() => startEventBus()).not.toThrow();\n    global.window = origWindow;\n  });\n});\n\ndescribe('stopEventBus', () => {\n  test('removes all attached listeners', () => {\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    startEventBus();\n    stopEventBus();\n    const spineEvents = Object.keys(__internals.SPINE_TO_HOT);\n    spineEvents.forEach(name =>\n      expect(removeSpy).toHaveBeenCalledWith(name, expect.any(Function))\n    );\n    removeSpy.mockRestore();\n  });\n});\n\ndescribe('event bridging – vault locked', () => {\n  test('silently drops events when vault is locked', async () => {\n    HOT.isUnlocked.mockReturnValue(false);\n    startEventBus();\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 't1' } }));\n    // Flush microtasks\n    await Promise.resolve();\n    expect(HOT.appendEvent).not.toHaveBeenCalled();\n  });\n});\n\ndescribe('event bridging – vault unlocked', () => {\n  test('appends focus_session_start event when vault is unlocked', async () => {\n    HOT.isUnlocked.mockReturnValue(true);\n    startEventBus(() => ({ streamId: 'tertiary', userId: 'user1' }));\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', {\n      detail: { taskId: 't1', plannedDurationMs: 25 * 60 * 1000 }\n    }));\n    await Promise.resolve();\n    expect(HOT.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ event_type: 'focus_session_start' })\n    );\n  });\n\n  test('payload is filtered to safe fields only', async () => {\n    HOT.isUnlocked.mockReturnValue(true);\n    startEventBus();\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', {\n      detail: { taskId: 't1', plannedDurationMs: 100, rawContent: 'PRIVATE' }\n    }));\n    await Promise.resolve();\n    const payload = HOT.appendEvent.mock.calls[0][0].payload;\n    expect(payload).not.toHaveProperty('rawContent');\n    expect(payload).toHaveProperty('taskId', 't1');\n  });\n});\n\ndescribe('recordTextEdit', () => {\n  test('no-ops when vault is locked', async () => {\n    HOT.isUnlocked.mockReturnValue(false);\n    await recordTextEdit({ sectionId: 's1', wordsAfter: 100 });\n    expect(HOT.appendEvent).not.toHaveBeenCalled();\n  });\n\n  test('appends text_edit event when unlocked', async () => {\n    HOT.isUnlocked.mockReturnValue(true);\n    await recordTextEdit({ sectionId: 's1', wordsAfter: 200, streamId: 'tertiary', userId: 'u1' });\n    expect(HOT.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ event_type: 'text_edit' })\n    );\n  });\n});\n\ndescribe('recordCitation', () => {\n  test('uses citation_added when added: true', async () => {\n    HOT.isUnlocked.mockReturnValue(true);\n    await recordCitation({ added: true, source: 'Smith 2020', sourceId: 'doi:1' });\n    expect(HOT.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ event_type: 'citation_added' })\n    );\n  });\n\n  test('uses citation_removed when added: false', async () => {\n    HOT.isUnlocked.mockReturnValue(true);\n    await recordCitation({ added: false, source: 'Smith 2020', sourceId: 'doi:1' });\n    expect(HOT.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ event_type: 'citation_removed' })\n    );\n  });\n\n  test('truncates source to 120 chars', async () => {\n    HOT.isUnlocked.mockReturnValue(true);\n    const longSource = 'x'.repeat(200);\n    await recordCitation({ added: true, source: longSource });\n    const payload = HOT.appendEvent.mock.calls[0][0].payload;\n    expect(payload.source).toHaveLength(120);\n  });\n});\n```\n\n---\n\n## Tier 2 — High-Risk Service Gaps\n\n### 6. `BriefService` — `src/services/BriefService.js` (656 lines)\n\n**Untested:** `extractBriefsFromText()` regex extraction, JSON parsing fallback when Ollama returns malformed JSON, empty/null input handling.\n\n```js\n// src/services/__tests__/BriefService.test.js\nimport { extractBriefsFromText, parseRubricCriteria } from '../BriefService';\n\nglobal.fetch = jest.fn();\n\nbeforeEach(() => fetch.mockReset());\n\ndescribe('extractBriefsFromText', () => {\n  test('returns empty array for null/empty input', async () => {\n    await expect(extractBriefsFromText(null)).resolves.toEqual([]);\n    await expect(extractBriefsFromText('')).resolves.toEqual([]);\n  });\n\n  test('parses valid Ollama JSON response into brief array', async () => {\n    fetch.mockResolvedValueOnce({\n      ok: true,\n      json: () => Promise.resolve({\n        message: { content: JSON.stringify([{ title: 'Essay', dueDate: '2026-06-01', weight: 40 }]) }\n      })\n    });\n    const result = await extractBriefsFromText('Essay due June 1, worth 40%');\n    expect(result).toHaveLength(1);\n    expect(result[0]).toHaveProperty('title', 'Essay');\n  });\n\n  test('falls back gracefully when Ollama returns malformed JSON', async () => {\n    fetch.mockResolvedValueOnce({\n      ok: true,\n      json: () => Promise.resolve({ message: { content: 'Not JSON at all' } })\n    });\n    const result = await extractBriefsFromText('Some text');\n    expect(Array.isArray(result)).toBe(true);\n  });\n\n  test('falls back gracefully when fetch fails', async () => {\n    fetch.mockRejectedValueOnce(new Error('Network error'));\n    const result = await extractBriefsFromText('Some text');\n    expect(Array.isArray(result)).toBe(true);\n  });\n});\n\ndescribe('parseRubricCriteria', () => {\n  test('returns empty array for null input', () => {\n    expect(parseRubricCriteria(null)).toEqual([]);\n  });\n\n  test('extracts criteria with marks from structured text', () => {\n    const text = 'Critical Analysis (30%)\\nStructure and Argument (20%)';\n    const result = parseRubricCriteria(text);\n    expect(result.length).toBeGreaterThanOrEqual(1);\n  });\n});\n```\n\n---\n\n### 7. `SovereignReconciler` — `src/services/SovereignReconciler.js`\n\n**Untested:** fuzzy title matching, deduplication logic, conflict resolution strategy.\n\n```js\n// src/services/__tests__/SovereignReconciler.test.js\nimport { reconcile, reconcileTitles } from '../SovereignReconciler';\n\ndescribe('reconcileTitles', () => {\n  test('deduplicates identical titles', () => {\n    const titles = ['Essay 1', 'Essay 1', 'Quiz'];\n    const result = reconcileTitles(titles);\n    expect(result.filter(t => t === 'Essay 1')).toHaveLength(1);\n  });\n\n  test('clusters near-duplicate titles', () => {\n    const titles = ['Critical Essay', 'critical essay', 'Critical Essay '];\n    const result = reconcileTitles(titles);\n    expect(result).toHaveLength(1);\n  });\n\n  test('preserves distinct titles', () => {\n    const titles = ['Essay', 'Presentation', 'Lab Report'];\n    const result = reconcileTitles(titles);\n    expect(result).toHaveLength(3);\n  });\n});\n\ndescribe('reconcile', () => {\n  test('returns empty array for empty input', () => {\n    expect(reconcile([])).toEqual([]);\n  });\n\n  test('resolves conflicting weights to sum to 100%', () => {\n    const assessments = [\n      { title: 'Essay', weight: 60 },\n      { title: 'Quiz', weight: 60 }\n    ];\n    const result = reconcile(assessments);\n    const total = result.reduce((sum, a) => sum + a.weight, 0);\n    expect(total).toBeLessThanOrEqual(100);\n  });\n});\n```\n\n---\n\n## Tier 3 — Integration Test Gaps\n\n### 8. Spine → EventBus → HistoryOfThought pipeline (integration)\n\n```js\n// src/core/__tests__/SpineToBus.integration.test.js\nimport 'fake-indexeddb/auto';\nimport { startFocusSession } from '../ExecutiveSpine';\nimport { startEventBus, stopEventBus } from '../EventBus';\nimport { unlockWithPassphrase, lockSession, listEvents } from '../HistoryOfThought';\n\nbeforeEach(async () => {\n  lockSession();\n  localStorage.clear();\n  await unlockWithPassphrase('integration-pass');\n  startEventBus(() => ({ streamId: 'tertiary', userId: 'integration-user' }));\n});\n\nafterEach(() => {\n  stopEventBus();\n  lockSession();\n});\n\ntest('focus-start spine event flows through bus into encrypted log', async () => {\n  startFocusSession({ taskId: 'int-task', durationMinutes: 25 });\n  // Allow async appendEvent to settle\n  await new Promise(resolve => setTimeout(resolve, 50));\n  const events = await listEvents({ user_id: 'integration-user' });\n  expect(events.some(e => e.event_type === 'focus_session_start')).toBe(true);\n});\n\ntest('events are silently dropped when vault is locked', async () => {\n  lockSession();\n  startFocusSession({ taskId: 'locked-task', durationMinutes: 25 });\n  await new Promise(resolve => setTimeout(resolve, 50));\n  const events = await listEvents({ user_id: 'integration-user' });\n  expect(events).toHaveLength(0);\n});\n```\n\n---\n\n## Summary of Gaps by Priority\n\n| Priority | Module | Gap | Skeleton Provided |\n|---|---|---|---|\n| P0 | `HistoryOfThought` | Encryption round-trip, vault lifecycle, all 10 event types | Yes |\n| P0 | `ExecutiveSpine` | Timer, idle threshold, credits, section health clamping | Yes |\n| P0 | `SovereignRouter` | Level→stream mapping, 11 variants, theme DOM writes | Yes |\n| P0 | `EventBus` | 8 listener attachments, silent vault-locked drop, payload filtering | Yes |\n| P0 | `LiteralMode` | All 26 patterns, dash sanitisation, clause splitting | Yes |\n| P1 | `BriefService` | Malformed JSON fallback, empty input, Ollama error handling | Yes |\n| P1 | `SovereignReconciler` | Fuzzy dedup, weight normalisation | Yes |\n| P2 | Spine→Bus→HoT | End-to-end integration pipeline | Yes |\n| P2 | `ChatService` | Steering dial integration, context building | Skeleton pattern same as BriefService |\n| P3 | All 40 components | Mount/unmount, props, conditional render | Use `@testing-library/react` render + screen queries |\n\nThe highest-risk gap is the `HistoryOfThought` encryption — a bug there silently loses student authenticity data with no recovery path.\n",
