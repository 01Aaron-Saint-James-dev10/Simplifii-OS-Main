        "content": "\n**Untested:** level→stream mapping, invalid stream fallback, `hydrate()` shape, `applyTheme()` DOM writes, `canAccess()`, `getVocab()`.\n\n```js\n// src/core/__tests__/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, applyTheme, __internals } from '../SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test.each([\n    ['primary',    'primary'],\n    ['secondary',  'secondary'],\n    ['highschool', 'secondary'],  // alias\n    ['tafe',       'tafe'],\n    ['homeschool', 'homeschool'],\n    ['university', 'tertiary'],\n    ['undergrad',  'tertiary'],\n    ['honours',    'tertiary'],\n    ['mres',       'tertiary'],\n    ['phd',        'tertiary'],\n  ])('maps level \"%s\" → stream \"%s\"', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('unknown level falls back to tertiary', () => {\n    expect(streamFromLevel('mystery')).toBe('tertiary');\n  });\n\n  test('null / undefined / empty string fall back to tertiary', () => {\n    expect(streamFromLevel(null)).toBe('tertiary');\n    expect(streamFromLevel(undefined)).toBe('tertiary');\n    expect(streamFromLevel('')).toBe('tertiary');\n  });\n\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('PRIMARY')).toBe('primary');\n    expect(streamFromLevel('Highschool')).toBe('secondary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('accepts all five known streams', () => {\n    ['primary','secondary','tertiary','tafe','homeschool'].forEach(id =>\n      expect(isValidStream(id)).toBe(true)\n    );\n  });\n\n  test('rejects unknown ids', () => {\n    expect(isValidStream('unknown')).toBe(false);\n    expect(isValidStream('')).toBe(false);\n    expect(isValidStream(null)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('returns correct streamId when explicit valid streamId provided', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.streamId).toBe('primary');\n  });\n\n  test('falls back to level when no streamId', () => {\n    const result = hydrate({ profile: { level: 'tafe' } });\n    expect(result.streamId).toBe('tafe');\n  });\n\n  test('defaults to tertiary when both absent', () => {\n    const result = hydrate({});\n    expect(result.streamId).toBe('tertiary');\n  });\n\n  test('invalid streamId falls back to level-based resolution', () => {\n    const result = hydrate({ streamId: 'bogus', profile: { level: 'primary' } });\n    expect(result.streamId).toBe('primary');\n  });\n\n  test('returns profile, vocab, theme, capabilities on result', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(result).toHaveProperty('profile');\n    expect(result).toHaveProperty('vocab');\n    expect(result).toHaveProperty('theme');\n    expect(result).toHaveProperty('capabilities');\n  });\n\n  test('getVocab returns stream vocab key or tertiary fallback', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.getVocab('essay')).toBe('string');\n  });\n\n  test('canAccess returns false for unknown module', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.canAccess('__nonexistent__')).toBe(false);\n  });\n\n  test('getDefaultLanding returns a string', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.getDefaultLanding()).toBe('string');\n  });\n});\n\ndescribe('applyTheme', () => {\n  test('writes CSS custom properties to document root', () => {\n    const stream = { theme: { '--bg': '#000', '--fg': '#fff' } };\n    applyTheme(stream);\n    expect(document.documentElement.style.getPropertyValue('--bg')).toBe('#000');\n    expect(document.documentElement.style.getPropertyValue('--fg')).toBe('#fff');\n  });\n\n  test('ignores non-CSS-variable keys', () => {\n    const stream = { theme: { 'background': 'red', '--valid': 'blue' } };\n    applyTheme(stream);\n    expect(document.documentElement.style.getPropertyValue('--valid')).toBe('blue');\n    // 'background' key without '--' prefix should not be set\n    expect(document.documentElement.style.getPropertyValue('background')).not.toBe('red');\n  });\n\n  test('no-ops when stream or theme is absent', () => {\n    expect(() => applyTheme(null)).not.toThrow();\n    expect(() => applyTheme({})).not.toThrow();\n  });\n});\n```\n\n---\n\n",
