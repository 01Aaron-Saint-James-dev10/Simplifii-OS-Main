        "content": "\n```js\n// tests/core/HistoryOfThought.test.js\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport,\n} from '../../src/core/HistoryOfThought';\n\n// Requires fake-indexeddb: npm install --save-dev fake-indexeddb\nimport 'fake-indexeddb/auto';\n\ndescribe('HistoryOfThought', () => {\n  beforeEach(async () => {\n    if (isUnlocked()) lockSession();\n    indexedDB.deleteDatabase('HistoryOfThought');\n  });\n\n  describe('Vault lock state', () => {\n    it('is locked before unlock', () => expect(isUnlocked()).toBe(false));\n\n    it('unlocks with correct passphrase', async () => {\n      await unlockWithPassphrase('test-pass');\n      expect(isUnlocked()).toBe(true);\n    });\n\n    it('lockSession() re-locks the vault', async () => {\n      await unlockWithPassphrase('test-pass');\n      lockSession();\n      expect(isUnlocked()).toBe(false);\n    });\n  });\n\n  describe('appendEvent()', () => {\n    it('silently fails when vault is locked', async () => {\n      await expect(appendEvent({ user_id: 'u1', event_type: 'text_edit', payload: {} }))\n        .resolves.toBeUndefined();\n    });\n\n    it('encrypts and stores event when unlocked', async () => {\n      await unlockWithPassphrase('test-pass');\n      await appendEvent({ user_id: 'u1', stream_id: 'tertiary', event_type: 'text_edit', payload: { words: 10 } });\n      const events = await listEvents({ user_id: 'u1' });\n      expect(events).toHaveLength(1);\n    });\n\n    it('rejects unknown event_type', async () => {\n      await unlockWithPassphrase('test-pass');\n      await expect(appendEvent({ user_id: 'u1', event_type: 'invalid_type', payload: {} }))\n        .rejects.toThrow();\n    });\n  });\n\n  describe('generateAuthenticityReport()', () => {\n    it('returns report with event counts after recording events', async () => {\n      await unlockWithPassphrase('pass');\n      await appendEvent({ user_id: 'u1', event_type: 'text_edit', payload: {} });\n      await appendEvent({ user_id: 'u1', event_type: 'focus_session_start', payload: {} });\n      const report = await generateAuthenticityReport({ user_id: 'u1' });\n      expect(report.totalEvents).toBe(2);\n      expect(report.eventBreakdown.text_edit).toBe(1);\n    });\n\n    it('handles corrupted encrypted payloads without throwing', async () => {\n      // Inject corrupted record directly via IndexedDB\n      // Then assert report completes with partial data\n    });\n  });\n\n  describe('enableCloudSync()', () => {\n    it('throws NotImplementedError', async () => {\n      const { enableCloudSync } = await import('../../src/core/HistoryOfThought');\n      expect(() => enableCloudSync()).toThrow();\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "4. LiteralMode.js — 16 Regex Transformations",
        "content": "\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('LiteralMode', () => {\n  describe('literalise()', () => {\n    const cases = [\n      ['utilises', 'uses'],\n      ['demonstrates', 'shows'],\n      ['it is evident that', ''],\n      ['in order to', 'to'],\n    ];\n\n    test.each(cases)('transforms \"%s\" → \"%s\"', (input, expected) => {\n      expect(literalise(input)).toContain(expected);\n    });\n\n    it('handles empty string', () => {\n      expect(literalise('')).toBe('');\n    });\n\n    it('returns non-string input unchanged', () => {\n      expect(literalise(123)).toBe(123);\n    });\n\n    it('returns null/undefined unchanged', () => {\n      expect(literalise(null)).toBeNull();\n    });\n\n    it('splits on semicolons when splitClauses=true', () => {\n      const result = literalise('First idea; second idea', { splitClauses: true });\n      expect(result).toContain('\\n');\n    });\n\n    it('does not split when splitClauses=false', () => {\n      const result = literalise('First idea; second idea', { splitClauses: false });\n      expect(result).not.toContain('\\n');\n    });\n\n    it('collapses consecutive whitespace', () => {\n      expect(literalise('word   word')).toBe('word word');\n    });\n\n    it('removes em-dashes', () => {\n      expect(literalise('left\\u2014right')).not.toContain('\\u2014');\n    });\n  });\n\n  describe('shouldLiteralise()', () => {\n    it('returns true for primary stream with no user override', () => {\n      expect(shouldLiteralise({ id: 'primary' }, undefined)).toBe(true);\n    });\n\n    it('user preference overrides stream default', () => {\n      expect(shouldLiteralise({ id: 'tertiary' }, true)).toBe(true);\n      expect(shouldLiteralise({ id: 'primary' }, false)).toBe(false);\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "5. KnowledgeGraphService.js — Regex Tokenization",
        "content": "\n```js\n// tests/services/KnowledgeGraphService.test.js\nimport { extractSemanticEntities } from '../../src/services/KnowledgeGraphService';\n\ndescribe('KnowledgeGraphService', () => {\n  it('extracts capitalised noun phrases', () => {\n    const result = extractSemanticEntities('Cell Division and Mitosis are key topics.');\n    const labels = result.map(e => e.label);\n    expect(labels).toContain('Cell Division');\n    expect(labels).toContain('Mitosis');\n  });\n\n  it('extracts acronyms', () => {\n    const result = extractSemanticEntities('The ATP cycle drives cellular respiration. ATP is crucial.');\n    const labels = result.map(e => e.label);\n    expect(labels).toContain('ATP');\n  });\n\n  it('filters STOP_PHRASES like \"The\", \"This\", \"University\"', () => {\n    const result = extractSemanticEntities('The University said This topic is important.');\n    const labels = result.map(e => e.label);\n    expect(labels).not.toContain('The');\n    expect(labels).not.toContain('University');\n  });\n\n  it('deduplicates case-insensitively', () => {\n    const result = extractSemanticEntities('Mitosis. Mitosis. mitosis.');\n    const mitosisItems = result.filter(e => e.label.toLowerCase() === 'mitosis');\n    expect(mitosisItems).toHaveLength(1);\n    expect(mitosisItems[0].confidence).toBeGreaterThan(0.6);\n  });\n\n  it('caps at 6 phrases and 4 acronyms', () => {\n    const text = 'Alpha Beta Gamma Delta Epsilon Zeta Eta. AA BB CC DD EE FF.';\n    const result = extractSemanticEntities(text);\n    const phrases = result.filter(e => e.type === 'phrase');\n    const acronyms = result.filter(e => e.type === 'acronym');\n    expect(phrases.length).toBeLessThanOrEqual(6);\n    expect(acronyms.length).toBeLessThanOrEqual(4);\n  });\n\n  it('returns fallback entity for empty/null input', () => {\n    expect(extractSemanticEntities('')).toHaveLength(1);\n    expect(extractSemanticEntities(null)).toHaveLength(1);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "6. VerificationService.js — Validation Gate",
        "content": "\n```js\n// tests/services/VerificationService.test.js\nimport { auditProjectContext } from '../../src/services/VerificationService';\n\ndescribe('VerificationService', () => {\n  jest.useFakeTimers();\n\n  const valid = {\n    theme: 'Cellular Respiration',\n    evidenceFormula: ['Point', 'Evidence', 'Explanation'],\n    formattingConfirmed: true,\n  };\n\n  it('resolves verified=true for complete valid data', async () => {\n    const p = auditProjectContext(valid);\n    jest.runAllTimers();\n    const result = await p;\n    expect(result.verified).toBe(true);\n  });\n\n  it('rejects empty theme', async () => {\n    const p = auditProjectContext({ ...valid, theme: '' });\n    jest.runAllTimers();\n    const result = await p;\n    expect(result.verified).toBe(false);\n    expect(result.errors).toContain(expect.stringMatching(/theme/i));\n  });\n\n  it('rejects empty evidenceFormula array', async () => {\n    const p = auditProjectContext({ ...valid, evidenceFormula: [] });\n    jest.runAllTimers();\n    const result = await p;\n    expect(result.verified).toBe(false);\n  });\n\n  it('rejects formattingConfirmed=false', async () => {\n    const p = auditProjectContext({ ...valid, formattingConfirmed: false });\n    jest.runAllTimers();\n    const result = await p;\n    expect(result.verified).toBe(false);\n  });\n\n  it('bypasses checks when detectedLevel is present', async () => {\n    const p = auditProjectContext({ detectedLevel: 'tertiary' });\n    jest.runAllTimers();\n    const result = await p;\n    expect(result.verified).toBe(true);\n  });\n\n  it('resolves after ~800ms delay', async () => {\n    const start = Date.now();\n    const p = auditProjectContext(valid);\n    jest.advanceTimersByTime(800);\n    await p;\n    // Delay is simulated — just verify it doesn't resolve instantly\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "7. Integration: Event Bus + History of Thought",
        "content": "\n```js\n// tests/integration/EventPipeline.test.js\nimport 'fake-indexeddb/auto';\nimport { startEventBus, stopEventBus, recordTextEdit } from '../../src/core/EventBus';\nimport { unlockWithPassphrase, lockSession, listEvents } from '../../src/core/HistoryOfThought';\n\ndescribe('Integration: EventBus → HistoryOfThought', () => {\n  afterEach(() => { stopEventBus(); lockSession(); });\n\n  it('records text_edit through the full pipeline when vault is unlocked', async () => {\n    await unlockWithPassphrase('integration-pass');\n    startEventBus(() => require('../../src/core/HistoryOfThought'));\n    recordTextEdit({ sectionId: 'intro', wordsAfter: 50, streamId: 'tertiary', userId: 'u1' });\n    await new Promise(r => setTimeout(r, 50)); // allow async propagation\n    const events = await listEvents({ user_id: 'u1' });\n    expect(events.some(e => e.event_type === 'text_edit')).toBe(true);\n  });\n\n  it('drops text_edit silently when vault is locked mid-session', async () => {\n    await unlockWithPassphrase('pass');\n    startEventBus(() => require('../../src/core/HistoryOfThought'));\n    lockSession(); // lock before event fires\n    recordTextEdit({ sectionId: 'intro', wordsAfter: 10, userId: 'u1' });\n    await new Promise(r => setTimeout(r, 50));\n    // unlock to check — should be empty\n    await unlockWithPassphrase('pass');\n    const events = await listEvents({ user_id: 'u1' });\n    expect(events).toHaveLength(0);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "8. Integration: Steering Dials Across Services",
        "content": "\n```js\n// tests/integration/SteeringDials.test.js\n// Mock Ollama responses\njest.mock('node-fetch'); // or mock fetch globally\n\ndescribe('Integration: Steering dials propagate across services', () => {\n  beforeEach(() => {\n    localStorage.clear();\n    localStorage.setItem('simplifii_literal_mode', 'true');\n    localStorage.setItem('simplifii_scaffolding', 'heavy');\n    localStorage.setItem('simplifii_grit', 'literal');\n  });\n\n  it('ChatService reads isLiteralMode=true and adjusts system prompt', async () => {\n    global.fetch = jest.fn().mockResolvedValue({\n      ok: true,\n      json: async () => ({ message: { content: 'response' } }),\n    });\n    const { askAura } = await import('../../src/services/ChatService');\n    const spy = jest.spyOn(global, 'fetch');\n    await askAura('What is mitosis?', null, []);\n    const body = JSON.parse(spy.mock.calls[0][1].body);\n    expect(body.messages[0].content).toMatch(/plain language|literal/i);\n  });\n\n  it('MicroStepService uses step count 5 for heavy scaffolding', async () => {\n    global.fetch = jest.fn().mockResolvedValue({\n      ok: true,\n      json: async () => ({ message: { content: JSON.stringify({ steps: Array(5).fill({ step: 1, title: 't', action: 'a', why: 'w' }) }) } }),\n    });\n    const { generateMicroSteps } = await import('../../src/services/MicroStepService');\n    const body = JSON.parse(global.fetch.mock.calls[0][1].body);\n    expect(body.messages[0].content).toMatch(/5 steps/i);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Setup Required",
        "content": "\nBefore writing any tests, install the test framework:\n\n```bash\nnpm install --save-dev jest @testing-library/react @testing-library/jest-dom \\\n  jest-environment-jsdom fake-indexeddb babel-jest @babel/preset-env @babel/preset-react\n```\n\nAdd to `package.json`:\n```json\n{\n  \"scripts\": {\n    \"test\": \"jest --coverage\"\n  },\n  \"jest\": {\n    \"testEnvironment\": \"jsdom\",\n    \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\"],\n    \"transform\": { \"^.+\\\\.js$\": \"babel-jest\" }\n  }\n}\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "Priority Summary",
        "content": "| Priority | Module | Gap Type | Risk |\n|---|---|---|---|\n| P0 | `HistoryOfThought` | Crypto correctness, vault lock | Security-critical |\n| P0 | `EventBus` | Listener lifecycle, silent drops | Data integrity |\n| P0 | `ExecutiveSpine` | Timer cleanup, localStorage corruption | State corruption |\n| P1 | `KnowledgeGraphService` | Regex edge cases, cap enforcement | Feature correctness |\n| P1 | `VerificationService` | Validation gate bypass via `detectedLevel` | UX gate |\n| P1 | `LiteralMode` | 16 regex patterns untested | Output quality |\n| P2 | All 17 services | Ollama error paths | Resilience |\n| P2 | Integration | Dial propagation, event pipeline | Cross-cutting |\n| P3 | 34 frontend components | Render, state, interaction | UI correctness |",
        "level": 2
      }
    ],
    "codeBlocks": [
      {
        "language": "js",
        "code": "// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../src/core/EventBus';\n\ndescribe('EventBus', () => {\n  let mockContext;\n\n  beforeEach(() => {\n    mockContext = {\n      isUnlocked: jest.fn().mockReturnValue(true),\n      appendEvent: jest.fn().mockResolvedValue(undefined),\n    };\n  });\n\n  afterEach(() => stopEventBus());\n\n  describe('startEventBus()', () => {\n    it('attaches window event listeners for all 8 event types', () => {\n      const spy = jest.spyOn(window, 'addEventListener');\n      startEventBus(() => mockContext);\n      expect(spy).toHaveBeenCalledTimes(8);\n    });\n\n    it('calls stopEventBus first if already started (idempotent re-entry)', () => {\n      const spy = jest.spyOn(window, 'removeEventListener');\n      startEventBus(() => mockContext);\n      startEventBus(() => mockContext); // second call\n      expect(spy).toHaveBeenCalled();\n    });\n  });\n\n  describe('stopEventBus()', () => {\n    it('removes all attached listeners', () => {\n      startEventBus(() => mockContext);\n      const spy = jest.spyOn(window, 'removeEventListener');\n      stopEventBus();\n      expect(spy).toHaveBeenCalledTimes(8);\n    });\n  });\n\n  describe('vault lock', () => {\n    it('silently drops events when vault is locked', async () => {\n      mockContext.isUnlocked.mockReturnValue(false);\n      startEventBus(() => mockContext);\n      recordTextEdit({ sectionId: 's1', wordsAfter: 10 });\n      await Promise.resolve();\n      expect(mockContext.appendEvent).not.toHaveBeenCalled();\n    });\n  });\n\n  describe('pickSafePayload()', () => {\n    it('sanitizes text_edit payload to only include allowed keys', () => {\n      startEventBus(() => mockContext);\n      recordTextEdit({ sectionId: 'sec1', wordsAfter: 42, secret: 'leak' });\n      // assert appendEvent was called WITHOUT 'secret' key\n    });\n\n    it('sanitizes citation payload', () => {\n      startEventBus(() => mockContext);\n      recordCitation({ added: true, source: 'APA', sourceId: 'r1' });\n      // assert payload shape\n    });\n  });\n});"
      },
      {
        "language": "js",
        "code": "// tests/core/ExecutiveSpine.test.js\nimport {\n  configureSpine, startFocusSession, endFocusSession, getFocusSession,\n  isFocusActive, startIdleDetection, stopIdleDetection,\n  getSectionHealth, setSectionHealth, getCredits, earnCredits, spendCredits,\n} from '../../src/core/ExecutiveSpine';\n\ndescribe('ExecutiveSpine', () => {\n  beforeEach(() => localStorage.clear());\n  afterEach(() => { endFocusSession({ reason: 'cleanup' }); stopIdleDetection(); });\n\n  describe('Focus Session', () => {\n    it('persists session to localStorage on start', () => {\n      startFocusSession({ taskId: 't1', durationMinutes: 25 });\n      const s = getFocusSession();\n      expect(s.taskId).toBe('t1');\n      expect(s.durationMinutes).toBe(25);\n    });\n\n    it('isFocusActive() returns false for expired session', () => {\n      const past = Date.now() - 1000;\n      localStorage.setItem('__sovereignFocus', JSON.stringify({ expiresAt: past }));\n      expect(isFocusActive()).toBe(false);\n    });\n\n    it('endFocusSession() clears localStorage key', () => {\n      startFocusSession({ taskId: 't1', durationMinutes: 1 });\n      endFocusSession({ reason: 'manual' });\n      expect(localStorage.getItem('__sovereignFocus')).toBeNull();\n    });\n\n    it('getFocusSession() returns null on corrupted JSON (no throw)', () => {\n      localStorage.setItem('__sovereignFocus', 'NOT_JSON');\n      expect(getFocusSession()).toBeNull();\n    });\n\n    it('clamps zero-duration sessions to minimum 1 minute', () => {\n      startFocusSession({ taskId: 't1', durationMinutes: 0 });\n      expect(getFocusSession().durationMinutes).toBeGreaterThanOrEqual(1);\n    });\n  });\n\n  describe('Section Health + PlayTime', () => {\n    it('getSectionHealth returns 0 for unknown section', () => {\n      expect(getSectionHealth('unknown')).toBe(0);\n    });\n\n    it('setSectionHealth persists dots value', () => {\n      setSectionHealth('intro', 3);\n      expect(getSectionHealth('intro')).toBe(3);\n    });\n\n    it('grants PlayTime when health threshold is crossed', () => {\n      configureSpine({ sectionHealthUnlockThreshold: 3 });\n      const spy = jest.spyOn(window, 'dispatchEvent');\n      setSectionHealth('intro', 3); // threshold met\n      expect(spy).toHaveBeenCalledWith(expect.objectContaining({ type: expect.stringContaining('playtime') }));\n    });\n  });\n\n  describe('Credits', () => {\n    it('earnCredits increments balance', () => {\n      earnCredits(10, 'test');\n      expect(getCredits()).toBe(10);\n    });\n\n    it('spendCredits is no-op when balance is insufficient', () => {\n      earnCredits(5, 'test');\n      spendCredits(10, 'test');\n      expect(getCredits()).toBe(5); // unchanged\n    });\n\n    it('spendCredits decrements when sufficient', () => {\n      earnCredits(20, 'test');\n      spendCredits(7, 'test');\n      expect(getCredits()).toBe(13);\n    });\n  });\n\n  describe('Idle Detection', () => {\n    it('does not fire nudge before threshold', () => {\n      jest.useFakeTimers();\n      const spy = jest.spyOn(window, 'dispatchEvent');\n      startIdleDetection({ thresholdMs: 10000 });\n      jest.advanceTimersByTime(5000);\n      expect(spy).not.toHaveBeenCalled();\n      jest.useRealTimers();\n    });\n\n    it('fires nudge once per idle crossing, not repeatedly', () => {\n      jest.useFakeTimers();\n      startIdleDetection({ thresholdMs: 1000 });\n      jest.advanceTimersByTime(3000);\n      const count = window.dispatchEvent.mock?.calls?.filter(\n        c => c[0]?.type?.includes('idle')\n      ).length;\n      expect(count).toBe(1);\n      jest.useRealTimers();\n    });\n  });\n});"
      },
