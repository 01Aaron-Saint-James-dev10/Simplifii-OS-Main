        "code": "// tests/services/KnowledgeGraphService.test.js\nimport { extractSemanticEntities } from '../../src/services/KnowledgeGraphService';\n\ndescribe('KnowledgeGraphService', () => {\n  it('extracts capitalised noun phrases', () => {\n    const result = extractSemanticEntities('Cell Division and Mitosis are key topics.');\n    const labels = result.map(e => e.label);\n    expect(labels).toContain('Cell Division');\n    expect(labels).toContain('Mitosis');\n  });\n\n  it('extracts acronyms', () => {\n    const result = extractSemanticEntities('The ATP cycle drives cellular respiration. ATP is crucial.');\n    const labels = result.map(e => e.label);\n    expect(labels).toContain('ATP');\n  });\n\n  it('filters STOP_PHRASES like \"The\", \"This\", \"University\"', () => {\n    const result = extractSemanticEntities('The University said This topic is important.');\n    const labels = result.map(e => e.label);\n    expect(labels).not.toContain('The');\n    expect(labels).not.toContain('University');\n  });\n\n  it('deduplicates case-insensitively', () => {\n    const result = extractSemanticEntities('Mitosis. Mitosis. mitosis.');\n    const mitosisItems = result.filter(e => e.label.toLowerCase() === 'mitosis');\n    expect(mitosisItems).toHaveLength(1);\n    expect(mitosisItems[0].confidence).toBeGreaterThan(0.6);\n  });\n\n  it('caps at 6 phrases and 4 acronyms', () => {\n    const text = 'Alpha Beta Gamma Delta Epsilon Zeta Eta. AA BB CC DD EE FF.';\n    const result = extractSemanticEntities(text);\n    const phrases = result.filter(e => e.type === 'phrase');\n    const acronyms = result.filter(e => e.type === 'acronym');\n    expect(phrases.length).toBeLessThanOrEqual(6);\n    expect(acronyms.length).toBeLessThanOrEqual(4);\n  });\n\n  it('returns fallback entity for empty/null input', () => {\n    expect(extractSemanticEntities('')).toHaveLength(1);\n    expect(extractSemanticEntities(null)).toHaveLength(1);\n  });\n});"
