        "language": "js",
        "code": "// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('literalise', () => {\n  // --- Guard clauses ---\n  test('returns non-string input unchanged', () => {\n    expect(literalise(null)).toBeNull();\n    expect(literalise(undefined)).toBeUndefined();\n    expect(literalise(42)).toBe(42);\n  });\n  test('returns empty string unchanged', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  // --- Pattern replacements ---\n  test('replaces \"consider revising\" with \"change\"', () => {\n    expect(literalise('consider revising your approach')).toBe('change your approach');\n  });\n  test('replaces academic verbs (case-insensitive)', () => {\n    expect(literalise('Synthesise sources')).toBe('Combine ideas from sources');\n    expect(literalise('Furthermore, this shows')).toBe('Also, this shows');\n  });\n  test('replaces passive voice patterns', () => {\n    expect(literalise('This should be revised')).toBe('This rewrite this');\n    expect(literalise('Evidence must be demonstrated')).toBe('Evidence show this');\n  });\n\n  // --- Em/en dash sanitisation ---\n  test('converts em-dash to comma before other transforms', () => {\n    const result = literalise('Step one\\u2014consider revising');\n    expect(result).toContain('change');\n    expect(result).not.toContain('\\u2014');\n  });\n\n  // --- splitClauses ---\n  test('splits on semicolon', () => {\n    const result = literalise('Do this; then do that');\n    expect(result).toContain('. ');\n  });\n  test('splits on \", and \"', () => {\n    const result = literalise('Write the intro, and then outline the body');\n    expect(result).toContain('. ');\n  });\n  test('splitClauses: false skips splitting', () => {\n    const result = literalise('Do this; then that', { splitClauses: false });\n    expect(result).not.toContain('. ');\n  });\n\n  // --- dropEmpty ---\n  test('collapses double spaces created by \"going forward\" deletion', () => {\n    const result = literalise('going forward you should write');\n    expect(result).not.toMatch(/\\s{2,}/);\n  });\n  test('capitalises first letter after a split', () => {\n    const result = literalise('do this; do that');\n    // After split, second sentence should start with capital\n    const sentences = result.split(/\\.\\s+/);\n    if (sentences.length > 1) {\n      expect(sentences[1][0]).toBe(sentences[1][0].toUpperCase());\n    }\n  });\n  test('dropEmpty: false preserves extra whitespace', () => {\n    const result = literalise('going forward  you', { dropEmpty: false });\n    expect(result).toMatch(/\\s{2,}/);\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('returns userPreference when boolean true', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true);\n  });\n  test('returns userPreference when boolean false', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false);\n  });\n  test('falls back to streamProfile.literalModeDefault when preference is null', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n  test('returns false when streamProfile is undefined', () => {\n    expect(shouldLiteralise(undefined, null)).toBe(false);\n  });\n  test('returns false when streamProfile has no literalModeDefault key', () => {\n    expect(shouldLiteralise({}, null)).toBe(false);\n  });\n});"
