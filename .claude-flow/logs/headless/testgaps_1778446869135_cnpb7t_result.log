=> {\n    const result = hydrate({ profile: { level: 'tafe' } });\n    expect(result.streamId).toBe('tafe');\n  });\n  test('falls back to tertiary when both streamId and level are absent', () => {\n    const result = hydrate({});\n    expect(result.streamId).toBe('tertiary');\n  });\n  test('falls back to tertiary when streamId is invalid', () => {\n    const result = hydrate({ streamId: 'invalid_stream' });\n    expect(result.streamId).toBe('tertiary');\n  });\n  test('returned object includes profile, vocab, theme, capabilities', () => {\n    const result = hydrate({ streamId: 'secondary' });\n    expect(result).toHaveProperty('profile');\n    expect(result).toHaveProperty('vocab');\n    expect(result).toHaveProperty('theme');\n    expect(result).toHaveProperty('capabilities');\n  });\n  test('getVocab falls back to DEFAULT_STREAM vocab for missing key', () => {\n    const result = hydrate({ streamId: 'primary' });\n    // A key that exists in tertiary but not primary should still return a string\n    const value = result.getVocab('__nonexistent_key__');\n    expect(typeof value).toBe('string');\n  });\n  test('canAccess returns false for null capabilities', () => {\n    // If stream.capabilities is not an array, should return false\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.canAccess('some_module')).toBe('boolean');\n  });\n  test('getDefaultLanding falls back to \"studio\"', () => {\n    // Even if profile.defaultLanding is missing, should return 'studio'\n    const result = hydrate({});\n    expect(result.getDefaultLanding()).toBeTruthy();\n  });\n});\n\ndescribe('applyTheme', () => {\n  test('sets CSS custom properties on document.documentElement', () => {\n    const result = hydrate({ streamId: 'primary' });\n    applyTheme(result);\n    // Verify at least one -- property was applied (if theme has any)\n    // This test is environment-sensitive; skip in non-browser environments\n    if (typeof document !== 'undefined') {