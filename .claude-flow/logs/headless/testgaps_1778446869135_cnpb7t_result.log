        "code": "// tests/services/KnowledgeGraphService.test.js\nimport { extractSemanticEntities } from '../../src/services/KnowledgeGraphService';\n\ndescribe('extractSemanticEntities', () => {\n  test('returns empty array for empty string', async () => {\n    expect(await extractSemanticEntities('')).toEqual([]);\n    expect(await extractSemanticEntities('   ')).toEqual([]);\n    expect(await extractSemanticEntities(null)).toEqual([]);\n  });\n\n  test('returns fallback \"Academic Source\" entity when no patterns match', async () => {\n    const result = await extractSemanticEntities('no capitalised words or acronyms here');\n    expect(result).toHaveLength(1);\n    expect(result[0].label).toBe('Academic Source');\n    expect(result[0].type).toBe('Document');\n    expect(result[0].confidence).toBe(1.0);\n  });\n\n  test('extracts capitalised multi-word phrases', async () => {\n    const text = 'Cognitive Load Theory has influenced Universal Design for Learning research.';\n    const result = await extractSemanticEntities(text);\n    const labels = result.map(e => e.label);\n    expect(labels.some(l => l.includes('Cognitive'))).toBe(true);\n  });\n\n  test('does not extract stop phrases as entities', async () => {\n    const text = 'The University Course Section covers the basics.';\n    const result = await extractSemanticEntities(text);\n    const labels = result.map(e => e.label);\n    expect(labels).not.toContain('The');\n    expect(labels).not.toContain('University');\n    expect(labels).not.toContain('Course');\n  });\n\n  test('extracts acronyms and assigns type \"Acronym\"', async () => {\n    const text = 'Students with ADHD may benefit from UDL strategies.';\n    const result = await extractSemanticEntities(text);\n    const acronymEntities = result.filter(e => e.type === 'Acronym');\n    expect(acronymEntities.length).toBeGreaterThan(0);\n    expect(acronymEntities.some(e => e.label === 'ADHD' || e.label === 'UDL')).toBe(true);\n  });\n\n  test('assigns type \"Course Code\" for pattern like BABS1201', async () => {\n    const text = 'This assessment is for BABS1201 students.';\n    const result = await extractSemanticEntities(text);\n    const courseCode = result.find(e => e.label === 'BABS1201');\n    expect(courseCode).toBeDefined();\n    expect(courseCode.type).toBe('Course Code');\n  });\n\n  test('confidence is capped at 0.99', async () => {\n    // Repeat a phrase 100 times to push confidence beyond cap\n    const text = Array(100).fill('Cognitive Load Theory').join(' ');\n    const result = await extractSemanticEntities(text);\n    result.forEach(e => {\n      expect(e.confidence).toBeLessThanOrEqual(0.99);\n    });\n  });\n\n  test('confidence for phrase appearing once is 0.65 (0.6 + 1*0.05)', async () => {\n    const text = 'Cognitive Load Theory is important.';\n    const result = await extractSemanticEntities(text);\n    const entity = result.find(e => e.label === 'Cognitive Load Theory');\n    if (entity) {\n      expect(entity.confidence).toBeCloseTo(0.65);\n    }\n  });\n\n  test('caps phrase results at 6 and acronym results at 4', async () => {\n    const phrases = ['Alpha Beta', 'Gamma Delta', 'Epsilon Zeta', 'Eta Theta', 'Iota Kappa', 'Lambda Mu', 'Nu Xi'];\n    const acronyms = ['ABCD', 'EFGH', 'IJKL', 'MNOP', 'QRST'];\n    const text = [...phrases, ...acronyms].join(' ') + ' ' + [...phrases, ...acronyms].join(' ');\n    const result = await extractSemanticEntities(text);\n    const conceptCount = result.filter(e => e.type === 'Concept').length;\n    const acronymCount = result.filter(e => e.type === 'Acronym' || e.type === 'Course Code').length;\n    expect(conceptCount).toBeLessThanOrEqual(6);\n    expect(acronymCount).toBeLessThanOrEqual(4);\n  });\n\n  test('deduplicates phrases case-insensitively', async () => {\n    const text = 'Cognitive Load Theory and cognitive load theory are the same.';\n    const result = await extractSemanticEntities(text);\n    const clt = result.filter(e => e.label.toLowerCase() === 'cognitive load theory');\n    expect(clt.length).toBe(1);\n  });\n\n  test('entity IDs follow expected format', async () => {\n    const text = 'Cognitive Load Theory and ADHD research.';\n    const result = await extractSemanticEntities(text);\n    result.forEach(e => {\n      expect(e.id).toMatch(/^(phrase_|acronym_|e)\\d+$/);\n    });\n  });\n});"
