  "output": "---\n\n## Test Coverage Analysis\n\n**Zero tests exist.** No test files, no test runner configured. `react-scripts` ships with Jest out of the box, so the infrastructure is already available -- you just need `@testing-library/react` and test files.\n\nBelow is a prioritised breakdown with test skeletons.\n\n---\n\n## Infrastructure Setup (zero cost, do first)\n\n```bash\nnpm install --save-dev @testing-library/react @testing-library/jest-dom @testing-library/user-event\n```\n\nAdd to `package.json` scripts:\n```json\n\"test\": \"react-scripts test\"\n```\n\n---\n\n## Priority 1 -- Pure Logic (easiest to test, highest ROI)\n\n### `src/core/LiteralMode.js`\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('literalise', () => {\n  // --- Guard clauses ---\n  test('returns non-string input unchanged', () => {\n    expect(literalise(null)).toBeNull();\n    expect(literalise(undefined)).toBeUndefined();\n    expect(literalise(42)).toBe(42);\n  });\n  test('returns empty string unchanged', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  // --- Pattern replacements ---\n  test('replaces \"consider revising\" with \"change\"', () => {\n    expect(literalise('consider revising your approach')).toBe('change your approach');\n  });\n  test('replaces academic verbs (case-insensitive)', () => {\n    expect(literalise('Synthesise sources')).toBe('Combine ideas from sources');\n    expect(literalise('Furthermore, this shows')).toBe('Also, this shows');\n  });\n  test('replaces passive voice patterns', () => {\n    expect(literalise('This should be revised')).toBe('This rewrite this');\n    expect(literalise('Evidence must be demonstrated')).toBe('Evidence show this');\n  });\n\n  // --- Em/en dash sanitisation ---\n  test('converts em-dash to comma before other transforms', () => {\n    const result = literalise('Step one\\u2014consider revising');\n    expect(result).toContain('change');\n    expect(result).not.toContain('\\u2014');\n  });\n\n  // --- splitClauses ---\n  test('splits on semicolon', () => {\n    const result = literalise('Do this; then do that');\n    expect(result).toContain('. ');\n  });\n  test('splits on \", and \"', () => {\n    const result = literalise('Write the intro, and then outline the body');\n    expect(result).toContain('. ');\n  });\n  test('splitClauses: false skips splitting', () => {\n    const result = literalise('Do this; then that', { splitClauses: false });\n    expect(result).not.toContain('. ');\n  });\n\n  // --- dropEmpty ---\n  test('collapses double spaces created by \"going forward\" deletion', () => {\n    const result = literalise('going forward you should write');\n    expect(result).not.toMatch(/\\s{2,}/);\n  });\n  test('capitalises first letter after a split', () => {\n    const result = literalise('do this; do that');\n    // After split, second sentence should start with capital\n    const sentences = result.split(/\\.\\s+/);\n    if (sentences.length > 1) {\n      expect(sentences[1][0]).toBe(sentences[1][0].toUpperCase());\n    }\n  });\n  test('dropEmpty: false preserves extra whitespace', () => {\n    const result = literalise('going forward  you', { dropEmpty: false });\n    expect(result).toMatch(/\\s{2,}/);\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('returns userPreference when boolean true', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true);\n  });\n  test('returns userPreference when boolean false', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false);\n  });\n  test('falls back to streamProfile.literalModeDefault when preference is null', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n  test('returns false when streamProfile is undefined', () => {\n    expect(shouldLiteralise(undefined, null)).toBe(false);\n  });\n  test('returns false when streamProfile has no literalModeDefault key', () => {\n    expect(shouldLiteralise({}, null)).toBe(false);\n  });\n});\n```\n\n---\n\n### `src/core/SovereignRouter.js`\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, applyTheme } from '../../src/core/SovereignRouter';\nimport { __internals } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test.each([\n    ['primary',     'primary'],\n    ['secondary',   'secondary'],\n    ['highschool',  'secondary'],\n    ['tafe',        'tafe'],\n    ['homeschool',  'homeschool'],\n    ['university',  'tertiary'],\n    ['undergrad',   'tertiary'],\n    ['honours',     'tertiary'],\n    ['mres',        'tertiary'],\n    ['phd',         'tertiary'],\n  ])('maps level \"%s\" to stream \"%s\"', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('PRIMARY')).toBe('primary');\n    expect(streamFromLevel('TAFE')).toBe('tafe');\n  });\n  test('trims whitespace', () => {\n    expect(streamFromLevel('  secondary  ')).toBe('secondary');\n  });\n  test('unknown level falls back to tertiary', () => {\n    expect(streamFromLevel('vocational')).toBe('tertiary');\n  });\n  test('null/undefined falls back to tertiary', () => {\n    expect(streamFromLevel(null)).toBe('tertiary');\n    expect(streamFromLevel(undefined)).toBe('tertiary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('returns true for all valid stream ids', () => {\n    ['primary', 'secondary', 'tertiary', 'tafe', 'homeschool'].forEach(id => {\n      expect(isValidStream(id)).toBe(true);\n    });\n  });\n  test('returns false for unknown id', () => {\n    expect(isValidStream('phd')).toBe(false);\n    expect(isValidStream('')).toBe(false);\n    expect(isValidStream(null)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('uses explicit streamId when valid', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.streamId).toBe('primary');\n  });\n  test('derives stream from profile.level when streamId absent', () => {\n    const result = hydrate({ profile: { level: 'tafe' } });\n    expect(result.streamId).toBe('tafe');\n  });\n  test('falls back to tertiary when both streamId and level are absent', () => {\n    const result = hydrate({});\n    expect(result.streamId).toBe('tertiary');\n  });\n  test('falls back to tertiary when streamId is invalid', () => {\n    const result = hydrate({ streamId: 'invalid_stream' });\n    expect(result.streamId).toBe('tertiary');\n  });\n  test('returned object includes profile, vocab, theme, capabilities', () => {\n    const result = hydrate({ streamId: 'secondary' });\n    expect(result).toHaveProperty('profile');\n    expect(result).toHaveProperty('vocab');\n    expect(result).toHaveProperty('theme');\n    expect(result).toHaveProperty('capabilities');\n  });\n  test('getVocab falls back to DEFAULT_STREAM vocab for missing key', () => {\n    const result = hydrate({ streamId: 'primary' });\n    // A key that exists in tertiary but not primary should still return a string\n    const value = result.getVocab('__nonexistent_key__');\n    expect(typeof value).toBe('string');\n  });\n  test('canAccess returns false for null capabilities', () => {\n    // If stream.capabilities is not an array, should return false\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.canAccess('some_module')).toBe('boolean');\n  });\n  test('getDefaultLanding falls back to \"studio\"', () => {\n    // Even if profile.defaultLanding is missing, should return 'studio'\n    const result = hydrate({});\n    expect(result.getDefaultLanding()).toBeTruthy();\n  });\n});\n\ndescribe('applyTheme', () => {\n  test('sets CSS custom properties on document.documentElement', () => {\n    const result = hydrate({ streamId: 'primary' });\n    applyTheme(result);\n    // Verify at least one -- property was applied (if theme has any)\n    // This test is environment-sensitive; skip in non-browser environments\n    if (typeof document !== 'undefined') {\n      const styles = document.documentElement.style;\n      expect(styles).toBeTruthy();\n    }\n  });\n  test('is a no-op when stream is null', () => {\n    expect(() => applyTheme(null)).not.toThrow();\n  });\n  test('is a no-op when stream.theme is absent', () => {\n    expect(() => applyTheme({})).not.toThrow();\n  });\n});\n```\n\n---\n\n### `src/services/KnowledgeGraphService.js`\n\n```js\n// tests/services/KnowledgeGraphService.test.js\nimport { extractSemanticEntities } from '../../src/services/KnowledgeGraphService';\n\ndescribe('extractSemanticEntities', () => {\n  test('returns empty array for empty string', async () => {\n    expect(await extractSemanticEntities('')).toEqual([]);\n    expect(await extractSemanticEntities('   ')).toEqual([]);\n    expect(await extractSemanticEntities(null)).toEqual([]);\n  });\n\n  test('returns fallback \"Academic Source\" entity when no patterns match', async () => {\n    const result = await extractSemanticEntities('no capitalised words or acronyms here');\n    expect(result).toHaveLength(1);\n    expect(result[0].label).toBe('Academic Source');\n    expect(result[0].type).toBe('Document');\n    expect(result[0].confidence).toBe(1.0);\n  });\n\n  test('extracts capitalised multi-word phrases', async () => {\n    const text = 'Cognitive Load Theory has influenced Universal Design for Learning research.';\n    const result = await extractSemanticEntities(text);\n    const labels = result.map(e => e.label);\n    expect(labels.some(l => l.includes('Cognitive'))).toBe(true);\n  });\n\n  test('does not extract stop phrases as entities', async () => {\n    const text = 'The University Course Section covers the basics.';\n    const result = await extractSemanticEntities(text);\n    const labels = result.map(e => e.label);\n    expect(labels).not.toContain('The');\n    expect(labels).not.toContain('University');\n    expect(labels).not.toContain('Course');\n  });\n\n  test('extracts acronyms and assigns type \"Acronym\"', async () => {\n    const text = 'Students with ADHD may benefit from UDL strategies.';\n    const result = await extractSemanticEntities(text);\n    const acronymEntities = result.filter(e => e.type === 'Acronym');\n    expect(acronymEntities.length).toBeGreaterThan(0);\n    expect(acronymEntities.some(e => e.label === 'ADHD' || e.label === 'UDL')).toBe(true);\n  });\n\n  test('assigns type \"Course Code\" for pattern like BABS1201', async () => {\n    const text = 'This assessment is for BABS1201 students.';\n    const result = await extractSemanticEntities(text);\n    const courseCode = result.find(e => e.label === 'BABS1201');\n    expect(courseCode).toBeDefined();\n    expect(courseCode.type).toBe('Course Code');\n  });\n\n  test('confidence is capped at 0.99', async () => {\n    // Repeat a phrase 100 times to push confidence beyond cap\n    const text = Array(100).fill('Cognitive Load Theory').join(' ');\n    const result = await extractSemanticEntities(text);\n    result.forEach(e => {\n      expect(e.confidence).toBeLessThanOrEqual(0.99);\n    });\n  });\n\n  test('confidence for phrase appearing once is 0.65 (0.6 + 1*0.05)', async () => {\n    const text = 'Cognitive Load Theory is important.';\n    const result = await extractSemanticEntities(text);\n    const entity = result.find(e => e.label === 'Cognitive Load Theory');\n    if (entity) {\n      expect(entity.confidence).toBeCloseTo(0.65);\n    }\n  });\n\n  test('caps phrase results at 6 and acronym results at 4', async () => {\n    const phrases = ['Alpha Beta', 'Gamma Delta', 'Epsilon Zeta', 'Eta Theta', 'Iota Kappa', 'Lambda Mu', 'Nu Xi'];\n    const acronyms = ['ABCD', 'EFGH', 'IJKL', 'MNOP', 'QRST'];\n    const text = [...phrases, ...acronyms].join(' ') + ' ' + [...phrases, ...acronyms].join(' ');\n    const result = await extractSemanticEntities(text);\n    const conceptCount = result.filter(e => e.type === 'Concept').length;\n    const acronymCount = result.filter(e => e.type === 'Acronym' || e.type === 'Course Code').length;\n    expect(conceptCount).toBeLessThanOrEqual(6);\n    expect(acronymCount).toBeLessThanOrEqual(4);\n  });\n\n  test('deduplicates phrases case-insensitively', async () => {\n    const text = 'Cognitive Load Theory and cognitive load theory are the same.';\n    const result = await extractSemanticEntities(text);\n    const clt = result.filter(e => e.label.toLowerCase() === 'cognitive load theory');\n    expect(clt.length).toBe(1);\n  });\n\n  test('entity IDs follow expected format', async () => {\n    const text = 'Cognitive Load Theory and ADHD research.';\n    const result = await extractSemanticEntities(text);\n    result.forEach(e => {\n      expect(e.id).toMatch(/^(phrase_|acronym_|e)\\d+$/);\n    });\n  });\n});\n```\n\n---\n\n## Priority 2 -- Integration Gaps\n\n### EventBus → HistoryOfThought lock coordination\n\n```js\n// tests/integration/EventBusVaultLock.test.js\nimport { startEventBus, stopEventBus, recordTextEdit } from '../../src/core/EventBus';\nimport { isUnlocked } from '../../src/core/HistoryOfThought';\n\ndescribe('EventBus with locked vault', () => {\n  afterEach(() => stopEventBus());\n\n  test('recordTextEdit does not throw when vault is locked', () => {\n    startEventBus();\n    expect(isUnlocked()).toBe(false);\n    expect(() => recordTextEdit({ sectionId: 's1', delta: 'hello' })).not.toThrow();\n  });\n\n  test('startEventBus called twice does not attach duplicate listeners', () => {\n    startEventBus();\n    startEventBus();\n    // Dispatch one event and verify it does not double-fire\n    // (requires spy on HistoryOfThought.appendEvent)\n  });\n});\n```\n\n### RewriteService provider fallback\n\n```js\n// tests/integration/RewriteServiceFallback.test.js\nimport { rewrite } from '../../src/services/RewriteService';\n\ndescribe('rewrite provider fallback', () => {\n  beforeEach(() => {\n    jest.spyOn(global, 'fetch').mockRejectedValue(new Error('Network error'));\n  });\n  afterEach(() => jest.restoreAllMocks());\n\n  test('falls back gracefully when Ollama is unreachable', async () => {\n    const result = await rewrite('Some text to rewrite', { level: 'tertiary' });\n    // Should not throw; should return something (possibly original text or mock)\n    expect(typeof result).toBe('string');\n  });\n});\n```\n\n---\n\n## Priority 3 -- Error Handling Gaps (skeletons)\n\n```js\n// tests/core/HistoryOfThought.test.js\nimport { isUnlocked, unlockWithPassphrase, lockSession, appendEvent } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought', () => {\n  test('isUnlocked returns false before any unlock', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlockWithPassphrase rejects empty passphrase', async () => {\n    await expect(unlockWithPassphrase('')).rejects.toThrow();\n  });\n\n  test('appendEvent is a no-op (soft drop) when vault is locked', async () => {\n    // Should not throw even with vault locked\n    await expect(appendEvent({ type: 'text_edit', payload: {} })).resolves.not.toThrow();\n  });\n\n  test('lockSession sets isUnlocked to false', async () => {\n    // Unlock first (requires a valid passphrase and mocked IndexedDB)\n    await lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n\n  // Edge cases for crypto\n  test('decrypt with tampered ciphertext throws or returns null gracefully', async () => {\n    // Requires mocking the crypto subtle key state\n  });\n});\n\n// tests/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, isFocusActive,\n  getCredits, earnCredits, spendCredits,\n  getSectionHealth, setSectionHealth\n} from '../../src/core/ExecutiveSpine';\n\ndescribe('ExecutiveSpine credits', () => {\n  test('getCredits returns 0 with no prior session', () => {\n    localStorage.clear();\n    expect(getCredits()).toBe(0);\n  });\n  test('earnCredits increases balance', () => {\n    localStorage.clear();\n    earnCredits(10);\n    expect(getCredits()).toBe(10);\n  });\n  test('spendCredits decreases balance', () => {\n    localStorage.clear();\n    earnCredits(10);\n    spendCredits(4);\n    expect(getCredits()).toBe(6);\n  });\n  test('spendCredits does not go below zero', () => {\n    localStorage.clear();\n    spendCredits(100);\n    expect(getCredits()).toBeGreaterThanOrEqual(0);\n  });\n});\n\ndescribe('ExecutiveSpine section health', () => {\n  test('setSectionHealth clamps to 0-5 range', () => {\n    setSectionHealth('intro', 10);\n    expect(getSectionHealth('intro')).toBeLessThanOrEqual(5);\n    setSectionHealth('intro', -5);\n    expect(getSectionHealth('intro')).toBeGreaterThanOrEqual(0);\n  });\n});\n\ndescribe('ExecutiveSpine focus session', () => {\n  afterEach(() => endFocusSession());\n\n  test('isFocusActive is false before start', () => {\n    expect(isFocusActive()).toBe(false);\n  });\n  test('isFocusActive is true after start', () => {\n    startFocusSession({ durationSeconds: 60 });\n    expect(isFocusActive()).toBe(true);\n  });\n  test('starting a second session while active does not throw', () => {\n    startFocusSession({ durationSeconds: 60 });\n    expect(() => startFocusSession({ durationSeconds: 60 })).not.toThrow();\n  });\n});\n```\n\n---\n\n## Summary\n\n| Priority | Files | Effort | ROI |\n|----------|-------|--------|-----|\n| 1 -- Pure logic | `LiteralMode`, `SovereignRouter`, `KnowledgeGraphService` | ~4h | Very high |\n| 2 -- Core state | `ExecutiveSpine`, `HistoryOfThought`, `EventBus` | ~12h | High |\n| 3 -- Services | `RewriteService`, `BriefService`, `ChatService` | ~20h | High |\n| 4 -- Integration | EventBus→Vault, Ollama fallback | ~8h | Medium |\n| 5 -- Components | `LinearCanvas`, `SteeringDrawer`, `AskAura` | ~30h | Medium |\n\n**Start with Priority 1** -- the three pure-function modules have no async, no DOM, no IndexedDB dependencies. The test skeletons above can run immediately after installing `@testing-library/react`.\n",
