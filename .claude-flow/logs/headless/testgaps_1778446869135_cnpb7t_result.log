      {
        "title": "EventBus → HistoryOfThought lock coordination",
        "content": "\n```js\n// tests/integration/EventBusVaultLock.test.js\nimport { startEventBus, stopEventBus, recordTextEdit } from '../../src/core/EventBus';\nimport { isUnlocked } from '../../src/core/HistoryOfThought';\n\ndescribe('EventBus with locked vault', () => {\n  afterEach(() => stopEventBus());\n\n  test('recordTextEdit does not throw when vault is locked', () => {\n    startEventBus();\n    expect(isUnlocked()).toBe(false);\n    expect(() => recordTextEdit({ sectionId: 's1', delta: 'hello' })).not.toThrow();\n  });\n\n  test('startEventBus called twice does not attach duplicate listeners', () => {\n    startEventBus();\n    startEventBus();\n    // Dispatch one event and verify it does not double-fire\n    // (requires spy on HistoryOfThought.appendEvent)\n  });\n});\n```\n\n",
        "level": 3
      },
      {
        "title": "RewriteService provider fallback",
        "content": "\n```js\n// tests/integration/RewriteServiceFallback.test.js\nimport { rewrite } from '../../src/services/RewriteService';\n\ndescribe('rewrite provider fallback', () => {\n  beforeEach(() => {\n    jest.spyOn(global, 'fetch').mockRejectedValue(new Error('Network error'));\n  });\n  afterEach(() => jest.restoreAllMocks());\n\n  test('falls back gracefully when Ollama is unreachable', async () => {\n    const result = await rewrite('Some text to rewrite', { level: 'tertiary' });\n    // Should not throw; should return something (possibly original text or mock)\n    expect(typeof result).toBe('string');\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Priority 3 -- Error Handling Gaps (skeletons)",
        "content": "\n```js\n// tests/core/HistoryOfThought.test.js\nimport { isUnlocked, unlockWithPassphrase, lockSession, appendEvent } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought', () => {\n  test('isUnlocked returns false before any unlock', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlockWithPassphrase rejects empty passphrase', async () => {\n    await expect(unlockWithPassphrase('')).rejects.toThrow();\n  });\n\n  test('appendEvent is a no-op (soft drop) when vault is locked', async () => {\n    // Should not throw even with vault locked\n    await expect(appendEvent({ type: 'text_edit', payload: {} })).resolves.not.toThrow();\n  });\n\n  test('lockSession sets isUnlocked to false', async () => {\n    // Unlock first (requires a valid passphrase and mocked IndexedDB)\n    await lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n\n  // Edge cases for crypto\n  test('decrypt with tampered ciphertext throws or returns null gracefully', async () => {\n    // Requires mocking the crypto subtle key state\n  });\n});\n\n// tests/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, isFocusActive,\n  getCredits, earnCredits, spendCredits,\n  getSectionHealth, setSectionHealth\n} from '../../src/core/ExecutiveSpine';\n\ndescribe('ExecutiveSpine credits', () => {\n  test('getCredits returns 0 with no prior session', () => {\n    localStorage.clear();\n    expect(getCredits()).toBe(0);\n  });\n  test('earnCredits increases balance', () => {\n    localStorage.clear();\n    earnCredits(10);\n    expect(getCredits()).toBe(10);\n  });\n  test('spendCredits decreases balance', () => {\n    localStorage.clear();\n    earnCredits(10);\n    spendCredits(4);\n    expect(getCredits()).toBe(6);\n  });\n  test('spendCredits does not go below zero', () => {\n    localStorage.clear();\n    spendCredits(100);\n    expect(getCredits()).toBeGreaterThanOrEqual(0);\n  });\n});\n\ndescribe('ExecutiveSpine section health', () => {\n  test('setSectionHealth clamps to 0-5 range', () => {\n    setSectionHealth('intro', 10);\n    expect(getSectionHealth('intro')).toBeLessThanOrEqual(5);\n    setSectionHealth('intro', -5);\n    expect(getSectionHealth('intro')).toBeGreaterThanOrEqual(0);\n  });\n});\n\ndescribe('ExecutiveSpine focus session', () => {\n  afterEach(() => endFocusSession());\n\n  test('isFocusActive is false before start', () => {\n    expect(isFocusActive()).toBe(false);\n  });\n  test('isFocusActive is true after start', () => {\n    startFocusSession({ durationSeconds: 60 });\n    expect(isFocusActive()).toBe(true);\n  });\n  test('starting a second session while active does not throw', () => {\n    startFocusSession({ durationSeconds: 60 });\n    expect(() => startFocusSession({ durationSeconds: 60 })).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 2
      },
