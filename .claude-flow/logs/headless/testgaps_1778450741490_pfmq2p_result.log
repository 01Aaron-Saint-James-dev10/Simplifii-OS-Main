le\n  test('startFocusSession does not throw when localStorage throws', () => {\n    jest.spyOn(Storage.prototype, 'setItem').mockImplementation(() => {\n      throw new DOMException('Storage full');\n    });\n    expect(() => startFocusSession({ streamId: 'primary' })).not.toThrow();\n  });\n});\n\ndescribe('ExecutiveSpine — section health', () => {\n  test('setSectionHealth persists and getSectionHealth returns it', () => {\n    setSectionHealth('essay', 3);\n    expect(getSectionHealth('essay')).toBe(3);\n  });\n\n  test('setSectionHealth at 5 triggers PlayTime grant', () => {\n    const spy = jest.spyOn({ grantPlayTime }, 'grantPlayTime');\n    setSectionHealth('essay', 5); // Should auto-grant PlayTime\n    // assert grantPlayTime was called or isPlayTimeActive() flips\n  });\n\n  test('health value clamps between 0 and 5', () => {\n    setSectionHealth('essay', 99);\n    expect(getSectionHealth('essay')).toBe(5);\n    setSectionHealth('essay', -1);\n    expect(getSectionHealth('essay')).toBe(0);\n  });\n});\n\ndescribe('ExecutiveSpine — credits', () => {\n  test('earnCredits increases balance', () => {\n    const before = getCredits();\n    earnCredits(10);\n    expect(getCredits()).toBe(before + 10);\n  });\n\n  test('spendCredits decreases balance', () => {\n    earnCredits(20);\n    spendCredits(5);\n    expect(getCredits()).toBeLessThan(getCredits() + 5); // confirm deduction\n  });\n\n  test('spendCredits does not go below zero', () => {\n    spendCredits(99999);\n    expect(getCredits()).toBeGreaterThanOrEqual(0);\n  });\n});\n```\n\n---\n\n## Priority 3: Text Pipeline (High Risk)\n\n### `LiteralMode.js` — 20+ regex patterns, zero tests\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('shouldLiteralise()', () => {\n  test('returns true when stream is primary and literal mode enabled', () => {\n    expect(shouldLiteralise({ stream: 'primary', literalMode: true })).toBe(true);\n  });\n  test('returns false for secondary stream regardless of literalMode', () => {\n    expect(shouldLiteralise({ stream: 'secondary', literalMode: true })).toBe(false);\n  });\n});\n\ndescribe('literalise() — pattern replacements', () => {\n  test('replaces em-dashes with commas', () => {\n    expect(literalise('cats — dogs')).toBe('cats, dogs');\n  });\n  test('splits clauses on semicolons', () => {\n    const out = literalise('First point; second point');\n    expect(out).toContain('First point');\n    expect(out).toContain('Second point'); // capitalised after split\n  });\n  test('handles empty string without throwing', () => {\n    expect(() => literalise('')).not.toThrow();\n    expect(literalise('')).toBe('');\n  });\n  test('handles null/undefined gracefully', () => {\n    expect(() => literalise(null)).not.toThrow();\n  });\n  test('preserves LaTeX blocks from replacement', () => {\n    const latex = '$E = mc^2$';\n    expect(literalise(latex)).toContain('$E = mc^2$');\n  });\n  test('does not alter text that needs no transformation', () => {\n    const plain = 'The cat sat on the mat.';\n    expect(literalise(plain)).toBe(plain);\n  });\n});\n```\n\n### `SovereignRouter.js` — Stream resolution logic\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, applyTheme } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel()', () => {\n  test.each([\n    [1, 'primary'], [2, 'primary'], [7, 'primary'],\n    [8, 'secondary'], [11, 'secondary'],\n    [12, 'tafe'], [13, 'tafe'],\n  ])('level %i maps to stream %s', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('invalid level falls back to tertiary/default', () => {\n    expect(streamFromLevel(999)).toBeDefined(); // should not throw\n  });\n});\n\ndescribe('isValidStream()', () => {\n  test('accepts known streams', () => {\n    ['primary', 'secondary', 'tafe', 'homeschool'].forEach(s => {\n      expect(isValidStream(s)).toBe(true);\n    });\n  });\n  test('rejects unknown stream', () => {\n    expect(isValidStream('unknown')).toBe(false);\n  });\n});\n\ndescribe('applyTheme()', () => {\n  test('sets CSS custom properties on document root', () => {\n    document.documentElement.style.setProperty = jest.fn();\n    applyTheme('primary');\n    expect(document.documentElement.style.setProperty).toHaveBeenCalled();\n  });\n  test('does not throw for unknown theme', () => {\n    expect(() => applyTheme('nonexistent')).not.toThrow();\n  });\n});\n```\n\n---\n\n## Priority 4: Event Pipeline (High Risk)\n\n### `EventBus.js` — Silent-drop on vault lock is unverified\n\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../src/core/EventBus';\nimport * as HistoryOfThought from '../../src/core/HistoryOfThought';\n\njest.mock('../../src/core/HistoryOfThought');\n\ndescribe('EventBus — event routing', () => {\n  beforeEach(() => {\n    HistoryOfThought.isUnlocked.mockReturnValue(true);\n    HistoryOfThought.appendEvent.mockResolvedValue(undefined);\n    startEventBus(() => ({ streamId: 'primary', userId: 'u1' }));\n  });\n  afterEach(() => stopEventBus());\n\n  test('recordTextEdit calls appendEvent when vault unlocked', async () => {\n    await recordTextEdit({ content: 'test content' });\n    expect(HistoryOfThought.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ type: 'text_edit' })\n    );\n  });\n\n  test('recordTextEdit silently skips when vault locked', async () => {\n    HistoryOfThought.isUnlocked.mockReturnValue(false);\n    await recordTextEdit({ content: 'test' });\n    expect(HistoryOfThought.appendEvent).not.toHaveBeenCalled();\n  });\n\n  test('recordCitation includes citation fields in payload', async () => {\n    await recordCitation({ source: 'Smith 2020', page: 42 });\n    expect(HistoryOfThought.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ type: 'citation', source: 'Smith 2020' })\n    );\n  });\n\n  test('appendEvent failure does not propagate to caller', async () => {\n    HistoryOfThought.appendEvent.mockRejectedValue(new Error('IndexedDB failure'));\n    await expect(recordTextEdit({ content: 'x' })).resolves.toBeUndefined();\n  });\n});\n```\n\n---\n\n## Priority 5: Service Layer (High Risk)\n\n### `BriefService.js` — Evidence formula regex\n\n```js\n// tests/services/BriefService.test.js\nimport { extractEvidenceFormula, extractDynamicThemes, deriveRoadmapFromAssessments } from '../../src/services/BriefService';\n\ndescribe('extractEvidenceFormula()', () => {\n  test('detects peer-reviewed sources requirement', () => {\n    const result = extractEvidenceFormula('You must cite at least 8 peer-reviewed journal articles');\n    expect(result.peerReviewed).toBe(8);\n  });\n  test('detects minimum sources from text', () => {\n    const result = extractEvidenceFormula('Include a minimum of 5 academic sources');\n    expect(result.minSources).toBe(5);\n  });\n  test('returns safe defaults for empty brief', () => {\n    const result = extractEvidenceFormula('');\n    expect(result).toBeDefined();\n    expect(result.minSources).toBeGreaterThanOrEqual(0);\n  });\n  test('handles null without throwing', () => {\n    expect(() => extractEvidenceFormula(null)).not.toThrow();\n  });\n});\n\ndescribe('extractDynamicThemes()', () => {\n  test('extracts capitalised topic words from brief', () => {\n    const themes = extractDynamicThemes('Discuss Photosynthesis and Cellular Respiration in detail');\n    expect(themes).toContain('Photosynthesis');\n    expect(themes).toContain('Cellular Respiration');\n  });\n  test('returns empty array for all-lowercase text', () => {\n    expect(extractDynamicThemes('no capitals here')).toEqual([]);\n  });\n});\n\ndescribe('deriveRoadmapFromAssessments()', () => {\n  test('returns ordered milestones from assessments', () => {\n    const assessments = [\n      { title: 'Essay', dueDate: '2026-06-01', weight: 40 },\n      { title: 'Quiz', dueDate: '2026-05-15', weight: 10 },\n    ];\n    const roadmap = deriveRoadmapFromAssessments(assessments);\n    expect(roadmap[0].title).toBe('Quiz'); // earlier due date first\n  });\n  test('handles empty assessments array', () => {\n    expect(deriveRoadmapFromAssessments([])).toEqual([]);\n  });\n});\n```\n\n### `MicroStepService.js` — Step count and Ollama fallback\n\n```js\n// tests/services/MicroStepService.test.js\nimport { generateMicroSteps } from '../../src/services/MicroStepService';\n\nglobal.fetch = jest.fn();\n\ndescribe('generateMicroSteps()', () => {\n  afterEach(() => jest.clearAllMocks());\n\n  test('returns 5 steps for heavy scaffolding', async () => {\n    fetch.mockResolvedValue({\n      ok: true,\n      json: async () => ({\n        message: { content: JSON.stringify({ steps: Array(5).fill({ action: 'Do x', why: 'y' }) }) }\n      })\n    });\n    const steps = await generateMicroSteps({ scaffolding: 'heavy', task: 'Write intro' });\n    expect(steps).toHaveLength(5);\n  });\n\n  test('returns 3 steps for light scaffolding', async () => {\n    fetch.mockResolvedValue({\n      ok: true,\n      json: async () => ({\n        message: { content: JSON.stringify({ steps: Array(3).fill({ action: 'Do x', why: 'y' }) }) }\n      })\n    });\n    const steps = await generateMicroSteps({ scaffolding: 'light', task: 'Write intro' });\n    expect(steps).toHaveLength(3);\n  });\n\n  test('returns fallback steps when Ollama is unreachable', async () => {\n    fetch.mockRejectedValue(new Error('Network error'));\n    const steps = await generateMicroSteps({ scaffolding: 'heavy', task: 'Write intro' });\n    expect(steps.length).toBeGreaterThan(0); // fallback, not empty\n  });\n\n  test('filters out steps shorter than 3 chars', async () => {\n    fetch.mockResolvedValue({\n      ok: true,\n      json: async () => ({\n        message: { content: JSON.stringify({ steps: [{ action: 'x', why: 'y' }, { action: 'Write a proper introduction', why: 'anchors your argument' }] }) }\n      })\n    });\n    const steps = await generateMicroSteps({ scaffolding: 'balanced', task: 'intro' });\n    expect(steps.every(s => s.action.length >= 3)).toBe(true);\n  });\n});\n```\n\n---\n\n## Priority 6: Integration Gaps\n\n### `IndexedDBService.js` — No storage tests\n\n```js\n// tests/services/IndexedDBService.test.js\nimport 'fake-indexeddb/auto'; // npm install --save-dev fake-indexeddb\nimport { initDB, saveBlockSnapshot, getBlockHistory, saveGhostAsset, getAllGhostAssets } from '../../src/services/IndexedDBService';\n\ndescribe('IndexedDBService', () => {\n  beforeAll(() => initDB());\n\n  test('saveBlockSnapshot then getBlockHistory returns saved blocks', async () => {\n    await saveBlockSnapshot({ blockId: 'b1', content: 'paragraph one', timestamp: Date.now() });\n    const history = await getBlockHistory('b1');\n    expect(history.length).toBeGreaterThan(0);\n    expect(history[0].content).toBe('paragraph one');\n  });\n\n  test('getBlockHistory returns empty array for unknown blockId', async () => {\n    const history = await getBlockHistory('nonexistent');\n    expect(history).toEqual([]);\n  });\n\n  test('saveGhostAsset and getAllGhostAssets round-trip', async () => {\n    await saveGhostAsset({ id: 'a1', name: 'lecture.pdf', url: 'blob://...' });\n    const assets = await getAllGhostAssets();\n    expect(assets.find(a => a.id === 'a1')).toBeDefined();\n  });\n\n  test('initDB is idempotent (no error on second call)', async () => {\n    await expect(initDB()).resolves.not.toThrow();\n  });\n});\n```\n\n### `SovereignReconciler.js` — Deduplication logic\n\n```js\n// tests/services/SovereignReconciler.test.js\nimport { reconcile } from '../../src/services/SovereignReconciler';\n\ndescribe('reconcile()', () => {\n  test('deduplicates assessments with identical titles', () => {\n    const input = [\n      { title: 'Essay 1', weight: 40 },\n      { title: 'Essay 1', weight: 40 }, // duplicate\n    ];\n    const result = reconcile(input);\n    expect(result).toHaveLength(1);\n  });\n\n  test('normalises title casing before comparing', () => {\n    const input = [\n      { title: 'ESSAY 1', weight: 40 },\n      { title: 'essay 1', weight: 40 },\n    ];\n    const result = reconcile(input);\n    expect(result).toHaveLength(1);\n  });\n\n  test('preserves distinct assessments', () => {\n    const input = [\n      { title: 'Essay', weight: 40 },\n      { title: 'Quiz', weight: 10 },\n    ];\n    expect(reconcile(input)).toHaveLength(2);\n  });\n\n  test('handles empty input', () => {\n    expect(reconcile([])).toEqual([]);\n  });\n});\n```\n\n---\n\n## Recommended Setup\n\nInstall the missing test infrastructure first:\n\n```bash\nnpm install --save-dev jest @testing-library/react @testing-library/jest-dom \\\n  jest-environment-jsdom fake-indexeddb\n\n# Add to package.json:\n# \"scripts\": { \"test\": \"jest\", \"test:watch\": \"jest --watch\" }\n# \"jest\": { \"testEnvironment\": \"jsdom\", \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\"] }\n```\n\n---\n\n## Summary by Priority\n\n| Priority | Area | Risk | Key Gap |\n|----------|------|------|---------|\n| 1 | `HistoryOfThought` crypto | Critical | AES-GCM round-trip, vault lock soft-drop |\n| 2 | `ExecutiveSpine` state | Critical | Focus sessions, health thresholds, credits |\n| 3 | `LiteralMode` patterns | High | 20+ regex replacements, edge cases |\n| 4 | `EventBus` pipeline | High | Silent-drop on vault lock unverified |\n| 5 | `BriefService` / `MicroStepService` | High | Regex extraction, Ollama fallback |\n| 6 | `IndexedDBService` / `SovereignReconciler` | Medium | Storage round-trips, deduplication |\n\nThe encryption layer and focus session state are the highest-risk untested paths given they underpin the academic authenticity and productivity claims of the system.\n",
