      {
        "language": "js",
        "code": "// tests/core/HistoryOfThought.test.js\nimport { unlockWithPassphrase, lockSession, appendEvent, listEvents, generateAuthenticityReport, isUnlocked } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought — vault lifecycle', () => {\n  beforeEach(() => { /* reset IndexedDB mock */ });\n\n  test('isUnlocked() returns false before unlock', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlockWithPassphrase() derives key and unlocks', async () => {\n    await unlockWithPassphrase('test-passphrase');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('lockSession() clears derived key from memory', async () => {\n    await unlockWithPassphrase('test-passphrase');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('HistoryOfThought — encryption round-trip', () => {\n  test('appendEvent then listEvents returns decrypted payload', async () => {\n    await unlockWithPassphrase('passphrase-123');\n    await appendEvent({ type: 'text_edit', content: 'Hello world' });\n    const events = await listEvents();\n    expect(events[0].type).toBe('text_edit');\n    expect(events[0].content).toBe('Hello world');\n  });\n\n  test('appendEvent silently drops when vault is locked', async () => {\n    lockSession();\n    await expect(appendEvent({ type: 'text_edit' })).resolves.toBeUndefined();\n    // No error thrown — soft-drop behaviour\n  });\n\n  test('wrong passphrase fails to decrypt events', async () => {\n    await unlockWithPassphrase('correct');\n    await appendEvent({ type: 'focus_session_start' });\n    lockSession();\n    await unlockWithPassphrase('wrong');\n    const events = await listEvents();\n    expect(events).toHaveLength(0); // or throws — document expected behaviour\n  });\n});\n\ndescribe('HistoryOfThought — authenticity report', () => {\n  test('generateAuthenticityReport returns event count and time span', async () => {\n    await unlockWithPassphrase('pass');\n    await appendEvent({ type: 'text_edit' });\n    const report = await generateAuthenticityReport();\n    expect(report.eventCount).toBeGreaterThan(0);\n    expect(report.timeSpanMs).toBeGreaterThanOrEqual(0);\n  });\n\n  test('report on empty vault returns zeroed summary', async () => {\n    await unlockWithPassphrase('pass');\n    const report = await generateAuthenticityReport();\n    expect(report.eventCount).toBe(0);\n  });\n});"
      },
      {
        "language": "js",
        "code": "// tests/core/ExecutiveSpine.test.js\nimport {\n  configureSpine, startFocusSession, endFocusSession,\n  getFocusSession, isFocusActive, getSectionHealth,\n  setSectionHealth, grantPlayTime, isPlayTimeActive,\n  getCredits, earnCredits, spendCredits\n} from '../../src/core/ExecutiveSpine';\n\ndescribe('ExecutiveSpine — focus sessions', () => {\n  beforeEach(() => { configureSpine({}); });\n\n  test('isFocusActive() is false before any session', () => {\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('startFocusSession sets active state', () => {\n    startFocusSession({ streamId: 'primary' });\n    expect(isFocusActive()).toBe(true);\n  });\n\n  test('endFocusSession clears active state and returns duration', () => {\n    startFocusSession({ streamId: 'primary' });\n    const result = endFocusSession();\n    expect(result.durationMs).toBeGreaterThanOrEqual(0);\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('getFocusSession returns null when no session active', () => {\n    expect(getFocusSession()).toBeNull();\n  });\n\n  // EDGE CASE: localStorage unavailable\n  test('startFocusSession does not throw when localStorage throws', () => {\n    jest.spyOn(Storage.prototype, 'setItem').mockImplementation(() => {\n      throw new DOMException('Storage full');\n    });\n    expect(() => startFocusSession({ streamId: 'primary' })).not.toThrow();\n  });\n});\n\ndescribe('ExecutiveSpine — section health', () => {\n  test('setSectionHealth persists and getSectionHealth returns it', () => {\n    setSectionHealth('essay', 3);\n    expect(getSectionHealth('essay')).toBe(3);\n  });\n\n  test('setSectionHealth at 5 triggers PlayTime grant', () => {\n    const spy = jest.spyOn({ grantPlayTime }, 'grantPlayTime');\n    setSectionHealth('essay', 5); // Should auto-grant PlayTime\n    // assert grantPlayTime was called or isPlayTimeActive() flips\n  });\n\n  test('health value clamps between 0 and 5', () => {\n    setSectionHealth('essay', 99);\n    expect(getSectionHealth('essay')).toBe(5);\n    setSectionHealth('essay', -1);\n    expect(getSectionHealth('essay')).toBe(0);\n  });\n});\n\ndescribe('ExecutiveSpine — credits', () => {\n  test('earnCredits increases balance', () => {\n    const before = getCredits();\n    earnCredits(10);\n    expect(getCredits()).toBe(before + 10);\n  });\n\n  test('spendCredits decreases balance', () => {\n    earnCredits(20);\n    spendCredits(5);\n    expect(getCredits()).toBeLessThan(getCredits() + 5); // confirm deduction\n  });\n\n  test('spendCredits does not go below zero', () => {\n    spendCredits(99999);\n    expect(getCredits()).toBeGreaterThanOrEqual(0);\n  });\n});"
      },
      {
        "language": "js",
        "code": "// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('shouldLiteralise()', () => {\n  test('returns true when stream is primary and literal mode enabled', () => {\n    expect(shouldLiteralise({ stream: 'primary', literalMode: true })).toBe(true);\n  });\n  test('returns false for secondary stream regardless of literalMode', () => {\n    expect(shouldLiteralise({ stream: 'secondary', literalMode: true })).toBe(false);\n  });\n});\n\ndescribe('literalise() — pattern replacements', () => {\n  test('replaces em-dashes with commas', () => {\n    expect(literalise('cats — dogs')).toBe('cats, dogs');\n  });\n  test('splits clauses on semicolons', () => {\n    const out = literalise('First point; second point');\n    expect(out).toContain('First point');\n    expect(out).toContain('Second point'); // capitalised after split\n  });\n  test('handles empty string without throwing', () => {\n    expect(() => literalise('')).not.toThrow();\n    expect(literalise('')).toBe('');\n  });\n  test('handles null/undefined gracefully', () => {\n    expect(() => literalise(null)).not.toThrow();\n  });\n  test('preserves LaTeX blocks from replacement', () => {\n    const latex = '$E = mc^2$';\n    expect(literalise(latex)).toContain('$E = mc^2$');\n  });\n  test('does not alter text that needs no transformation', () => {\n    const plain = 'The cat sat on the mat.';\n    expect(literalise(plain)).toBe(plain);\n  });\n});"
