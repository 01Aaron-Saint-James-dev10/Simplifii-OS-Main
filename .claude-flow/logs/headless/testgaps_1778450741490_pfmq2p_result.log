        "content": "\n```js\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, applyTheme } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel()', () => {\n  test.each([\n    [1, 'primary'], [2, 'primary'], [7, 'primary'],\n    [8, 'secondary'], [11, 'secondary'],\n    [12, 'tafe'], [13, 'tafe'],\n  ])('level %i maps to stream %s', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  test('invalid level falls back to tertiary/default', () => {\n    expect(streamFromLevel(999)).toBeDefined(); // should not throw\n  });\n});\n\ndescribe('isValidStream()', () => {\n  test('accepts known streams', () => {\n    ['primary', 'secondary', 'tafe', 'homeschool'].forEach(s => {\n      expect(isValidStream(s)).toBe(true);\n    });\n  });\n  test('rejects unknown stream', () => {\n    expect(isValidStream('unknown')).toBe(false);\n  });\n});\n\ndescribe('applyTheme()', () => {\n  test('sets CSS custom properties on document root', () => {\n    document.documentElement.style.setProperty = jest.fn();\n    applyTheme('primary');\n    expect(document.documentElement.style.setProperty).toHaveBeenCalled();\n  });\n  test('does not throw for unknown theme', () => {\n    expect(() => applyTheme('nonexistent')).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Priority 4: Event Pipeline (High Risk)",
        "content": "\n",
        "level": 2
      },
      {
        "title": "`EventBus.js` — Silent-drop on vault lock is unverified",
        "content": "\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../src/core/EventBus';\nimport * as HistoryOfThought from '../../src/core/HistoryOfThought';\n\njest.mock('../../src/core/HistoryOfThought');\n\ndescribe('EventBus — event routing', () => {\n  beforeEach(() => {\n    HistoryOfThought.isUnlocked.mockReturnValue(true);\n    HistoryOfThought.appendEvent.mockResolvedValue(undefined);\n    startEventBus(() => ({ streamId: 'primary', userId: 'u1' }));\n  });\n  afterEach(() => stopEventBus());\n\n  test('recordTextEdit calls appendEvent when vault unlocked', async () => {\n    await recordTextEdit({ content: 'test content' });\n    expect(HistoryOfThought.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ type: 'text_edit' })\n    );\n  });\n\n  test('recordTextEdit silently skips when vault locked', async () => {\n    HistoryOfThought.isUnlocked.mockReturnValue(false);\n    await recordTextEdit({ content: 'test' });\n    expect(HistoryOfThought.appendEvent).not.toHaveBeenCalled();\n  });\n\n  test('recordCitation includes citation fields in payload', async () => {\n    await recordCitation({ source: 'Smith 2020', page: 42 });\n    expect(HistoryOfThought.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ type: 'citation', source: 'Smith 2020' })\n    );\n  });\n\n  test('appendEvent failure does not propagate to caller', async () => {\n    HistoryOfThought.appendEvent.mockRejectedValue(new Error('IndexedDB failure'));\n    await expect(recordTextEdit({ content: 'x' })).resolves.toBeUndefined();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Priority 5: Service Layer (High Risk)",
        "content": "\n",
        "level": 2
      },
      {
        "title": "`BriefService.js` — Evidence formula regex",
        "content": "\n```js\n// tests/services/BriefService.test.js\nimport { extractEvidenceFormula, extractDynamicThemes, deriveRoadmapFromAssessments } from '../../src/services/BriefService';\n\ndescribe('extractEvidenceFormula()', () => {\n  test('detects peer-reviewed sources requirement', () => {\n    const result = extractEvidenceFormula('You must cite at least 8 peer-reviewed journal articles');\n    expect(result.peerReviewed).toBe(8);\n  });\n  test('detects minimum sources from text', () => {\n    const result = extractEvidenceFormula('Include a minimum of 5 academic sources');\n    expect(result.minSources).toBe(5);\n  });\n  test('returns safe defaults for empty brief', () => {\n    const result = extractEvidenceFormula('');\n    expect(result).toBeDefined();\n    expect(result.minSources).toBeGreaterThanOrEqual(0);\n  });\n  test('handles null without throwing', () => {\n    expect(() => extractEvidenceFormula(null)).not.toThrow();\n  });\n});\n\ndescribe('extractDynamicThemes()', () => {\n  test('extracts capitalised topic words from brief', () => {\n    const themes = extractDynamicThemes('Discuss Photosynthesis and Cellular Respiration in detail');\n    expect(themes).toContain('Photosynthesis');\n    expect(themes).toContain('Cellular Respiration');\n  });\n  test('returns empty array for all-lowercase text', () => {\n    expect(extractDynamicThemes('no capitals here')).toEqual([]);\n  });\n});\n\ndescribe('deriveRoadmapFromAssessments()', () => {\n  test('returns ordered milestones from assessments', () => {\n    const assessments = [\n      { title: 'Essay', dueDate: '2026-06-01', weight: 40 },\n      { title: 'Quiz', dueDate: '2026-05-15', weight: 10 },\n    ];\n    const roadmap = deriveRoadmapFromAssessments(assessments);\n    expect(roadmap[0].title).toBe('Quiz'); // earlier due date first\n  });\n  test('handles empty assessments array', () => {\n    expect(deriveRoadmapFromAssessments([])).toEqual([]);\n  });\n});\n```\n\n",
        "level": 3
      },
      {
        "title": "`MicroStepService.js` — Step count and Ollama fallback",
        "content": "\n```js\n// tests/services/MicroStepService.test.js\nimport { generateMicroSteps } from '../../src/services/MicroStepService';\n\nglobal.fetch = jest.fn();\n\ndescribe('generateMicroSteps()', () => {\n  afterEach(() => jest.clearAllMocks());\n\n  test('returns 5 steps for heavy scaffolding', async () => {\n    fetch.mockResolvedValue({\n      ok: true,\n      json: async () => ({\n        message: { content: JSON.stringify({ steps: Array(5).fill({ action: 'Do x', why: 'y' }) }) }\n      })\n    });\n    const steps = await generateMicroSteps({ scaffolding: 'heavy', task: 'Write intro' });\n    expect(steps).toHaveLength(5);\n  });\n\n  test('returns 3 steps for light scaffolding', async () => {\n    fetch.mockResolvedValue({\n      ok: true,\n      json: async () => ({\n        message: { content: JSON.stringify({ steps: Array(3).fill({ action: 'Do x', why: 'y' }) }) }\n      })\n    });\n    const steps = await generateMicroSteps({ scaffolding: 'light', task: 'Write intro' });\n    expect(steps).toHaveLength(3);\n  });\n\n  test('returns fallback steps when Ollama is unreachable', async () => {\n    fetch.mockRejectedValue(new Error('Network error'));\n    const steps = await generateMicroSteps({ scaffolding: 'heavy', task: 'Write intro' });\n    expect(steps.length).toBeGreaterThan(0); // fallback, not empty\n  });\n\n  test('filters out steps shorter than 3 chars', async () => {\n    fetch.mockResolvedValue({\n      ok: true,\n      json: async () => ({\n        message: { content: JSON.stringify({ steps: [{ action: 'x', why: 'y' }, { action: 'Write a proper introduction', why: 'anchors your argument' }] }) }\n      })\n    });\n    const steps = await generateMicroSteps({ scaffolding: 'balanced', task: 'intro' });\n    expect(steps.every(s => s.action.length >= 3)).toBe(true);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
