        "code": "// tests/services/IndexedDBService.test.js\nimport 'fake-indexeddb/auto'; // npm install --save-dev fake-indexeddb\nimport { initDB, saveBlockSnapshot, getBlockHistory, saveGhostAsset, getAllGhostAssets } from '../../src/services/IndexedDBService';\n\ndescribe('IndexedDBService', () => {\n  beforeAll(() => initDB());\n\n  test('saveBlockSnapshot then getBlockHistory returns saved blocks', async () => {\n    await saveBlockSnapshot({ blockId: 'b1', content: 'paragraph one', timestamp: Date.now() });\n    const history = await getBlockHistory('b1');\n    expect(history.length).toBeGreaterThan(0);\n    expect(history[0].content).toBe('paragraph one');\n  });\n\n  test('getBlockHistory returns empty array for unknown blockId', async () => {\n    const history = await getBlockHistory('nonexistent');\n    expect(history).toEqual([]);\n  });\n\n  test('saveGhostAsset and getAllGhostAssets round-trip', async () => {\n    await saveGhostAsset({ id: 'a1', name: 'lecture.pdf', url: 'blob://...' });\n    const assets = await getAllGhostAssets();\n    expect(assets.find(a => a.id === 'a1')).toBeDefined();\n  });\n\n  test('initDB is idempotent (no error on second call)', async () => {\n    await expect(initDB()).resolves.not.toThrow();\n  });\n});"
