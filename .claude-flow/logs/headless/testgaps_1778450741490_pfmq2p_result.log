        "code": "// tests/services/SovereignReconciler.test.js\nimport { reconcile } from '../../src/services/SovereignReconciler';\n\ndescribe('reconcile()', () => {\n  test('deduplicates assessments with identical titles', () => {\n    const input = [\n      { title: 'Essay 1', weight: 40 },\n      { title: 'Essay 1', weight: 40 }, // duplicate\n    ];\n    const result = reconcile(input);\n    expect(result).toHaveLength(1);\n  });\n\n  test('normalises title casing before comparing', () => {\n    const input = [\n      { title: 'ESSAY 1', weight: 40 },\n      { title: 'essay 1', weight: 40 },\n    ];\n    const result = reconcile(input);\n    expect(result).toHaveLength(1);\n  });\n\n  test('preserves distinct assessments', () => {\n    const input = [\n      { title: 'Essay', weight: 40 },\n      { title: 'Quiz', weight: 10 },\n    ];\n    expect(reconcile(input)).toHaveLength(2);\n  });\n\n  test('handles empty input', () => {\n    expect(reconcile([])).toEqual([]);\n  });\n});"
