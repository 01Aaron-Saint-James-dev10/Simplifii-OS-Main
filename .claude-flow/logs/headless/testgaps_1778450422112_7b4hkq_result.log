  "output": "## Test Coverage Analysis: Simplifii-OS_Master\n\n**Summary: Zero test coverage across the entire codebase.** No test files, no test framework configured, no CI test pipeline.\n\n---\n\n## Critical Gaps by Priority\n\n### 1. Core Security Module — `HistoryOfThought.js`\n\nHighest risk: handles AES-GCM-256 encryption, PBKDF2 key derivation, and IndexedDB persistence. A bug here is silent data loss or silent decryption failure.\n\n**Untested:**\n- Passphrase derivation with correct/wrong key\n- Encryption round-trip (encrypt → decrypt → verify)\n- IndexedDB transaction failures\n- `generateAuthenticityReport()` output shape\n- `enableCloudSync()` opt-in gate\n\n**Test skeleton:**\n\n```js\n// tests/core/HistoryOfThought.test.js\nimport { unlockWithPassphrase, appendEvent, listEvents, generateAuthenticityReport } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought', () => {\n  beforeEach(() => indexedDB.deleteDatabase('sovereign-vault'));\n\n  describe('unlockWithPassphrase', () => {\n    it('derives a key and marks vault as unlocked', async () => {\n      await expect(unlockWithPassphrase('correct-horse')).resolves.toBe(true);\n    });\n\n    it('returns false for empty passphrase', async () => {\n      await expect(unlockWithPassphrase('')).resolves.toBe(false);\n    });\n  });\n\n  describe('appendEvent / listEvents round-trip', () => {\n    it('encrypts and decrypts an event transparently', async () => {\n      await unlockWithPassphrase('test-pass');\n      await appendEvent({ type: 'text_edit', content: 'hello' });\n      const events = await listEvents();\n      expect(events[0].content).toBe('hello');\n    });\n\n    it('soft-drops (no throw) when vault is locked', async () => {\n      // vault not unlocked\n      await expect(appendEvent({ type: 'text_edit' })).resolves.not.toThrow();\n    });\n  });\n\n  describe('generateAuthenticityReport', () => {\n    it('returns report with session count and word delta', async () => {\n      await unlockWithPassphrase('test-pass');\n      const report = await generateAuthenticityReport();\n      expect(report).toHaveProperty('sessionCount');\n      expect(report).toHaveProperty('wordDelta');\n    });\n  });\n});\n```\n\n---\n\n### 2. State Engine — `ExecutiveSpine.js`\n\n**Untested:**\n- Focus session timer start/end/persist\n- Credits: earn, spend, overdraft rejection\n- PlayTime gate logic\n- Idle detection threshold firing\n- `configureSpine()` per-stream tunables\n\n**Test skeleton:**\n\n```js\n// tests/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, isFocusActive,\n  earnCredits, spendCredits, getCredits,\n  grantPlayTime, isPlayTimeActive,\n} from '../../src/core/ExecutiveSpine';\n\ndescribe('ExecutiveSpine', () => {\n  beforeEach(() => localStorage.clear());\n\n  describe('FocusSession', () => {\n    it('marks session active after start', () => {\n      startFocusSession({ streamId: 'tertiary' });\n      expect(isFocusActive()).toBe(true);\n    });\n\n    it('is inactive before first session', () => {\n      expect(isFocusActive()).toBe(false);\n    });\n\n    it('persists session across JS reload (localStorage)', () => {\n      startFocusSession({ streamId: 'tertiary' });\n      // simulate reload by re-importing (or checking raw localStorage)\n      expect(localStorage.getItem('sovereignFocusSession')).not.toBeNull();\n    });\n  });\n\n  describe('SovereignCredits', () => {\n    it('starts at 0', () => expect(getCredits()).toBe(0));\n\n    it('increments on earnCredits', () => {\n      earnCredits(10);\n      expect(getCredits()).toBe(10);\n    });\n\n    it('decrements on spendCredits', () => {\n      earnCredits(20);\n      spendCredits(5);\n      expect(getCredits()).toBe(15);\n    });\n\n    it('rejects spend when balance insufficient', () => {\n      earnCredits(3);\n      expect(() => spendCredits(10)).toThrow();\n    });\n  });\n\n  describe('PlayTime', () => {\n    it('is inactive without explicit grant', () => {\n      expect(isPlayTimeActive()).toBe(false);\n    });\n\n    it('activates after grant', () => {\n      grantPlayTime({ durationMs: 300_000 });\n      expect(isPlayTimeActive()).toBe(true);\n    });\n  });\n});\n```\n\n---\n\n### 3. Event Pipeline — `EventBus.js`\n\n**Untested:**\n- CustomEvent listener wiring on `startEventBus()`\n- Listener removal on `stopEventBus()` (memory leak risk)\n- `recordTextEdit()` dispatches correct payload\n- Events reach `HistoryOfThought.appendEvent` when vault unlocked\n\n**Test skeleton:**\n\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit } from '../../src/core/EventBus';\nimport * as HOT from '../../src/core/HistoryOfThought';\n\njest.mock('../../src/core/HistoryOfThought');\n\ndescribe('EventBus', () => {\n  afterEach(() => stopEventBus());\n\n  it('forwards text_edit events to HistoryOfThought', () => {\n    startEventBus();\n    recordTextEdit({ sectionId: 'intro', wordCount: 42 });\n    expect(HOT.appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ type: 'text_edit', sectionId: 'intro' })\n    );\n  });\n\n  it('does not throw when vault is locked (soft-drop)', () => {\n    HOT.appendEvent.mockRejectedValueOnce(new Error('locked'));\n    startEventBus();\n    expect(() => recordTextEdit({ sectionId: 'intro' })).not.toThrow();\n  });\n\n  it('removes listeners on stopEventBus (no double-fire)', () => {\n    startEventBus();\n    stopEventBus();\n    recordTextEdit({ sectionId: 'x' });\n    expect(HOT.appendEvent).not.toHaveBeenCalled();\n  });\n});\n```\n\n---\n\n### 4. Routing Logic — `SovereignRouter.js`\n\n**Untested:**\n- All 5 stream codes (primary/secondary/tertiary/tafe/homeschool)\n- Invalid level input rejection\n- Theme application side effects\n- `hydrate()` with missing profile fields\n\n**Test skeleton:**\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate } from '../../src/core/SovereignRouter';\n\ndescribe('SovereignRouter', () => {\n  describe('streamFromLevel', () => {\n    it.each([\n      ['primary', 'primary'],\n      ['secondary', 'secondary'],\n      ['tertiary', 'tertiary'],\n      ['tafe', 'tafe'],\n      ['homeschool', 'homeschool'],\n    ])('maps \"%s\" to stream \"%s\"', (input, expected) => {\n      expect(streamFromLevel(input)).toBe(expected);\n    });\n\n    it('throws on unknown level', () => {\n      expect(() => streamFromLevel('university')).toThrow();\n    });\n\n    it('is case-insensitive', () => {\n      expect(streamFromLevel('TERTIARY')).toBe('tertiary');\n    });\n  });\n\n  describe('isValidStream', () => {\n    it('returns true for known streams', () => {\n      expect(isValidStream('tertiary')).toBe(true);\n    });\n\n    it('returns false for unknown stream', () => {\n      expect(isValidStream('phd')).toBe(false);\n    });\n  });\n\n  describe('hydrate', () => {\n    it('returns profile with defaults for missing fields', () => {\n      const profile = hydrate({});\n      expect(profile).toHaveProperty('stream');\n      expect(profile).toHaveProperty('theme');\n    });\n  });\n});\n```\n\n---\n\n### 5. Text Transform — `LiteralMode.js`\n\n**Untested:**\n- Pattern replacement (academic → plain English)\n- Empty/whitespace input\n- Capitalization normalization\n- `shouldLiteralise()` dial-reading logic\n\n**Test skeleton:**\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('LiteralMode', () => {\n  describe('literalise', () => {\n    it('converts academic prose to plain imperative', () => {\n      const input = 'It is imperative that the student demonstrates understanding.';\n      expect(literalise(input)).toMatch(/^Show/i);\n    });\n\n    it('returns empty string for empty input', () => {\n      expect(literalise('')).toBe('');\n    });\n\n    it('does not invent content beyond schema-anchored transforms', () => {\n      const input = 'Analyse the data.';\n      const out = literalise(input);\n      expect(out.length).toBeGreaterThan(0);\n      expect(out).not.toContain('[GENERATED]');\n    });\n  });\n\n  describe('shouldLiteralise', () => {\n    it('returns true when Persona dial is \"Literal\"', () => {\n      expect(shouldLiteralise({ persona: 'Literal' })).toBe(true);\n    });\n\n    it('returns false when Persona dial is \"Academic\"', () => {\n      expect(shouldLiteralise({ persona: 'Academic' })).toBe(false);\n    });\n  });\n});\n```\n\n---\n\n### 6. Service Layer — `IndexedDBService.js`\n\n**Untested:**\n- `initDB()` creates correct object stores\n- `saveBlockSnapshot()` → `getBlockHistory()` round-trip\n- `saveGhostAsset()` → `getAllGhostAssets()` round-trip\n- Failure when IndexedDB quota exceeded\n\n**Test skeleton:**\n\n```js\n// tests/services/IndexedDBService.test.js\nimport { initDB, saveBlockSnapshot, getBlockHistory, saveGhostAsset, getAllGhostAssets }\n  from '../../src/services/IndexedDBService';\n\ndescribe('IndexedDBService', () => {\n  beforeEach(async () => {\n    indexedDB.deleteDatabase('sovereign-db');\n    await initDB();\n  });\n\n  it('saves and retrieves block snapshots', async () => {\n    await saveBlockSnapshot({ blockId: 'intro', html: '<p>test</p>', ts: Date.now() });\n    const history = await getBlockHistory('intro');\n    expect(history[0].html).toBe('<p>test</p>');\n  });\n\n  it('returns empty array for unknown blockId', async () => {\n    const history = await getBlockHistory('nonexistent');\n    expect(history).toEqual([]);\n  });\n\n  it('saves and retrieves ghost assets', async () => {\n    await saveGhostAsset({ id: 'g1', url: 'blob://x', type: 'image/png' });\n    const assets = await getAllGhostAssets();\n    expect(assets.some(a => a.id === 'g1')).toBe(true);\n  });\n});\n```\n\n---\n\n### 7. Integration Gap — EventBus → HistoryOfThought Pipeline\n\nNo integration test verifies that a real user editing action (text_edit CustomEvent) actually lands as an encrypted entry in IndexedDB.\n\n**Test skeleton:**\n\n```js\n// tests/integration/edit-to-vault.test.js\nimport { startEventBus, stopEventBus } from '../../src/core/EventBus';\nimport { unlockWithPassphrase, listEvents } from '../../src/core/HistoryOfThought';\nimport { initDB } from '../../src/services/IndexedDBService';\n\ndescribe('Integration: text_edit → encrypted vault', () => {\n  beforeEach(async () => {\n    indexedDB.deleteDatabase('sovereign-vault');\n    await initDB();\n    await unlockWithPassphrase('integration-test');\n    startEventBus();\n  });\n\n  afterEach(() => stopEventBus());\n\n  it('user edit event appears as encrypted vault entry', async () => {\n    document.dispatchEvent(new CustomEvent('sovereign:text_edit', {\n      detail: { sectionId: 'conclusion', wordCount: 100 }\n    }));\n\n    await new Promise(r => setTimeout(r, 50)); // let async pipeline settle\n\n    const events = await listEvents();\n    expect(events.some(e => e.sectionId === 'conclusion')).toBe(true);\n  });\n});\n```\n\n---\n\n## Missing Infrastructure (Must Add First)\n\n```json\n// package.json additions needed\n{\n  \"scripts\": {\n    \"test\": \"jest --coverage\",\n    \"test:watch\": \"jest --watch\"\n  },\n  \"devDependencies\": {\n    \"jest\": \"^29\",\n    \"jest-environment-jsdom\": \"^29\",\n    \"@testing-library/react\": \"^14\",\n    \"@testing-library/jest-dom\": \"^6\",\n    \"fake-indexeddb\": \"^5\"\n  },\n  \"jest\": {\n    \"testEnvironment\": \"jsdom\",\n    \"setupFilesAfterFramework\": [\"<rootDir>/tests/setup.js\"],\n    \"globals\": { \"fake-indexeddb\": true }\n  }\n}\n```\n\n---\n\n## Priority Order\n\n| Priority | Module | Reason |\n|---|---|---|\n| 1 | `HistoryOfThought` | Encryption bugs = silent data loss |\n| 2 | `ExecutiveSpine` | Credit/timer state corruption risks |\n| 3 | `EventBus` | Memory leaks from unremoved listeners |\n| 4 | `SovereignRouter` | Wrong stream routing breaks entire session |\n| 5 | `IndexedDBService` | Data persistence core |\n| 6 | `LiteralMode` | Lower risk, pure function |\n| 7 | Integration pipeline | Validates system-level assumptions |\n\nThe biggest immediate win is installing Jest + `fake-indexeddb`, then writing `HistoryOfThought.test.js` — that module has the highest consequence-per-untested-line ratio in the codebase.\n",
