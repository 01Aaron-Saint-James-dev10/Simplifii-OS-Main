  "output": "Now I have a thorough picture. Let me provide the full analysis.\n\n---\n\n## Test Coverage Analysis: Simplifii OS Master\n\n**Critical finding: Zero test files exist.** No testing framework is installed in `package.json`. All test skeletons below assume Jest (the natural fit for CRA projects), added via `npm install --save-dev jest @testing-library/react @testing-library/jest-dom`.\n\n---\n\n## Gap Analysis by Module\n\n### 1. `src/core/LiteralMode.js` -- **Highest priority, pure functions, zero browser deps**\n\n**Untested functions:** `literalise`, `shouldLiteralise`, `sanitiseDashes` (internal)\n\n**Missing cases:**\n- Non-string / falsy input passthrough (`null`, `undefined`, `0`, `\"\"`)\n- Em-dash and en-dash replacement by `sanitiseDashes`\n- Each pattern row in isolation (e.g. `consider revising`, `furthermore`, `should be revised`)\n- Passive construction transforms (`are required to` -> `must`)\n- `splitClauses: false` disables semicolon and conjunction splitting\n- `dropEmpty: false` keeps double spaces\n- Sentence-start capitalisation after deletions (e.g. `going forward do X` -> `Do X`)\n- `shouldLiteralise` with explicit `userPreference: true/false` overrides stream default\n- `shouldLiteralise` with `userPreference: null` falls through to `streamProfile.literalModeDefault`\n\n**Test skeleton:**\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../../src/core/LiteralMode';\n\ndescribe('sanitiseDashes', () => {\n  const { sanitiseDashes } = __internals;\n\n  test('replaces em-dash with comma', () => {\n    expect(sanitiseDashes('word\\u2014word')).toBe('word,word');\n  });\n\n  test('replaces en-dash with comma', () => {\n    expect(sanitiseDashes('word\\u2013word')).toBe('word,word');\n  });\n\n  test('leaves plain hyphens unchanged', () => {\n    expect(sanitiseDashes('word-word')).toBe('word-word');\n  });\n\n  test('returns empty string for null/undefined', () => {\n    expect(sanitiseDashes(null)).toBe('');\n    expect(sanitiseDashes(undefined)).toBe('');\n  });\n});\n\ndescribe('literalise - input guards', () => {\n  test('returns null unchanged', () => expect(literalise(null)).toBeNull());\n  test('returns undefined unchanged', () => expect(literalise(undefined)).toBeUndefined());\n  test('returns empty string unchanged', () => expect(literalise('')).toBe(''));\n  test('returns number unchanged', () => expect(literalise(42)).toBe(42));\n});\n\ndescribe('literalise - pattern transforms', () => {\n  test('consider revising -> change', () => {\n    expect(literalise('You should consider revising this section.')).toContain('change');\n  });\n\n  test('furthermore -> also', () => {\n    expect(literalise('Furthermore, this is important.')).toContain('Also');\n  });\n\n  test('synthesise -> combine ideas from', () => {\n    expect(literalise('Synthesise the findings.')).toContain('combine ideas from');\n  });\n\n  test('should be revised -> rewrite this', () => {\n    expect(literalise('The argument should be revised.')).toContain('rewrite this');\n  });\n\n  test('are required to -> must', () => {\n    expect(literalise('Students are required to submit by Friday.')).toContain('must');\n  });\n\n  test('going forward is deleted (empty drop)', () => {\n    const result = literalise('Going forward do the work.');\n    expect(result).not.toContain('going forward');\n    expect(result).not.toContain('Going forward');\n  });\n});\n\ndescribe('literalise - clause splitting', () => {\n  test('semicolons become full stops', () => {\n    const result = literalise('Do this; then do that.');\n    expect(result).toContain('. ');\n    expect(result).not.toContain(';');\n  });\n\n  test('splitClauses: false leaves semicolons intact', () => {\n    const result = literalise('Do this; then do that.', { splitClauses: false });\n    expect(result).toContain(';');\n  });\n\n  test(', and connector becomes full stop', () => {\n    const result = literalise('Submit the draft, and ensure formatting is correct.');\n    expect(result).toMatch(/\\.\\s/);\n  });\n});\n\ndescribe('literalise - capitalisation after deletion', () => {\n  test('first word is capitalised after going-forward deletion', () => {\n    const result = literalise('going forward ensure quality.');\n    expect(result[0]).toBe(result[0].toUpperCase());\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('explicit true overrides stream default', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true);\n  });\n\n  test('explicit false overrides stream default', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false);\n  });\n\n  test('null preference defers to stream default true', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n  });\n\n  test('null preference defers to stream default false', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n\n  test('undefined stream returns false', () => {\n    expect(shouldLiteralise(undefined, null)).toBe(false);\n  });\n});\n```\n\n---\n\n### 2. `src/core/SovereignRouter.js` -- **High priority, pure logic with JSON imports**\n\n**Untested functions:** `streamFromLevel`, `isValidStream`, `hydrate`, `applyTheme`\n\n**Missing cases:**\n- `streamFromLevel` with every mapped key (primary, secondary, highschool, tafe, homeschool, university, undergrad, honours, mres, phd)\n- `streamFromLevel` with unknown level falls back to `tertiary`\n- `streamFromLevel` with empty string, `null`, `undefined`\n- `isValidStream` with valid and invalid ids\n- `hydrate` with explicit valid `streamId`\n- `hydrate` with invalid `streamId` falls back via `streamFromLevel`\n- `hydrate` with empty session defaults to tertiary\n- `hydrate` returns `getVocab`, `canAccess`, `getDefaultLanding` as callable helpers\n- `applyTheme` is a no-op when `document` is undefined (SSR guard)\n- `applyTheme` only sets CSS properties starting with `--`\n\n**Test skeleton:**\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, applyTheme, __internals } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  const cases = [\n    ['primary',    'primary'],\n    ['secondary',  'secondary'],\n    ['highschool', 'secondary'],\n    ['tafe',       'tafe'],\n    ['homeschool', 'homeschool'],\n    ['university', 'tertiary'],\n    ['undergrad',  'tertiary'],\n    ['honours',    'tertiary'],\n    ['mres',       'tertiary'],\n    ['phd',        'tertiary'],\n  ];\n\n  test.each(cases)('level \"%s\" maps to \"%s\"', (input, expected) => {\n    expect(streamFromLevel(input)).toBe(expected);\n  });\n\n  test('unknown level falls back to tertiary', () => {\n    expect(streamFromLevel('moonschool')).toBe('tertiary');\n  });\n\n  test('empty string falls back to tertiary', () => {\n    expect(streamFromLevel('')).toBe('tertiary');\n  });\n\n  test('null falls back to tertiary', () => {\n    expect(streamFromLevel(null)).toBe('tertiary');\n  });\n\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('PRIMARY')).toBe('primary');\n    expect(streamFromLevel('  Tafe  ')).toBe('tafe');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test.each(['primary', 'secondary', 'tertiary', 'tafe', 'homeschool'])('%s is valid', (id) => {\n    expect(isValidStream(id)).toBe(true);\n  });\n\n  test('invalid id returns false', () => {\n    expect(isValidStream('moonstream')).toBe(false);\n    expect(isValidStream('')).toBe(false);\n    expect(isValidStream(null)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('explicit valid streamId is honoured', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.streamId).toBe('primary');\n  });\n\n  test('invalid streamId falls back via level', () => {\n    const result = hydrate({ streamId: 'invalid', profile: { level: 'tafe' } });\n    expect(result.streamId).toBe('tafe');\n  });\n\n  test('empty session defaults to tertiary', () => {\n    const result = hydrate({});\n    expect(result.streamId).toBe('tertiary');\n  });\n\n  test('returns getVocab helper', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.getVocab).toBe('function');\n  });\n\n  test('returns canAccess helper', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    expect(typeof result.canAccess).toBe('function');\n  });\n\n  test('canAccess returns false for unknown module', () => {\n    const result = hydrate({ streamId: 'primary' });\n    expect(result.canAccess('__nonexistent_module__')).toBe(false);\n  });\n\n  test('getDefaultLanding falls back to \"studio\"', () => {\n    const result = hydrate({ streamId: 'tertiary' });\n    // Either a real value or the hardcoded fallback\n    expect(typeof result.getDefaultLanding()).toBe('string');\n  });\n});\n\ndescribe('applyTheme', () => {\n  test('is a no-op when stream is null', () => {\n    expect(() => applyTheme(null)).not.toThrow();\n  });\n\n  test('is a no-op when theme is missing', () => {\n    expect(() => applyTheme({ theme: null })).not.toThrow();\n  });\n\n  test('sets CSS custom properties on document root', () => {\n    const stream = { theme: { '--bg': '#fff', '--fg': '#000' } };\n    applyTheme(stream);\n    expect(document.documentElement.style.getPropertyValue('--bg')).toBe('#fff');\n    expect(document.documentElement.style.getPropertyValue('--fg')).toBe('#000');\n  });\n\n  test('skips properties that do not start with --', () => {\n    const stream = { theme: { color: 'red', '--accent': 'blue' } };\n    applyTheme(stream);\n    // 'color' must not be set via setProperty (no side effect check needed;\n    // the guard is the implementation under test)\n    expect(document.documentElement.style.getPropertyValue('--accent')).toBe('blue');\n  });\n});\n```\n\n---\n\n### 3. `src/core/EventBus.js` -- **Medium priority, DOM-dependent**\n\n**Untested functions:** `startEventBus`, `stopEventBus`, `recordTextEdit`, `recordCitation`, `pickSafePayload` (internal)\n\n**Missing cases:**\n- `startEventBus` is a no-op in non-browser environments\n- `startEventBus` registers exactly N listeners (one per `SPINE_TO_HOT` entry)\n- Calling `startEventBus` twice clears prior listeners (re-entrant safety)\n- `stopEventBus` removes all listeners and resets state\n- `pickSafePayload` returns correct shape for each event type\n- `safeAppend` silently drops events when vault is locked\n- `safeAppend` silently drops events with invalid `EVENT_TYPES`\n- `recordTextEdit` is a no-op when vault locked\n- `recordCitation` truncates `source` to 120 chars and `sourceId` to 60 chars\n\n**Test skeleton:**\n\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation, __internals } from '../../src/core/EventBus';\n\n// Mock HistoryOfThought so we control vault state\njest.mock('../../src/core/HistoryOfThought', () => ({\n  isUnlocked: jest.fn(() => false),\n  appendEvent: jest.fn(() => Promise.resolve()),\n  EVENT_TYPES: ['focus_session_start','focus_session_end','nudge_triggered','section_health_change',\n    'playtime_granted','playtime_expired','ai_assist_invoked','text_edit','citation_added','citation_removed']\n}));\n\nimport { isUnlocked, appendEvent } from '../../src/core/HistoryOfThought';\n\ndescribe('startEventBus / stopEventBus', () => {\n  afterEach(() => stopEventBus());\n\n  test('registers one listener per SPINE_TO_HOT entry', () => {\n    const addSpy = jest.spyOn(window, 'addEventListener');\n    startEventBus();\n    const spineCount = Object.keys(__internals.SPINE_TO_HOT).length;\n    expect(addSpy).toHaveBeenCalledTimes(spineCount);\n    addSpy.mockRestore();\n  });\n\n  test('calling start twice replaces listeners (re-entrant)', () => {\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    startEventBus();\n    startEventBus(); // second call should stop first\n    expect(removeSpy).toHaveBeenCalled();\n    removeSpy.mockRestore();\n  });\n\n  test('stopEventBus removes all listeners', () => {\n    startEventBus();\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    stopEventBus();\n    const spineCount = Object.keys(__internals.SPINE_TO_HOT).length;\n    expect(removeSpy).toHaveBeenCalledTimes(spineCount);\n    removeSpy.mockRestore();\n  });\n});\n\ndescribe('event routing when vault is locked', () => {\n  beforeEach(() => { isUnlocked.mockReturnValue(false); appendEvent.mockClear(); });\n  afterEach(() => stopEventBus());\n\n  test('spine events are silently dropped when vault locked', () => {\n    startEventBus();\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 't1', plannedDurationMs: 1500000 } }));\n    expect(appendEvent).not.toHaveBeenCalled();\n  });\n});\n\ndescribe('event routing when vault is unlocked', () => {\n  beforeEach(() => { isUnlocked.mockReturnValue(true); appendEvent.mockClear(); });\n  afterEach(() => stopEventBus());\n\n  test('simplifii:focus-start calls appendEvent with focus_session_start', async () => {\n    startEventBus();\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 't1', plannedDurationMs: 1500000 } }));\n    await Promise.resolve(); // flush microtasks\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'focus_session_start' }));\n  });\n});\n\ndescribe('recordTextEdit', () => {\n  beforeEach(() => appendEvent.mockClear());\n\n  test('no-op when vault locked', async () => {\n    isUnlocked.mockReturnValue(false);\n    await recordTextEdit({ sectionId: 's1', wordsAfter: 100 });\n    expect(appendEvent).not.toHaveBeenCalled();\n  });\n\n  test('appends text_edit event when unlocked', async () => {\n    isUnlocked.mockReturnValue(true);\n    await recordTextEdit({ sectionId: 's1', wordsAfter: 100, debounceWindowMs: 500 });\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'text_edit' }));\n  });\n\n  test('coerces missing wordsAfter to 0', async () => {\n    isUnlocked.mockReturnValue(true);\n    await recordTextEdit({ sectionId: 's1' });\n    expect(appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ payload: expect.objectContaining({ wordsAfter: 0 }) })\n    );\n  });\n});\n\ndescribe('recordCitation', () => {\n  beforeEach(() => { isUnlocked.mockReturnValue(true); appendEvent.mockClear(); });\n\n  test('added=true uses citation_added type', async () => {\n    await recordCitation({ added: true, source: 'Smith 2023', sourceId: 'abc' });\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'citation_added' }));\n  });\n\n  test('added=false uses citation_removed type', async () => {\n    await recordCitation({ added: false, source: 'Smith 2023', sourceId: 'abc' });\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'citation_removed' }));\n  });\n\n  test('source is truncated to 120 chars', async () => {\n    const longSource = 'x'.repeat(200);\n    await recordCitation({ added: true, source: longSource, sourceId: 'id' });\n    const call = appendEvent.mock.calls[0][0];\n    expect(call.payload.source.length).toBeLessThanOrEqual(120);\n  });\n\n  test('sourceId is truncated to 60 chars', async () => {\n    const longId = 'y'.repeat(100);\n    await recordCitation({ added: true, source: 'src', sourceId: longId });\n    const call = appendEvent.mock.calls[0][0];\n    expect(call.payload.sourceId.length).toBeLessThanOrEqual(60);\n  });\n});\n```\n\n---\n\n### 4. `src/services/TemporalFilter.js` -- **Low complexity, easy wins**\n\n**Untested functions:** `buildWeeklySchedule`, `checkTemporalAlignment`, `analyzeFileMetadata`\n\n**Missing cases:**\n- `buildWeeklySchedule` always returns an empty array (stub contract)\n- `checkTemporalAlignment` with empty schedule returns `{ aligned: false, event: null }`\n- `checkTemporalAlignment` with event within 24 hours returns `{ aligned: true, event }`\n- `checkTemporalAlignment` with event exactly 24 hours away (boundary)\n- `checkTemporalAlignment` with event 24h + 1ms away (boundary)\n- `analyzeFileMetadata` falls back to `Date.now()` when `lastModified` is absent\n\n**Test skeleton:**\n\n```js\n// tests/services/TemporalFilter.test.js\nimport { buildWeeklySchedule, checkTemporalAlignment, analyzeFileMetadata } from '../../src/services/TemporalFilter';\n\nconst ONE_DAY = 86400000;\n\ndescribe('buildWeeklySchedule', () => {\n  test('always returns an empty array', () => {\n    expect(buildWeeklySchedule('any text')).toEqual([]);\n    expect(buildWeeklySchedule('')).toEqual([]);\n    expect(buildWeeklySchedule(null)).toEqual([]);\n  });\n});\n\ndescribe('checkTemporalAlignment', () => {\n  test('empty schedule returns not aligned', () => {\n    expect(checkTemporalAlignment(Date.now(), [])).toEqual({ aligned: false, event: null });\n  });\n\n  test('event within 24h returns aligned + event', () => {\n    const now = Date.now();\n    const schedule = [{ timestamp: now - 1000, label: 'Lecture' }];\n    const result = checkTemporalAlignment(now, schedule);\n    expect(result.aligned).toBe(true);\n    expect(result.event).toBe(schedule[0]);\n  });\n\n  test('event exactly 24h away is aligned (boundary inclusive)', () => {\n    const now = Date.now();\n    const schedule = [{ timestamp: now - ONE_DAY, label: 'Lab' }];\n    const result = checkTemporalAlignment(now, schedule);\n    expect(result.aligned).toBe(true);\n  });\n\n  test('event 24h + 1ms away is NOT aligned', () => {\n    const now = Date.now();\n    const schedule = [{ timestamp: now - ONE_DAY - 1, label: 'Lab' }];\n    const result = checkTemporalAlignment(now, schedule);\n    expect(result.aligned).toBe(false);\n  });\n\n  test('returns first matching event when multiple exist', () => {\n    const now = Date.now();\n    const schedule = [\n      { timestamp: now - 500, label: 'First' },\n      { timestamp: now - 1000, label: 'Second' }\n    ];\n    expect(checkTemporalAlignment(now, schedule).event.label).toBe('First');\n  });\n});\n\ndescribe('analyzeFileMetadata', () => {\n  test('uses file.lastModified for timestamp', () => {\n    const now = Date.now();\n    const file = { lastModified: now };\n    // empty schedule -> always not aligned; just assert it doesn't throw\n    const result = analyzeFileMetadata(file);\n    expect(result).toHaveProperty('aligned');\n  });\n\n  test('falls back gracefully when lastModified is missing', () => {\n    expect(() => analyzeFileMetadata({})).not.toThrow();\n  });\n});\n```\n\n---\n\n### 5. `src/services/BriefService.js` -- **Highest complexity, most critical business logic**\n\n**Untested functions:** `mapToWorkspace`, `extractDynamicThemes`, `extractEvidenceFormula`, `detectAcademicTier`, `extractDeepCourseData`, `mergeExtractionData`, `deriveRoadmapFromAssessments`\n\n**Key gaps:**\n- `mapToWorkspace` returns correct section count per level (Tertiary=7, Undergrad=3, Honours=3, PhD=2, unknown=[])\n- `extractDynamicThemes` excludes stop words, caps at 3 themes, returns fallback for all-noise text\n- `extractEvidenceFormula` with non-tertiary level returns single generic source\n- `extractEvidenceFormula` parses digit counts (\"2 primary articles\")\n- `extractEvidenceFormula` parses word counts (\"three review articles\")\n- `extractEvidenceFormula` falls back to 1 generic source when no match\n- `detectAcademicTier` returns `Lab` for methodology/experiment text\n- `detectAcademicTier` returns `Research` for literature-review text\n- `detectAcademicTier` returns `Practical` for portfolio/clinical text\n- `detectAcademicTier` returns `General` as default\n- `mergeExtractionData` with `prev=null` returns `next`; with `next=null` returns `prev`\n- `mergeExtractionData` deduplicates assessment titles\n- `mergeExtractionData` takes max word count\n- `deriveRoadmapFromAssessments` with empty/null array returns null\n- `deriveRoadmapFromAssessments` with 1 title sets `currentTask` and nulls `nextAssessment`/`finalMilestone`\n- `deriveRoadmapFromAssessments` preferentially picks `Final Exam` for `finalMilestone`\n- `deriveRoadmapFromAssessments` caps noisy extraction at 5 milestones when >10 titles\n- `deriveRoadmapFromAssessments` attaches Pareto steps for literature-review tasks\n\n**Test skeleton:**\n\n```js\n// tests/services/BriefService.test.js\nimport {\n  mapToWorkspace,\n  extractDynamicThemes,\n  extractEvidenceFormula,\n  detectAcademicTier,\n  mergeExtractionData,\n  deriveRoadmapFromAssessments,\n  extractDeepCourseData\n} from '../../src/services/BriefService';\n\n// TierParameters is imported inside BriefService; mock it to avoid JSON fixtures\njest.mock('../../src/services/TierParameters', () => ({\n  TierParameters: { tertiary: { heuristics: {} }, Undergrad: { heuristics: {} } }\n}));\n\n// ---- mapToWorkspace ----\ndescribe('mapToWorkspace', () => {\n  test('Tertiary returns 7 sections', () => {\n    expect(mapToWorkspace('', 'Tertiary')).toHaveLength(7);\n  });\n  test('Undergrad returns 3 sections', () => {\n    expect(mapToWorkspace('', 'Undergrad')).toHaveLength(3);\n  });\n  test('Honours returns 3 sections', () => {\n    expect(mapToWorkspace('', 'Honours')).toHaveLength(3);\n  });\n  test('PhD returns 2 sections', () => {\n    expect(mapToWorkspace('', 'PhD')).toHaveLength(2);\n  });\n  test('unknown level returns empty array', () => {\n    expect(mapToWorkspace('', 'MoonDegree')).toEqual([]);\n  });\n});\n\n// ---- extractDynamicThemes ----\ndescribe('extractDynamicThemes', () => {\n  test('returns up to 3 themes from capitalised words', () => {\n    const text = 'Metabolism Photosynthesis Osmosis Metabolism Metabolism';\n    const result = extractDynamicThemes(text);\n    expect(result.split(', ').length).toBeLessThanOrEqual(3);\n    expect(result).toContain('Metabolism');\n  });\n\n  test('excludes stop words', () => {\n    const result = extractDynamicThemes('University Student Assignment Assessment Course');\n    expect(result).toBe('General Studies');\n  });\n\n  test('returns \"General Studies\" when no matches', () => {\n    expect(extractDynamicThemes('this is all lowercase text')).toBe('General Studies');\n  });\n});\n\n// ---- extractEvidenceFormula ----\ndescribe('extractEvidenceFormula', () => {\n  test('non-tertiary level returns single generic source', () => {\n    const result = extractEvidenceFormula('Some text', 'secondary');\n    expect(result).toEqual([{ type: 'generic', count: 1, label: 'Academic Source' }]);\n  });\n\n  test('parses digit count for primary articles', () => {\n    const result = extractEvidenceFormula('You need 2 primary articles for this task', 'tertiary');\n    const primary = result.find(r => r.type === 'primary');\n    expect(primary).toBeDefined();\n    expect(primary.count).toBe(2);\n  });\n\n  test('parses word count for review articles', () => {\n    const result = extractEvidenceFormula('You need three review articles', 'tertiary');\n    const review = result.find(r => r.type === 'review');\n    expect(review).toBeDefined();\n    expect(review.count).toBe(3);\n  });\n\n  test('falls back to 1 generic source when nothing matches', () => {\n    const result = extractEvidenceFormula('No source requirements here.', 'tertiary');\n    expect(result).toEqual([{ type: 'generic', count: 1, label: 'Academic Source' }]);\n  });\n});\n\n// ---- detectAcademicTier ----\ndescribe('detectAcademicTier', () => {\n  test('Lab text detected as Lab', () => {\n    expect(detectAcademicTier('This laboratory experiment uses a specific procedure.')).toBe('Lab');\n  });\n  test('Research text detected', () => {\n    expect(detectAcademicTier('Write a literature review and cite journal articles.')).toBe('Research');\n  });\n  test('Practical text detected', () => {\n    expect(detectAcademicTier('Submit a portfolio for clinical placement.')).toBe('Practical');\n  });\n  test('Unclassified text falls to General', () => {\n    expect(detectAcademicTier('Complete the task by Friday.')).toBe('General');\n  });\n  test('empty string returns General', () => {\n    expect(detectAcademicTier('')).toBe('General');\n  });\n});\n\n// ---- mergeExtractionData ----\ndescribe('mergeExtractionData', () => {\n  test('returns next when prev is null', () => {\n    const next = { assessmentTitles: ['Essay (30%)'], words: 1500 };\n    expect(mergeExtractionData(null, next)).toBe(next);\n  });\n\n  test('returns prev when next is null', () => {\n    const prev = { assessmentTitles: ['Essay (30%)'], words: 1500 };\n    expect(mergeExtractionData(prev, null)).toBe(prev);\n  });\n\n  test('deduplicates assessment titles', () => {\n    const prev = { assessmentTitles: ['Essay (30%)'], words: 1000 };\n    const next = { assessmentTitles: ['Essay (30%)', 'Final Exam (50%)'], words: 500 };\n    const result = mergeExtractionData(prev, next);\n    expect(result.assessmentTitles.filter(t => t === 'Essay (30%)')).toHaveLength(1);\n  });\n\n  test('takes max word count', () => {\n    const prev = { words: 2000 };\n    const next = { words: 1000 };\n    expect(mergeExtractionData(prev, next).words).toBe(2000);\n  });\n\n  test('merges udlPrinciples without duplicates', () => {\n    const prev = { udlPrinciples: ['engagement'] };\n    const next = { udlPrinciples: ['engagement', 'representation'] };\n    const result = mergeExtractionData(prev, next);\n    expect(result.udlPrinciples.filter(p => p === 'engagement')).toHaveLength(1);\n    expect(result.udlPrinciples).toContain('representation');\n  });\n});\n\n// ---- deriveRoadmapFromAssessments ----\ndescribe('deriveRoadmapFromAssessments', () => {\n  test('null input returns null', () => {\n    expect(deriveRoadmapFromAssessments(null)).toBeNull();\n  });\n\n  test('empty array returns null', () => {\n    expect(deriveRoadmapFromAssessments([])).toBeNull();\n  });\n\n  test('all-duplicate titles returns null', () => {\n    expect(deriveRoadmapFromAssessments(['x', 'x', 'x'])).toBeNull();\n  });\n\n  test('single title sets currentTask; nextAssessment and finalMilestone are null', () => {\n    const result = deriveRoadmapFromAssessments(['Lab Report (25%)']);\n    expect(result.currentTask).toBe('Lab Report (25%)');\n    expect(result.nextAssessment).toBeNull();\n    expect(result.finalMilestone).toBeNull();\n  });\n\n  test('three titles: prefers Final Exam for finalMilestone', () => {\n    const titles = ['Essay (20%)', 'Mid-semester Test (30%)', 'Final Exam (50%)'];\n    const result = deriveRoadmapFromAssessments(titles);\n    expect(result.finalMilestone).toMatch(/Final Exam/i);\n  });\n\n  test('literature review task attaches Pareto steps', () => {\n    const titles = ['Mini Literature Review (25%)', 'Final Exam (50%)', 'Lab Report (25%)'];\n    const result = deriveRoadmapFromAssessments(titles);\n    expect(result.paretoSteps).not.toBeNull();\n    expect(result.totalWeight).toBe('25%');\n  });\n\n  test('caps noisy extraction at 5 milestones when >10 titles', () => {\n    const titles = Array.from({ length: 15 }, (_, i) => `Assessment ${i + 1} (${5 + i}%)`);\n    const result = deriveRoadmapFromAssessments(titles);\n    // currentTask must be one of top 5 by weight\n    expect(result).not.toBeNull();\n    // If synthesise runs, the titles array fed in is <= 5\n    // We verify indirectly by checking no crash and result is valid\n    expect(typeof result.currentTask).toBe('string');\n  });\n});\n\n// ---- extractDeepCourseData integration smoke test ----\ndescribe('extractDeepCourseData', () => {\n  const SAMPLE = `\n    Assessment 1: Literature Review (25%)\n    Assessment 2: Lab Report (25%)\n    Final Exam (50%)\n    LO1: Demonstrate understanding of osmosis and diffusion.\n    Word count: 1500 words\n    References: APA style\n    Due: Friday Week 5\n  `;\n\n  test('returns expected shape', () => {\n    const result = extractDeepCourseData(SAMPLE);\n    expect(result).toHaveProperty('assessmentTitles');\n    expect(result).toHaveProperty('learningOutcomes');\n    expect(result).toHaveProperty('words');\n    expect(result).toHaveProperty('referencingStyle');\n    expect(result).toHaveProperty('doneWhenChecklist');\n  });\n\n  test('detects APA referencing style', () => {\n    expect(extractDeepCourseData(SAMPLE).referencingStyle).toBe('APA');\n  });\n\n  test('extracts word count of 1500', () => {\n    expect(extractDeepCourseData(SAMPLE).words).toBe(1500);\n  });\n\n  test('doneWhenChecklist items have id, text, checked=false', () => {\n    const { doneWhenChecklist } = extractDeepCourseData(SAMPLE);\n    for (const item of doneWhenChecklist) {\n      expect(item).toHaveProperty('id');\n      expect(item).toHaveProperty('text');\n      expect(item.checked).toBe(false);\n    }\n  });\n\n  test('empty text returns empty arrays gracefully', () => {\n    const result = extractDeepCourseData('');\n    expect(result.assessmentTitles).toEqual([]);\n    expect(result.doneWhenChecklist).toEqual([]);\n  });\n});\n```\n\n---\n\n## Summary Table\n\n| Module | Functions | Priority | Test Complexity | Browser Deps |\n|---|---|---|---|---|\n| `LiteralMode.js` | `literalise`, `shouldLiteralise` | **Critical** | Low | None |\n| `TemporalFilter.js` | `checkTemporalAlignment`, `analyzeFileMetadata` | High | Low | None |\n| `SovereignRouter.js` | `streamFromLevel`, `isValidStream`, `hydrate`, `applyTheme` | High | Low (jsdom) | jsdom only |\n| `BriefService.js` | 7 functions | **Critical** | Medium | None |\n| `EventBus.js` | `startEventBus`, `stopEventBus`, `recordTextEdit`, `recordCitation` | Medium | Medium | jsdom + mock HoT |\n| `HistoryOfThought.js` | `appendEvent`, `isUnlocked`, `generateReport` | High | High | IndexedDB mock |\n| `ExecutiveSpine.js` | focus/idle/playtime logic | Medium | High | `window` + timers |\n| All frontend components | Render + interactions | Low (start) | High | `@testing-library/react` |\n\n## Setup Required First\n\n```bash\nnpm install --save-dev jest jest-environment-jsdom @testing-library/react @testing-library/jest-dom babel-jest\n```\n\nAdd to `package.json`:\n```json\n\"jest\": {\n  \"testEnvironment\": \"jsdom\",\n  \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\"]\n}\n```\n\nStart with **`LiteralMode`** and **`BriefService`** -- pure functions, zero mocking required, highest logic density.\n",
