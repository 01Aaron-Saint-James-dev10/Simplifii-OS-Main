        "language": "js",
        "code": "// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation, __internals } from '../../src/core/EventBus';\n\n// Mock HistoryOfThought so we control vault state\njest.mock('../../src/core/HistoryOfThought', () => ({\n  isUnlocked: jest.fn(() => false),\n  appendEvent: jest.fn(() => Promise.resolve()),\n  EVENT_TYPES: ['focus_session_start','focus_session_end','nudge_triggered','section_health_change',\n    'playtime_granted','playtime_expired','ai_assist_invoked','text_edit','citation_added','citation_removed']\n}));\n\nimport { isUnlocked, appendEvent } from '../../src/core/HistoryOfThought';\n\ndescribe('startEventBus / stopEventBus', () => {\n  afterEach(() => stopEventBus());\n\n  test('registers one listener per SPINE_TO_HOT entry', () => {\n    const addSpy = jest.spyOn(window, 'addEventListener');\n    startEventBus();\n    const spineCount = Object.keys(__internals.SPINE_TO_HOT).length;\n    expect(addSpy).toHaveBeenCalledTimes(spineCount);\n    addSpy.mockRestore();\n  });\n\n  test('calling start twice replaces listeners (re-entrant)', () => {\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    startEventBus();\n    startEventBus(); // second call should stop first\n    expect(removeSpy).toHaveBeenCalled();\n    removeSpy.mockRestore();\n  });\n\n  test('stopEventBus removes all listeners', () => {\n    startEventBus();\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    stopEventBus();\n    const spineCount = Object.keys(__internals.SPINE_TO_HOT).length;\n    expect(removeSpy).toHaveBeenCalledTimes(spineCount);\n    removeSpy.mockRestore();\n  });\n});\n\ndescribe('event routing when vault is locked', () => {\n  beforeEach(() => { isUnlocked.mockReturnValue(false); appendEvent.mockClear(); });\n  afterEach(() => stopEventBus());\n\n  test('spine events are silently dropped when vault locked', () => {\n    startEventBus();\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 't1', plannedDurationMs: 1500000 } }));\n    expect(appendEvent).not.toHaveBeenCalled();\n  });\n});\n\ndescribe('event routing when vault is unlocked', () => {\n  beforeEach(() => { isUnlocked.mockReturnValue(true); appendEvent.mockClear(); });\n  afterEach(() => stopEventBus());\n\n  test('simplifii:focus-start calls appendEvent with focus_session_start', async () => {\n    startEventBus();\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 't1', plannedDurationMs: 1500000 } }));\n    await Promise.resolve(); // flush microtasks\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'focus_session_start' }));\n  });\n});\n\ndescribe('recordTextEdit', () => {\n  beforeEach(() => appendEvent.mockClear());\n\n  test('no-op when vault locked', async () => {\n    isUnlocked.mockReturnValue(false);\n    await recordTextEdit({ sectionId: 's1', wordsAfter: 100 });\n    expect(appendEvent).not.toHaveBeenCalled();\n  });\n\n  test('appends text_edit event when unlocked', async () => {\n    isUnlocked.mockReturnValue(true);\n    await recordTextEdit({ sectionId: 's1', wordsAfter: 100, debounceWindowMs: 500 });\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'text_edit' }));\n  });\n\n  test('coerces missing wordsAfter to 0', async () => {\n    isUnlocked.mockReturnValue(true);\n    await recordTextEdit({ sectionId: 's1' });\n    expect(appendEvent).toHaveBeenCalledWith(\n      expect.objectContaining({ payload: expect.objectContaining({ wordsAfter: 0 }) })\n    );\n  });\n});\n\ndescribe('recordCitation', () => {\n  beforeEach(() => { isUnlocked.mockReturnValue(true); appendEvent.mockClear(); });\n\n  test('added=true uses citation_added type', async () => {\n    await recordCitation({ added: true, source: 'Smith 2023', sourceId: 'abc' });\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'citation_added' }));\n  });\n\n  test('added=false uses citation_removed type', async () => {\n    await recordCitation({ added: false, source: 'Smith 2023', sourceId: 'abc' });\n    expect(appendEvent).toHaveBeenCalledWith(expect.objectContaining({ event_type: 'citation_removed' }));\n  });\n\n  test('source is truncated to 120 chars', async () => {\n    const longSource = 'x'.repeat(200);\n    await recordCitation({ added: true, source: longSource, sourceId: 'id' });\n    const call = appendEvent.mock.calls[0][0];\n    expect(call.payload.source.length).toBeLessThanOrEqual(120);\n  });\n\n  test('sourceId is truncated to 60 chars', async () => {\n    const longId = 'y'.repeat(100);\n    await recordCitation({ added: true, source: 'src', sourceId: longId });\n    const call = appendEvent.mock.calls[0][0];\n    expect(call.payload.sourceId.length).toBeLessThanOrEqual(60);\n  });\n});"
