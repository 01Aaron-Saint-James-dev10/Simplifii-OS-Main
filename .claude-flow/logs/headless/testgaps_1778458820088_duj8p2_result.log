      {
        "title": "4. `src/services/TemporalFilter.js` -- **Low complexity, easy wins**",
        "content": "\n**Untested functions:** `buildWeeklySchedule`, `checkTemporalAlignment`, `analyzeFileMetadata`\n\n**Missing cases:**\n- `buildWeeklySchedule` always returns an empty array (stub contract)\n- `checkTemporalAlignment` with empty schedule returns `{ aligned: false, event: null }`\n- `checkTemporalAlignment` with event within 24 hours returns `{ aligned: true, event }`\n- `checkTemporalAlignment` with event exactly 24 hours away (boundary)\n- `checkTemporalAlignment` with event 24h + 1ms away (boundary)\n- `analyzeFileMetadata` falls back to `Date.now()` when `lastModified` is absent\n\n**Test skeleton:**\n\n```js\n// tests/services/TemporalFilter.test.js\nimport { buildWeeklySchedule, checkTemporalAlignment, analyzeFileMetadata } from '../../src/services/TemporalFilter';\n\nconst ONE_DAY = 86400000;\n\ndescribe('buildWeeklySchedule', () => {\n  test('always returns an empty array', () => {\n    expect(buildWeeklySchedule('any text')).toEqual([]);\n    expect(buildWeeklySchedule('')).toEqual([]);\n    expect(buildWeeklySchedule(null)).toEqual([]);\n  });\n});\n\ndescribe('checkTemporalAlignment', () => {\n  test('empty schedule returns not aligned', () => {\n    expect(checkTemporalAlignment(Date.now(), [])).toEqual({ aligned: false, event: null });\n  });\n\n  test('event within 24h returns aligned + event', () => {\n    const now = Date.now();\n    const schedule = [{ timestamp: now - 1000, label: 'Lecture' }];\n    const result = checkTemporalAlignment(now, schedule);\n    expect(result.aligned).toBe(true);\n    expect(result.event).toBe(schedule[0]);\n  });\n\n  test('event exactly 24h away is aligned (boundary inclusive)', () => {\n    const now = Date.now();\n    const schedule = [{ timestamp: now - ONE_DAY, label: 'Lab' }];\n    const result = checkTemporalAlignment(now, schedule);\n    expect(result.aligned).toBe(true);\n  });\n\n  test('event 24h + 1ms away is NOT aligned', () => {\n    const now = Date.now();\n    const schedule = [{ timestamp: now - ONE_DAY - 1, label: 'Lab' }];\n    const result = checkTemporalAlignment(now, schedule);\n    expect(result.aligned).toBe(false);\n  });\n\n  test('returns first matching event when multiple exist', () => {\n    const now = Date.now();\n    const schedule = [\n      { timestamp: now - 500, label: 'First' },\n      { timestamp: now - 1000, label: 'Second' }\n    ];\n    expect(checkTemporalAlignment(now, schedule).event.label).toBe('First');\n  });\n});\n\ndescribe('analyzeFileMetadata', () => {\n  test('uses file.lastModified for timestamp', () => {\n    const now = Date.now();\n    const file = { lastModified: now };\n    // empty schedule -> always not aligned; just assert it doesn't throw\n    const result = analyzeFileMetadata(file);\n    expect(result).toHaveProperty('aligned');\n  });\n\n  test('falls back gracefully when lastModified is missing', () => {\n    expect(() => analyzeFileMetadata({})).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "5. `src/services/BriefService.js` -- **Highest complexity, most critical business logic**",
        "content": "\n**Untested functions:** `mapToWorkspace`, `extractDynamicThemes`, `extractEvidenceFormula`, `detectAcademicTier`, `extractDeepCourseData`, `mergeExtractionData`, `deriveRoadmapFromAssessments`\n\n**Key gaps:**\n- `mapToWorkspace` returns correct section count per level (Tertiary=7, Undergrad=3, Honours=3, PhD=2, unknown=[])\n- `extractDynamicThemes` excludes stop words, caps at 3 themes, returns fallback for all-noise text\n- `extractEvidenceFormula` with non-tertiary level returns single generic source\n- `extractEvidenceFormula` parses digit counts (\"2 primary articles\")\n- `extractEvidenceFormula` parses word counts (\"three review articles\")\n- `extractEvidenceFormula` falls back to 1 generic source when no match\n- `detectAcademicTier` returns `Lab` for methodology/experiment text\n- `detectAcademicTier` returns `Research` for literature-review text\n- `detectAcademicTier` returns `Practical` for portfolio/clinical text\n- `detectAcademicTier` returns `General` as default\n- `mergeExtractionData` with `prev=null` returns `next`; with `next=null` returns `prev`\n- `mergeExtractionData` deduplicates assessment titles\n- `mergeExtractionData` takes max word count\n- `deriveRoadmapFromAssessments` with empty/null array returns null\n- `deriveRoadmapFromAssessments` with 1 title sets `currentTask` and nulls `nextAssessment`/`finalMilestone`\n- `deriveRoadmapFromAssessments` preferentially picks `Final Exam` for `finalMilestone`\n- `deriveRoadmapFromAssessments` caps noisy extraction at 5 milestones when >10 titles\n- `deriveRoadmapFromAssessments` attaches Pareto steps for literature-review tasks\n\n**Test skeleton:**\n\n```js\n// tests/services/BriefService.test.js\nimport {\n  mapToWorkspace,\n  extractDynamicThemes,\n  extractEvidenceFormula,\n  detectAcademicTier,\n  mergeExtractionData,\n  deriveRoadmapFromAssessments,\n  extractDeepCourseData\n} from '../../src/services/BriefService';\n\n// TierParameters is imported inside BriefService; mock it to avoid JSON fixtures\njest.mock('../../src/services/TierParameters', () => ({\n  TierParameters: { tertiary: { heuristics: {} }, Undergrad: { heuristics: {} } }\n}));\n\n// ---- mapToWorkspace ----\ndescribe('mapToWorkspace', () => {\n  test('Tertiary returns 7 sections', () => {\n    expect(mapToWorkspace('', 'Tertiary')).toHaveLength(7);\n  });\n  test('Undergrad returns 3 sections', () => {\n    expect(mapToWorkspace('', 'Undergrad')).toHaveLength(3);\n  });\n  test('Honours returns 3 sections', () => {\n    expect(mapToWorkspace('', 'Honours')).toHaveLength(3);\n  });\n  test('PhD returns 2 sections', () => {\n    expect(mapToWorkspace('', 'PhD')).toHaveLength(2);\n  });\n  test('unknown level returns empty array', () => {\n    expect(mapToWorkspace('', 'MoonDegree')).toEqual([]);\n  });\n});\n\n// ---- extractDynamicThemes ----\ndescribe('extractDynamicThemes', () => {\n  test('returns up to 3 themes from capitalised words', () => {\n    const text = 'Metabolism Photosynthesis Osmosis Metabolism Metabolism';\n    const result = extractDynamicThemes(text);\n    expect(result.split(', ').length).toBeLessThanOrEqual(3);\n    expect(result).toContain('Metabolism');\n  });\n\n  test('excludes stop words', () => {\n    const result = extractDynamicThemes('University Student Assignment Assessment Course');\n    expect(result).toBe('General Studies');\n  });\n\n  test('returns \"General Studies\" when no matches', () => {\n    expect(extractDynamicThemes('this is all lowercase text')).toBe('General Studies');\n  });\n});\n\n// ---- extractEvidenceFormula ----\ndescribe('extractEvidenceFormula', () => {\n  test('non-tertiary level returns single generic source', () => {\n    const result = extractEvidenceFormula('Some text', 'secondary');\n    expect(result).toEqual([{ type: 'generic', count: 1, label: 'Academic Source' }]);\n  });\n\n  test('parses digit count for primary articles', () => {\n    const result = extractEvidenceFormula('You need 2 primary articles for this task', 'tertiary');\n    const primary = result.find(r => r.type === 'primary');\n    expect(primary).toBeDefined();\n    expect(primary.count).toBe(2);\n  });\n\n  test('parses word count for review articles', () => {\n    const result = extractEvidenceFormula('You need three review articles', 'tertiary');\n    const review = result.find(r => r.type === 'review');\n    expect(review).toBeDefined();\n    expect(review.count).toBe(3);\n  });\n\n  test('falls back to 1 generic source when nothing matches', () => {\n    const result = extractEvidenceFormula('No source requirements here.', 'tertiary');\n    expect(result).toEqual([{ type: 'generic', count: 1, label: 'Academic Source' }]);\n  });\n});\n\n// ---- detectAcademicTier ----\ndescribe('detectAcademicTier', () => {\n  test('Lab text detected as Lab', () => {\n    expect(detectAcademicTier('This laboratory experiment uses a specific procedure.')).toBe('Lab');\n  });\n  test('Research text detected', () => {\n    expect(detectAcademicTier('Write a literature review and cite journal articles.')).toBe('Research');\n  });\n  test('Practical text detected', () => {\n    expect(detectAcademicTier('Submit a portfolio for clinical placement.')).toBe('Practical');\n  });\n  test('Unclassified text falls to General', () => {\n    expect(detectAcademicTier('Complete the task by Friday.')).toBe('General');\n  });\n  test('empty string returns General', () => {\n    expect(detectAcademicTier('')).toBe('General');\n  });\n});\n\n// ---- mergeExtractionData ----\ndescribe('mergeExtractionData', () => {\n  test('returns next when prev is null', () => {\n    const next = { assessmentTitles: ['Essay (30%)'], words: 1500 };\n    expect(mergeExtractionData(null, next)).toBe(next);\n  });\n\n  test('returns prev when next is null', () => {\n    const prev = { assessmentTitles: ['Essay (30%)'], words: 1500 };\n    expect(mergeExtractionData(prev, null)).toBe(prev);\n  });\n\n  test('deduplicates assessment titles', () => {\n    const prev = { assessmentTitles: ['Essay (30%)'], words: 1000 };\n    const next = { assessmentTitles: ['Essay (30%)', 'Final Exam (50%)'], words: 500 };\n    const result = mergeExtractionData(prev, next);\n    expect(result.assessmentTitles.filter(t => t === 'Essay (30%)')).toHaveLength(1);\n  });\n\n  test('takes max word count', () => {\n    const prev = { words: 2000 };\n    const next = { words: 1000 };\n    expect(mergeExtractionData(prev, next).words).toBe(2000);\n  });\n\n  test('merges udlPrinciples without duplicates', () => {\n    const prev = { udlPrinciples: ['engagement'] };\n    const next = { udlPrinciples: ['engagement', 'representation'] };\n    const result = mergeExtractionData(prev, next);\n    expect(result.udlPrinciples.filter(p => p === 'engagement')).toHaveLength(1);\n    expect(result.udlPrinciples).toContain('representation');\n  });\n});\n\n// ---- deriveRoadmapFromAssessments ----\ndescribe('deriveRoadmapFromAssessments', () => {\n  test('null input returns null', () => {\n    expect(deriveRoadmapFromAssessments(null)).toBeNull();\n  });\n\n  test('empty array returns null', () => {\n    expect(deriveRoadmapFromAssessments([])).toBeNull();\n  });\n\n  test('all-duplicate titles returns null', () => {\n    expect(deriveRoadmapFromAssessments(['x', 'x', 'x'])).toBeNull();\n  });\n\n  test('single title sets currentTask; nextAssessment and finalMilestone are null', () => {\n    const result = deriveRoadmapFromAssessments(['Lab Report (25%)']);\n    expect(result.currentTask).toBe('Lab Report (25%)');\n    expect(result.nextAssessment).toBeNull();\n    expect(result.finalMilestone).toBeNull();\n  });\n\n  test('three titles: prefers Final Exam for finalMilestone', () => {\n    const titles = ['Essay (20%)', 'Mid-semester Test (30%)', 'Final Exam (50%)'];\n    const result = deriveRoadmapFromAssessments(titles);\n    expect(result.finalMilestone).toMatch(/Final Exam/i);\n  });\n\n  test('literature review task attaches Pareto steps', () => {\n    const titles = ['Mini Literature Review (25%)', 'Final Exam (50%)', 'Lab Report (25%)'];\n    const result = deriveRoadmapFromAssessments(titles);\n    expect(result.paretoSteps).not.toBeNull();\n    expect(result.totalWeight).toBe('25%');\n  });\n\n  test('caps noisy extraction at 5 milestones when >10 titles', () => {\n    const titles = Array.from({ length: 15 }, (_, i) => `Assessment ${i + 1} (${5 + i}%)`);\n    const result = deriveRoadmapFromAssessments(titles);\n    // currentTask must be one of top 5 by weight\n    expect(result).not.toBeNull();\n    // If synthesise runs, the titles array fed in is <= 5\n    // We verify indirectly by checking no crash and result is valid\n    expect(typeof result.currentTask).toBe('string');\n  });\n});\n\n// ---- extractDeepCourseData integration smoke test ----\ndescribe('extractDeepCourseData', () => {\n  const SAMPLE = `\n    Assessment 1: Literature Review (25%)\n    Assessment 2: Lab Report (25%)\n    Final Exam (50%)\n    LO1: Demonstrate understanding of osmosis and diffusion.\n    Word count: 1500 words\n    References: APA style\n    Due: Friday Week 5\n  `;\n\n  test('returns expected shape', () => {\n    const result = extractDeepCourseData(SAMPLE);\n    expect(result).toHaveProperty('assessmentTitles');\n    expect(result).toHaveProperty('learningOutcomes');\n    expect(result).toHaveProperty('words');\n    expect(result).toHaveProperty('referencingStyle');\n    expect(result).toHaveProperty('doneWhenChecklist');\n  });\n\n  test('detects APA referencing style', () => {\n    expect(extractDeepCourseData(SAMPLE).referencingStyle).toBe('APA');\n  });\n\n  test('extracts word count of 1500', () => {\n    expect(extractDeepCourseData(SAMPLE).words).toBe(1500);\n  });\n\n  test('doneWhenChecklist items have id, text, checked=false', () => {\n    const { doneWhenChecklist } = extractDeepCourseData(SAMPLE);\n    for (const item of doneWhenChecklist) {\n      expect(item).toHaveProperty('id');\n      expect(item).toHaveProperty('text');\n      expect(item.checked).toBe(false);\n    }\n  });\n\n  test('empty text returns empty arrays gracefully', () => {\n    const result = extractDeepCourseData('');\n    expect(result.assessmentTitles).toEqual([]);\n    expect(result.doneWhenChecklist).toEqual([]);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Summary Table",
        "content": "\n| Module | Functions | Priority | Test Complexity | Browser Deps |\n|---|---|---|---|---|\n| `LiteralMode.js` | `literalise`, `shouldLiteralise` | **Critical** | Low | None |\n| `TemporalFilter.js` | `checkTemporalAlignment`, `analyzeFileMetadata` | High | Low | None |\n| `SovereignRouter.js` | `streamFromLevel`, `isValidStream`, `hydrate`, `applyTheme` | High | Low (jsdom) | jsdom only |\n| `BriefService.js` | 7 functions | **Critical** | Medium | None |\n| `EventBus.js` | `startEventBus`, `stopEventBus`, `recordTextEdit`, `recordCitation` | Medium | Medium | jsdom + mock HoT |\n| `HistoryOfThought.js` | `appendEvent`, `isUnlocked`, `generateReport` | High | High | IndexedDB mock |\n| `ExecutiveSpine.js` | focus/idle/playtime logic | Medium | High | `window` + timers |\n| All frontend components | Render + interactions | Low (start) | High | `@testing-library/react` |\n\n",
        "level": 2
