        "title": "1. `src/core/LiteralMode.js` -- **Highest priority, pure functions, zero browser deps**",
        "content": "\n**Untested functions:** `literalise`, `shouldLiteralise`, `sanitiseDashes` (internal)\n\n**Missing cases:**\n- Non-string / falsy input passthrough (`null`, `undefined`, `0`, `\"\"`)\n- Em-dash and en-dash replacement by `sanitiseDashes`\n- Each pattern row in isolation (e.g. `consider revising`, `furthermore`, `should be revised`)\n- Passive construction transforms (`are required to` -> `must`)\n- `splitClauses: false` disables semicolon and conjunction splitting\n- `dropEmpty: false` keeps double spaces\n- Sentence-start capitalisation after deletions (e.g. `going forward do X` -> `Do X`)\n- `shouldLiteralise` with explicit `userPreference: true/false` overrides stream default\n- `shouldLiteralise` with `userPreference: null` falls through to `streamProfile.literalModeDefault`\n\n**Test skeleton:**\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../../src/core/LiteralMode';\n\ndescribe('sanitiseDashes', () => {\n  const { sanitiseDashes } = __internals;\n\n  test('replaces em-dash with comma', () => {\n    expect(sanitiseDashes('word\\u2014word')).toBe('word,word');\n  });\n\n  test('replaces en-dash with comma', () => {\n    expect(sanitiseDashes('word\\u2013word')).toBe('word,word');\n  });\n\n  test('leaves plain hyphens unchanged', () => {\n    expect(sanitiseDashes('word-word')).toBe('word-word');\n  });\n\n  test('returns empty string for null/undefined', () => {\n    expect(sanitiseDashes(null)).toBe('');\n    expect(sanitiseDashes(undefined)).toBe('');\n  });\n});\n\ndescribe('literalise - input guards', () => {\n  test('returns null unchanged', () => expect(literalise(null)).toBeNull());\n  test('returns undefined unchanged', () => expect(literalise(undefined)).toBeUndefined());\n  test('returns empty string unchanged', () => expect(literalise('')).toBe(''));\n  test('returns number unchanged', () => expect(literalise(42)).toBe(42));\n});\n\ndescribe('literalise - pattern transforms', () => {\n  test('consider revising -> change', () => {\n    expect(literalise('You should consider revising this section.')).toContain('change');\n  });\n\n  test('furthermore -> also', () => {\n    expect(literalise('Furthermore, this is important.')).toContain('Also');\n  });\n\n  test('synthesise -> combine ideas from', () => {\n    expect(literalise('Synthesise the findings.')).toContain('combine ideas from');\n  });\n\n  test('should be revised -> rewrite this', () => {\n    expect(literalise('The argument should be revised.')).toContain('rewrite this');\n  });\n\n  test('are required to -> must', () => {\n    expect(literalise('Students are required to submit by Friday.')).toContain('must');\n  });\n\n  test('going forward is deleted (empty drop)', () => {\n    const result = literalise('Going forward do the work.');\n    expect(result).not.toContain('going forward');\n    expect(result).not.toContain('Going forward');\n  });\n});\n\ndescribe('literalise - clause splitting', () => {\n  test('semicolons become full stops', () => {\n    const result = literalise('Do this; then do that.');\n    expect(result).toContain('. ');\n    expect(result).not.toContain(';');\n  });\n\n  test('splitClauses: false leaves semicolons intact', () => {\n    const result = literalise('Do this; then do that.', { splitClauses: false });\n    expect(result).toContain(';');\n  });\n\n  test(', and connector becomes full stop', () => {\n    const result = literalise('Submit the draft, and ensure formatting is correct.');\n    expect(result).toMatch(/\\.\\s/);\n  });\n});\n\ndescribe('literalise - capitalisation after deletion', () => {\n  test('first word is capitalised after going-forward deletion', () => {\n    const result = literalise('going forward ensure quality.');\n    expect(result[0]).toBe(result[0].toUpperCase());\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('explicit true overrides stream default', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, true)).toBe(true);\n  });\n\n  test('explicit false overrides stream default', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, false)).toBe(false);\n  });\n\n  test('null preference defers to stream default true', () => {\n    expect(shouldLiteralise({ literalModeDefault: true }, null)).toBe(true);\n  });\n\n  test('null preference defers to stream default false', () => {\n    expect(shouldLiteralise({ literalModeDefault: false }, null)).toBe(false);\n  });\n\n  test('undefined stream returns false', () => {\n    expect(shouldLiteralise(undefined, null)).toBe(false);\n  });\n});\n```\n\n---\n\n",
