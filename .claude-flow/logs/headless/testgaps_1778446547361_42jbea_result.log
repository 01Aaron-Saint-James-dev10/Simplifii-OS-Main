        "content": "\nUntested: `unlockWithPassphrase`, `appendEvent`, `listEvents`, `generateAuthenticityReport`, key derivation, AES-GCM round-trip.\n\n```js\n// tests/unit/core/HistoryOfThought.test.js\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport, EVENT_TYPES\n} from '../../../src/core/HistoryOfThought.js';\n\ndescribe('HistoryOfThought', () => {\n  beforeEach(() => lockSession());\n\n  describe('isUnlocked', () => {\n    it('returns false before any unlock', () => {\n      expect(isUnlocked()).toBe(false);\n    });\n  });\n\n  describe('unlockWithPassphrase', () => {\n    it('resolves true for a valid passphrase', async () => {\n      await expect(unlockWithPassphrase('correct-passphrase')).resolves.toBe(true);\n      expect(isUnlocked()).toBe(true);\n    });\n\n    it('returns false for an empty passphrase', async () => {\n      await expect(unlockWithPassphrase('')).resolves.toBe(false);\n    });\n\n    it('returns false for null passphrase', async () => {\n      await expect(unlockWithPassphrase(null)).resolves.toBe(false);\n    });\n\n    it('two unlocks with different passphrases produce different keys', async () => {\n      await unlockWithPassphrase('pass-a');\n      const keyA = isUnlocked();\n      lockSession();\n      await unlockWithPassphrase('pass-b');\n      const keyB = isUnlocked();\n      // Both unlock, but keys differ — verify via encrypt/decrypt mismatch\n      expect(keyA).toBe(true);\n      expect(keyB).toBe(true);\n    });\n  });\n\n  describe('appendEvent / listEvents round-trip', () => {\n    const userId = 'test-user';\n\n    beforeEach(async () => {\n      await unlockWithPassphrase('test-passphrase');\n    });\n\n    it('appends an event and retrieves it', async () => {\n      await appendEvent({ user_id: userId, stream_id: 'undergraduate', event_type: 'text_edit', payload: { section: 'intro' } });\n      const events = await listEvents({ user_id: userId, limit: 10 });\n      expect(events.length).toBeGreaterThan(0);\n      expect(events[0].event_type).toBe('text_edit');\n    });\n\n    it('rejects appendEvent when vault is locked', async () => {\n      lockSession();\n      await expect(\n        appendEvent({ user_id: userId, stream_id: 's1', event_type: 'text_edit', payload: {} })\n      ).rejects.toThrow();\n    });\n\n    it('rejects unknown event_type', async () => {\n      await expect(\n        appendEvent({ user_id: userId, stream_id: 's1', event_type: 'NOT_VALID', payload: {} })\n      ).rejects.toThrow();\n    });\n\n    it('enforces limit parameter on listEvents', async () => {\n      for (let i = 0; i < 5; i++) {\n        await appendEvent({ user_id: userId, stream_id: 's1', event_type: 'text_edit', payload: {} });\n      }\n      const events = await listEvents({ user_id: userId, limit: 2 });\n      expect(events.length).toBeLessThanOrEqual(2);\n    });\n  });\n\n  describe('generateAuthenticityReport', () => {\n    it('returns a report object with event_count when unlocked', async () => {\n      await unlockWithPassphrase('test-passphrase');\n      const report = await generateAuthenticityReport({ user_id: 'test-user' });\n      expect(report).toHaveProperty('event_count');\n    });\n\n    it('rejects when vault is locked', async () => {\n      lockSession();\n      await expect(generateAuthenticityReport({ user_id: 'test-user' })).rejects.toThrow();\n    });\n  });\n\n  describe('enableCloudSync', () => {\n    it('throws NotImplementedError', () => {\n      const { enableCloudSync } = require('../../../src/core/HistoryOfThought.js');\n      expect(() => enableCloudSync()).toThrow();\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "2. `src/core/ExecutiveSpine.js` — Session, Credits, Idle",
        "content": "\nUntested: `startFocusSession`, `endFocusSession`, `isFocusActive`, `setSectionHealth`, `earnCredits`, `spendCredits`, `grantPlayTime`, idle detection debounce.\n\n```js\n// tests/unit/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  getSectionHealth, setSectionHealth,\n  getCredits, earnCredits, spendCredits,\n  grantPlayTime, isPlayTimeActive,\n  startIdleDetection, stopIdleDetection\n} from '../../../src/core/ExecutiveSpine.js';\n\ndescribe('ExecutiveSpine', () => {\n  beforeEach(() => {\n    endFocusSession({ reason: 'test-reset' });\n    localStorage.clear();\n  });\n\n  describe('Focus session lifecycle', () => {\n    it('starts a session and reports as active', () => {\n      startFocusSession({ taskId: 'task-1', durationMinutes: 25 });\n      expect(isFocusActive()).toBe(true);\n    });\n\n    it('getFocusSession returns the active session', () => {\n      startFocusSession({ taskId: 'task-2', durationMinutes: 25 });\n      const session = getFocusSession();\n      expect(session.taskId).toBe('task-2');\n      expect(session.durationMinutes).toBe(25);\n    });\n\n    it('endFocusSession clears the active session', () => {\n      startFocusSession({ taskId: 'task-3', durationMinutes: 10 });\n      endFocusSession({ reason: 'completed' });\n      expect(isFocusActive()).toBe(false);\n    });\n\n    it('starting a second session while one is active replaces it', () => {\n      startFocusSession({ taskId: 'first', durationMinutes: 10 });\n      startFocusSession({ taskId: 'second', durationMinutes: 20 });\n      expect(getFocusSession().taskId).toBe('second');\n    });\n\n    it('startFocusSession with no taskId throws or defaults gracefully', () => {\n      expect(() => startFocusSession({})).not.toThrow();\n    });\n  });\n\n  describe('Section health', () => {\n    it('getSectionHealth returns 0 for unknown section', () => {\n      expect(getSectionHealth('unknown-section')).toBe(0);\n    });\n\n    it('setSectionHealth persists and retrieves dots', () => {\n      setSectionHealth('intro', 3);\n      expect(getSectionHealth('intro')).toBe(3);\n    });\n\n    it('setSectionHealth clamps at valid range', () => {\n      setSectionHealth('intro', 99);\n      expect(getSectionHealth('intro')).toBeLessThanOrEqual(5); // assuming max 5\n    });\n\n    it('setSectionHealth dispatches a CustomEvent', () => {\n      const listener = jest.fn();\n      window.addEventListener('section_health_change', listener);\n      setSectionHealth('intro', 2);\n      expect(listener).toHaveBeenCalled();\n      window.removeEventListener('section_health_change', listener);\n    });\n  });\n\n  describe('Credits system', () => {\n    it('getCredits starts at 0 or a known default', () => {\n      expect(typeof getCredits()).toBe('number');\n    });\n\n    it('earnCredits increases balance', () => {\n      const before = getCredits();\n      earnCredits(10);\n      expect(getCredits()).toBe(before + 10);\n    });\n\n    it('spendCredits decreases balance', () => {\n      earnCredits(20);\n      const before = getCredits();\n      spendCredits(5);\n      expect(getCredits()).toBe(before - 5);\n    });\n\n    it('spendCredits throws or returns false when insufficient', () => {\n      const current = getCredits();\n      expect(() => spendCredits(current + 9999)).toThrow();\n    });\n\n    it('earnCredits with negative amount throws', () => {\n      expect(() => earnCredits(-1)).toThrow();\n    });\n  });\n\n  describe('PlayTime', () => {\n    it('isPlayTimeActive returns false before any grant', () => {\n      expect(isPlayTimeActive()).toBe(false);\n    });\n\n    it('grantPlayTime activates playtime', () => {\n      grantPlayTime({ minutes: 5, reason: 'reward' });\n      expect(isPlayTimeActive()).toBe(true);\n    });\n  });\n\n  describe('Idle detection', () => {\n    it('startIdleDetection and stopIdleDetection do not throw', () => {\n      expect(() => startIdleDetection({ thresholdMs: 1000 })).not.toThrow();\n      expect(() => stopIdleDetection()).not.toThrow();\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "3. `src/core/SovereignRouter.js` — Stream Resolution",
        "content": "\nUntested: `streamFromLevel`, `isValidStream`, `hydrate`, `applyTheme`, fallback to `DEFAULT_STREAM`.\n\n```js\n// tests/unit/core/SovereignRouter.test.js\nimport {\n  streamFromLevel, isValidStream, hydrate, applyTheme, __internals\n} from '../../../src/core/SovereignRouter.js';\n\nconst { VALID_STREAM_IDS, DEFAULT_STREAM } = __internals;\n\ndescribe('SovereignRouter', () => {\n  describe('streamFromLevel', () => {\n    it('maps \"undergraduate\" to a valid stream id', () => {\n      const id = streamFromLevel('undergraduate');\n      expect(VALID_STREAM_IDS).toContain(id);\n    });\n\n    it('maps \"secondary\" to a valid stream id', () => {\n      expect(VALID_STREAM_IDS).toContain(streamFromLevel('secondary'));\n    });\n\n    it('returns DEFAULT_STREAM for unknown levels', () => {\n      expect(streamFromLevel('alien-level')).toBe(DEFAULT_STREAM);\n    });\n\n    it('returns DEFAULT_STREAM for null/undefined', () => {\n      expect(streamFromLevel(null)).toBe(DEFAULT_STREAM);\n      expect(streamFromLevel(undefined)).toBe(DEFAULT_STREAM);\n    });\n  });\n\n  describe('isValidStream', () => {\n    it('returns true for every known stream id', () => {\n      VALID_STREAM_IDS.forEach(id => expect(isValidStream(id)).toBe(true));\n    });\n\n    it('returns false for an arbitrary string', () => {\n      expect(isValidStream('not-a-stream')).toBe(false);\n    });\n\n    it('returns false for empty string', () => {\n      expect(isValidStream('')).toBe(false);\n    });\n  });\n\n  describe('hydrate', () => {\n    it('returns a profile with stream_id and capabilities', () => {\n      const profile = hydrate({ level: 'undergraduate' });\n      expect(profile).toHaveProperty('stream_id');\n      expect(profile).toHaveProperty('capabilities');\n    });\n\n    it('falls back to DEFAULT_STREAM for empty session', () => {\n      const profile = hydrate({});\n      expect(profile.stream_id).toBe(DEFAULT_STREAM);\n    });\n\n    it('merges session fields into the profile', () => {\n      const profile = hydrate({ level: 'secondary', user_id: 'u1' });\n      expect(profile.user_id).toBe('u1');\n    });\n  });\n\n  describe('applyTheme', () => {\n    it('sets CSS custom properties on document root', () => {\n      const profile = hydrate({ level: 'undergraduate' });\n      expect(() => applyTheme(profile.stream_id)).not.toThrow();\n      // CSS vars applied — verify at least one is set\n      const rootStyle = getComputedStyle(document.documentElement);\n      expect(rootStyle.getPropertyValue('--color-primary') ||\n             document.documentElement.style.getPropertyValue('--color-primary')).toBeTruthy();\n    });\n\n    it('does not throw for DEFAULT_STREAM', () => {\n      expect(() => applyTheme(DEFAULT_STREAM)).not.toThrow();\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "4. `src/core/LiteralMode.js` — Text Transformation",
        "content": "\nUntested: all regex PATTERNS, `shouldLiteralise`, empty/null inputs, `splitClauses`, `dropEmpty`.\n\n```js\n// tests/unit/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../../src/core/LiteralMode.js';\n\ndescribe('LiteralMode', () => {\n  describe('literalise', () => {\n    it('returns original text when no patterns match', () => {\n      const plain = 'Write three points.';\n      expect(literalise(plain)).toBe(plain);\n    });\n\n    it('handles empty string without throwing', () => {\n      expect(() => literalise('')).not.toThrow();\n      expect(literalise('')).toBe('');\n    });\n\n    it('handles null gracefully', () => {\n      expect(() => literalise(null)).not.toThrow();\n    });\n\n    it('transforms academic hedging phrases', () => {\n      const academic = 'It is important to consider the implications.';\n      const result = literalise(academic);\n      expect(result.toLowerCase()).not.toContain('it is important to consider');\n    });\n\n    it('splitClauses option returns an array', () => {\n      const result = literalise('Do this. Then do that.', { splitClauses: true });\n      expect(Array.isArray(result)).toBe(true);\n      expect(result.length).toBeGreaterThan(1);\n    });\n\n    it('dropEmpty option removes blank entries when splitClauses is set', () => {\n      const result = literalise('  . ', { splitClauses: true, dropEmpty: true });\n      expect(result.every(s => s.trim().length > 0)).toBe(true);\n    });\n  });\n\n  describe('shouldLiteralise', () => {\n    it('returns true when streamProfile enables literalMode', () => {\n      expect(shouldLiteralise({ literalMode: true }, 'literal')).toBe(true);\n    });\n\n    it('returns false when user preference overrides to academic', () => {\n      expect(shouldLiteralise({ literalMode: true }, 'academic')).toBe(false);\n    });\n\n    it('returns false for undefined stream profile', () => {\n      expect(shouldLiteralise(undefined, undefined)).toBe(false);\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "5. `src/core/EventBus.js` — Event Pipeline",
        "content": "\nUntested: `startEventBus`, `stopEventBus`, `recordTextEdit`, `recordCitation`, payload filtering, HistoryOfThought integration.\n\n```js\n// tests/unit/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../../src/core/EventBus.js';\n\ndescribe('EventBus', () => {\n  const mockGetContext = jest.fn(() => ({ user_id: 'u1', stream_id: 's1', vaultUnlocked: true }));\n\n  afterEach(() => stopEventBus());\n\n  describe('startEventBus / stopEventBus', () => {\n    it('starts without throwing', () => {\n      expect(() => startEventBus(mockGetContext)).not.toThrow();\n    });\n\n    it('stopping a non-started bus does not throw', () => {\n      expect(() => stopEventBus()).not.toThrow();\n    });\n\n    it('can restart after stop', () => {\n      startEventBus(mockGetContext);\n      stopEventBus();\n      expect(() => startEventBus(mockGetContext)).not.toThrow();\n    });\n  });\n\n  describe('recordTextEdit', () => {\n    it('dispatches without throwing when bus is running', () => {\n      startEventBus(mockGetContext);\n      expect(() => recordTextEdit({ sectionId: 'intro', wordsAfter: 120 })).not.toThrow();\n    });\n\n    it('silently drops event when vault is locked', () => {\n      const lockedContext = jest.fn(() => ({ user_id: 'u1', stream_id: 's1', vaultUnlocked: false }));\n      startEventBus(lockedContext);\n      expect(() => recordTextEdit({ sectionId: 'intro', wordsAfter: 50 })).not.toThrow();\n    });\n\n    it('strips non-safe payload fields', () => {\n      // Payload should not include raw text content — only metadata\n      const spy = jest.spyOn(window, 'dispatchEvent');\n      startEventBus(mockGetContext);\n      recordTextEdit({ sectionId: 'intro', wordsAfter: 10, rawContent: 'secret text' });\n      const dispatched = spy.mock.calls.find(([e]) => e.type?.includes('text'));\n      if (dispatched) {\n        expect(JSON.stringify(dispatched[0].detail)).not.toContain('secret text');\n      }\n      spy.mockRestore();\n    });\n  });\n\n  describe('recordCitation', () => {\n    it('dispatches a citation event when bus is running', () => {\n      startEventBus(mockGetContext);\n      expect(() => recordCitation({ added: true, source: 'Smith 2020' })).not.toThrow();\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "Tier 2 — High Priority",
        "content": "\n",
        "level": 3
      },
      {
        "title": "6. `src/services/BriefService.js` — Data Extraction",
        "content": "\n```js\n// tests/unit/services/BriefService.test.js\nimport {\n  mapToWorkspace, extractDynamicThemes, extractEvidenceFormula, extractDeepCourseData\n} from '../../../src/services/BriefService.js';\n\ndescribe('BriefService', () => {\n  describe('extractDynamicThemes', () => {\n    it('extracts capitalized words as themes', () => {\n      const themes = extractDynamicThemes('Study Sustainability and Climate Justice in Policy.');\n      expect(themes).toContain('Sustainability');\n      expect(themes).toContain('Climate');\n    });\n\n    it('returns empty array for plain lowercase text', () => {\n      expect(extractDynamicThemes('just lowercase text here')).toHaveLength(0);\n    });\n\n    it('handles empty string', () => {\n      expect(extractDynamicThemes('')).toEqual([]);\n    });\n  });\n\n  describe('extractEvidenceFormula', () => {\n    it('extracts source count from \"minimum 8 peer-reviewed sources\"', () => {\n      const result = extractEvidenceFormula('You must cite a minimum of 8 peer-reviewed sources.', 'undergraduate');\n      expect(result).toHaveProperty('minSources');\n      expect(result.minSources).toBe(8);\n    });\n\n    it('returns sensible defaults when no source count found', () => {\n      const result = extractEvidenceFormula('Write an essay.', 'secondary');\n      expect(result).toHaveProperty('minSources');\n    });\n  });\n\n  describe('extractDeepCourseData', () => {\n    const sampleBrief = `\n      Learning Outcomes: 1. Analyse policy frameworks. 2. Evaluate stakeholder impact.\n      Word Count: 2000 words\n      Rubric: Critical Analysis (40%), Evidence (30%), Structure (30%)\n    `;\n\n    it('extracts learning outcomes', () => {\n      const data = extractDeepCourseData(sampleBrief);\n      expect(data.learningOutcomes?.length).toBeGreaterThan(0);\n    });\n\n    it('extracts word count', () => {\n      const data = extractDeepCourseData(sampleBrief);\n      expect(data.wordCount).toBe(2000);\n    });\n\n    it('extracts rubric criteria', () => {\n      const data = extractDeepCourseData(sampleBrief);\n      expect(data.rubric?.length).toBeGreaterThan(0);\n    });\n\n    it('handles empty input without throwing', () => {\n      expect(() => extractDeepCourseData('')).not.toThrow();\n    });\n  });\n\n  describe('mapToWorkspace', () => {\n    it('returns sections array for undergraduate tier', () => {\n      const ws = mapToWorkspace('Analyse the role of policy in...', 'undergraduate');\n      expect(Array.isArray(ws.sections)).toBe(true);\n      expect(ws.sections.length).toBeGreaterThan(0);\n    });\n\n    it('returns sections for secondary tier', () => {\n      const ws = mapToWorkspace('Discuss the causes of WWI.', 'secondary');\n      expect(ws.sections.length).toBeGreaterThan(0);\n    });\n\n    it('handles null text without throwing', () => {\n      expect(() => mapToWorkspace(null, 'undergraduate')).not.toThrow();\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "7. `src/services/SovereignReconciler.js` — Deduplication",
        "content": "\n```js\n// tests/unit/services/SovereignReconciler.test.js\nimport { reconcile, reconcileTitles } from '../../../src/services/SovereignReconciler.js';\n\ndescribe('SovereignReconciler', () => {\n  describe('reconcileTitles', () => {\n    it('merges near-duplicate titles', () => {\n      const result = reconcileTitles([\n        'BABS Critical Analysis',\n        'BABS Critical Analysis ',\n        'Critical Analysis BABS'\n      ]);\n      expect(result.length).toBeLessThan(3);\n    });\n\n    it('preserves distinctly different titles', () => {\n      const result = reconcileTitles(['Essay One', 'Lab Report', 'Reflective Journal']);\n      expect(result.length).toBe(3);\n    });\n\n    it('handles empty array', () => {\n      expect(reconcileTitles([])).toEqual([]);\n    });\n\n    it('handles single item', () => {\n      expect(reconcileTitles(['Solo Title'])).toHaveLength(1);\n    });\n  });\n\n  describe('reconcile', () => {\n    const briefs = [\n      { title: 'Critical Analysis', wordCount: 2000, id: '1' },\n      { title: 'Critical Analysis', wordCount: 2000, id: '2' },  // duplicate\n      { title: 'Lab Report', wordCount: 1500, id: '3' }\n    ];\n\n    it('removes duplicate briefs', () => {\n      const result = reconcile(briefs);\n      expect(result.length).toBeLessThan(briefs.length);\n    });\n\n    it('preserves unique briefs', () => {\n      const result = reconcile(briefs);\n      const titles = result.map(b => b.title);\n      expect(titles).toContain('Lab Report');\n    });\n\n    it('handles empty array', () => {\n      expect(reconcile([])).toEqual([]);\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "Tier 2 — Integration Test Gaps",
        "content": "\n",
        "level": 3
      },
      {
        "title": "8. EventBus → HistoryOfThought Pipeline",
        "content": "\n```js\n// tests/integration/EventPipeline.test.js\nimport { startEventBus, stopEventBus, recordTextEdit } from '../../src/core/EventBus.js';\nimport { unlockWithPassphrase, lockSession, listEvents } from '../../src/core/HistoryOfThought.js';\n\ndescribe('EventPipeline integration', () => {\n  const userId = 'pipeline-test-user';\n\n  beforeEach(async () => {\n    await unlockWithPassphrase('integration-pass');\n    startEventBus(() => ({ user_id: userId, stream_id: 'undergraduate', vaultUnlocked: true }));\n  });\n\n  afterEach(() => {\n    stopEventBus();\n    lockSession();\n  });\n\n  it('recordTextEdit results in an encrypted event in IndexedDB', async () => {\n    recordTextEdit({ sectionId: 'intro', wordsAfter: 150 });\n    await new Promise(r => setTimeout(r, 50)); // allow async write\n    const events = await listEvents({ user_id: userId, limit: 10 });\n    const textEdits = events.filter(e => e.event_type === 'text_edit');\n    expect(textEdits.length).toBeGreaterThan(0);\n  });\n\n  it('events are NOT written when vault is locked', async () => {\n    lockSession();\n    const before = (await listEvents({ user_id: userId, limit: 100 })).length;\n    startEventBus(() => ({ user_id: userId, stream_id: 'undergraduate', vaultUnlocked: false }));\n    recordTextEdit({ sectionId: 'body', wordsAfter: 200 });\n    await new Promise(r => setTimeout(r, 50));\n    const after = (await listEvents({ user_id: userId, limit: 100 })).length;\n    expect(after).toBe(before);\n  });\n});\n```\n\n",
        "level": 4
      },
      {
        "title": "9. Stream Hydration → Theme Application Pipeline",
        "content": "\n```js\n// tests/integration/StreamHydration.test.js\nimport { hydrate, applyTheme } from '../../src/core/SovereignRouter.js';\nimport { configureSpine } from '../../src/core/ExecutiveSpine.js';\n\ndescribe('StreamHydration integration', () => {\n  it('full hydrate → applyTheme → configureSpine pipeline does not throw', () => {\n    const profile = hydrate({ level: 'undergraduate' });\n    expect(() => applyTheme(profile.stream_id)).not.toThrow();\n    expect(() => configureSpine(profile)).not.toThrow();\n  });\n\n  it('hydrate with unknown level still produces a usable profile', () => {\n    const profile = hydrate({ level: 'alien' });\n    expect(profile.stream_id).toBeTruthy();\n    expect(() => applyTheme(profile.stream_id)).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 4
      },
      {
        "title": "Setup Required Before Running Tests",
        "content": "\nSince no test framework is installed, you'll need:\n\n```json\n// Add to package.json\n{\n  \"scripts\": {\n    \"test\": \"jest\",\n    \"test:coverage\": \"jest --coverage\"\n  },\n  \"devDependencies\": {\n    \"jest\": \"^29.7.0\",\n    \"@testing-library/react\": \"^14.0.0\",\n    \"@testing-library/jest-dom\": \"^6.1.4\",\n    \"jest-environment-jsdom\": \"^29.7.0\"\n  }\n}\n```\n\n```js\n// jest.config.js\nmodule.exports = {\n  testEnvironment: 'jsdom',\n  testMatch: ['**/tests/**/*.test.js'],\n  setupFilesAfterFramework: ['@testing-library/jest-dom'],\n  moduleNameMapper: { '\\\\.(css|svg)$': '<rootDir>/tests/__mocks__/fileMock.js' }\n};\n```\n\n---\n\n",
        "level": 2
      },
