        "code": "// tests/unit/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  getSectionHealth, setSectionHealth,\n  getCredits, earnCredits, spendCredits,\n  grantPlayTime, isPlayTimeActive,\n  startIdleDetection, stopIdleDetection\n} from '../../../src/core/ExecutiveSpine.js';\n\ndescribe('ExecutiveSpine', () => {\n  beforeEach(() => {\n    endFocusSession({ reason: 'test-reset' });\n    localStorage.clear();\n  });\n\n  describe('Focus session lifecycle', () => {\n    it('starts a session and reports as active', () => {\n      startFocusSession({ taskId: 'task-1', durationMinutes: 25 });\n      expect(isFocusActive()).toBe(true);\n    });\n\n    it('getFocusSession returns the active session', () => {\n      startFocusSession({ taskId: 'task-2', durationMinutes: 25 });\n      const session = getFocusSession();\n      expect(session.taskId).toBe('task-2');\n      expect(session.durationMinutes).toBe(25);\n    });\n\n    it('endFocusSession clears the active session', () => {\n      startFocusSession({ taskId: 'task-3', durationMinutes: 10 });\n      endFocusSession({ reason: 'completed' });\n      expect(isFocusActive()).toBe(false);\n    });\n\n    it('starting a second session while one is active replaces it', () => {\n      startFocusSession({ taskId: 'first', durationMinutes: 10 });\n      startFocusSession({ taskId: 'second', durationMinutes: 20 });\n      expect(getFocusSession().taskId).toBe('second');\n    });\n\n    it('startFocusSession with no taskId throws or defaults gracefully', () => {\n      expect(() => startFocusSession({})).not.toThrow();\n    });\n  });\n\n  describe('Section health', () => {\n    it('getSectionHealth returns 0 for unknown section', () => {\n      expect(getSectionHealth('unknown-section')).toBe(0);\n    });\n\n    it('setSectionHealth persists and retrieves dots', () => {\n      setSectionHealth('intro', 3);\n      expect(getSectionHealth('intro')).toBe(3);\n    });\n\n    it('setSectionHealth clamps at valid range', () => {\n      setSectionHealth('intro', 99);\n      expect(getSectionHealth('intro')).toBeLessThanOrEqual(5); // assuming max 5\n    });\n\n    it('setSectionHealth dispatches a CustomEvent', () => {\n      const listener = jest.fn();\n      window.addEventListener('section_health_change', listener);\n      setSectionHealth('intro', 2);\n      expect(listener).toHaveBeenCalled();\n      window.removeEventListener('section_health_change', listener);\n    });\n  });\n\n  describe('Credits system', () => {\n    it('getCredits starts at 0 or a known default', () => {\n      expect(typeof getCredits()).toBe('number');\n    });\n\n    it('earnCredits increases balance', () => {\n      const before = getCredits();\n      earnCredits(10);\n      expect(getCredits()).toBe(before + 10);\n    });\n\n    it('spendCredits decreases balance', () => {\n      earnCredits(20);\n      const before = getCredits();\n      spendCredits(5);\n      expect(getCredits()).toBe(before - 5);\n    });\n\n    it('spendCredits throws or returns false when insufficient', () => {\n      const current = getCredits();\n      expect(() => spendCredits(current + 9999)).toThrow();\n    });\n\n    it('earnCredits with negative amount throws', () => {\n      expect(() => earnCredits(-1)).toThrow();\n    });\n  });\n\n  describe('PlayTime', () => {\n    it('isPlayTimeActive returns false before any grant', () => {\n      expect(isPlayTimeActive()).toBe(false);\n    });\n\n    it('grantPlayTime activates playtime', () => {\n      grantPlayTime({ minutes: 5, reason: 'reward' });\n      expect(isPlayTimeActive()).toBe(true);\n    });\n  });\n\n  describe('Idle detection', () => {\n    it('startIdleDetection and stopIdleDetection do not throw', () => {\n      expect(() => startIdleDetection({ thresholdMs: 1000 })).not.toThrow();\n      expect(() => stopIdleDetection()).not.toThrow();\n    });\n  });\n});"
