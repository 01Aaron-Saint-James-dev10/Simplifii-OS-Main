    "codeBlocks": [
      {
        "language": "javascript",
        "code": "// tests/core/HistoryOfThought.test.js\nimport { isUnlocked, unlockWithPassphrase, lockSession, appendEvent, listEvents, generateAuthenticityReport } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought — vault lifecycle', () => {\n  beforeEach(() => lockSession());\n\n  test('isUnlocked() returns false before unlock', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlockWithPassphrase() derives key and sets locked=false', async () => {\n    await unlockWithPassphrase('correcthorse');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('rejects passphrase shorter than 4 chars', async () => {\n    await expect(unlockWithPassphrase('abc')).rejects.toThrow();\n  });\n\n  test('lockSession() clears derived key', async () => {\n    await unlockWithPassphrase('correcthorse');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('HistoryOfThought — appendEvent + listEvents', () => {\n  beforeEach(async () => { lockSession(); await unlockWithPassphrase('testpass'); });\n\n  test('appendEvent persists an encrypted event', async () => {\n    await appendEvent({ type: 'text_edit', userId: 'u1', payload: { section: 'intro' } });\n    const events = await listEvents({ userId: 'u1' });\n    expect(events).toHaveLength(1);\n    expect(events[0].type).toBe('text_edit');\n  });\n\n  test('appendEvent silently drops when vault is locked', async () => {\n    lockSession();\n    await expect(appendEvent({ type: 'text_edit', userId: 'u1', payload: {} })).resolves.not.toThrow();\n    // no throw — silent drop\n  });\n\n  test('appendEvent rejects unknown event types', async () => {\n    await expect(appendEvent({ type: 'INVALID_TYPE', userId: 'u1', payload: {} })).rejects.toThrow();\n  });\n\n  test('listEvents returns [] when locked', async () => {\n    lockSession();\n    const events = await listEvents({ userId: 'u1' });\n    expect(events).toEqual([]);\n  });\n\n  test('events encrypted with different passphrase are not readable', async () => {\n    await appendEvent({ type: 'text_edit', userId: 'u1', payload: { data: 'secret' } });\n    lockSession();\n    await unlockWithPassphrase('wrongpass');\n    const events = await listEvents({ userId: 'u1' });\n    expect(events).toHaveLength(0); // decrypt failure = empty\n  });\n\n  test('generateAuthenticityReport includes all event types', async () => {\n    await appendEvent({ type: 'focus_session_start', userId: 'u1', payload: {} });\n    await appendEvent({ type: 'text_edit', userId: 'u1', payload: { chars: 50 } });\n    const report = await generateAuthenticityReport({ userId: 'u1' });\n    expect(report.events).toHaveLength(2);\n    expect(report.deviceSignature).toBeTruthy();\n  });\n});"
      },
      {
        "language": "javascript",
        "code": "// tests/core/ExecutiveSpine.test.js\nimport {\n  configureSpine, startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  startIdleDetection, stopIdleDetection,\n  getSectionHealth, setSectionHealth,\n  grantPlayTime, isPlayTimeActive,\n  getCredits, earnCredits, spendCredits\n} from '../../src/core/ExecutiveSpine';\n\nbeforeEach(() => {\n  localStorage.clear();\n  jest.useFakeTimers();\n});\nafterEach(() => jest.useRealTimers());\n\ndescribe('FocusSession', () => {\n  test('isFocusActive() is false before start', () => {\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('startFocusSession() activates session', () => {\n    startFocusSession({ durationMs: 25 * 60_000, userId: 'u1' });\n    expect(isFocusActive()).toBe(true);\n  });\n\n  test('endFocusSession() deactivates and dispatches event', () => {\n    const listener = jest.fn();\n    window.addEventListener('simplifii:focus_end', listener);\n    startFocusSession({ durationMs: 25 * 60_000, userId: 'u1' });\n    endFocusSession({ userId: 'u1' });\n    expect(isFocusActive()).toBe(false);\n    expect(listener).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:focus_end', listener);\n  });\n\n  test('session auto-expires after durationMs', () => {\n    startFocusSession({ durationMs: 1000, userId: 'u1' });\n    jest.advanceTimersByTime(1001);\n    expect(isFocusActive()).toBe(false);\n  });\n});\n\ndescribe('SectionHealth', () => {\n  test('getSectionHealth returns 0 for unknown section', () => {\n    expect(getSectionHealth('unknown')).toBe(0);\n  });\n\n  test('setSectionHealth clamps to 0-5', () => {\n    setSectionHealth('intro', 10);\n    expect(getSectionHealth('intro')).toBe(5);\n    setSectionHealth('intro', -3);\n    expect(getSectionHealth('intro')).toBe(0);\n  });\n\n  test('setSectionHealth dispatches section_health_change event', () => {\n    const listener = jest.fn();\n    window.addEventListener('simplifii:section_health_change', listener);\n    setSectionHealth('intro', 3);\n    expect(listener).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:section_health_change', listener);\n  });\n\n  test('reaching unlock threshold grants PlayTime automatically', () => {\n    configureSpine({ unlockThreshold: 3 });\n    setSectionHealth('intro', 3);\n    expect(isPlayTimeActive()).toBe(true);\n  });\n});\n\ndescribe('SovereignCredits', () => {\n  test('earnCredits increases balance', () => {\n    earnCredits(10, 'test');\n    expect(getCredits()).toBe(10);\n  });\n\n  test('spendCredits decreases balance', () => {\n    earnCredits(20, 'setup');\n    spendCredits(5, 'test');\n    expect(getCredits()).toBe(15);\n  });\n\n  test('spendCredits cannot go below zero', () => {\n    spendCredits(9999, 'test');\n    expect(getCredits()).toBe(0);\n  });\n});\n\ndescribe('IdleDetection', () => {\n  test('startIdleDetection fires simplifii:idle after threshold', () => {\n    const listener = jest.fn();\n    window.addEventListener('simplifii:idle', listener);\n    startIdleDetection({ thresholdMs: 180_000 });\n    jest.advanceTimersByTime(181_000);\n    expect(listener).toHaveBeenCalled();\n    stopIdleDetection();\n    window.removeEventListener('simplifii:idle', listener);\n  });\n});"
      },
      {
        "language": "javascript",
        "code": "// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation, pickSafePayload } from '../../src/core/EventBus';\n\nconst makeContext = (locked = false) => () => ({ isUnlocked: !locked, userId: 'u1' });\n\ndescribe('pickSafePayload', () => {\n  test('text_edit strips raw content field', () => {\n    const result = pickSafePayload('text_edit', { chars: 50, rawContent: 'secret' });\n    expect(result).not.toHaveProperty('rawContent');\n    expect(result.chars).toBe(50);\n  });\n\n  test('returns empty object for unknown event type', () => {\n    const result = pickSafePayload('UNKNOWN', { data: 'x' });\n    expect(result).toEqual({});\n  });\n});\n\ndescribe('EventBus lifecycle', () => {\n  afterEach(() => stopEventBus());\n\n  test('startEventBus does not throw', () => {\n    expect(() => startEventBus(makeContext())).not.toThrow();\n  });\n\n  test('calling startEventBus twice does not double-register', () => {\n    const appendSpy = jest.fn();\n    startEventBus(makeContext());\n    startEventBus(makeContext()); // second call should be idempotent\n    window.dispatchEvent(new CustomEvent('simplifii:text_edit', { detail: { chars: 5 } }));\n    // verify appendSpy called once, not twice — mock HistoryOfThought.appendEvent\n  });\n\n  test('stops listening after stopEventBus()', () => {\n    startEventBus(makeContext());\n    stopEventBus();\n    // dispatching after stop should not trigger processing\n    expect(() => window.dispatchEvent(new CustomEvent('simplifii:text_edit', { detail: {} }))).not.toThrow();\n  });\n});\n\ndescribe('EventBus vault-locked behaviour', () => {\n  test('events are silently dropped when vault is locked', async () => {\n    // mock HistoryOfThought.appendEvent and check it's NOT called when locked\n    startEventBus(makeContext(true)); // locked context\n    window.dispatchEvent(new CustomEvent('simplifii:text_edit', { detail: { chars: 10 } }));\n    // assert appendEvent mock was not called\n  });\n});"
      },
