  "output": "## Test Coverage Analysis: Simplifii-OS_Master\n\n**Critical Finding: 0% test coverage across the entire codebase.**\n\nNo test files exist, no testing framework is configured, and no Jest/Vitest setup is present. Here's a prioritised breakdown with skeletons.\n\n---\n\n## Priority 1: Cryptographic Core (HistoryOfThought.js)\n\nHighest risk — untested encryption handling student vault data.\n\n```javascript\n// tests/core/HistoryOfThought.test.js\nimport { isUnlocked, unlockWithPassphrase, lockSession, appendEvent, listEvents, generateAuthenticityReport } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought — vault lifecycle', () => {\n  beforeEach(() => lockSession());\n\n  test('isUnlocked() returns false before unlock', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlockWithPassphrase() derives key and sets locked=false', async () => {\n    await unlockWithPassphrase('correcthorse');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('rejects passphrase shorter than 4 chars', async () => {\n    await expect(unlockWithPassphrase('abc')).rejects.toThrow();\n  });\n\n  test('lockSession() clears derived key', async () => {\n    await unlockWithPassphrase('correcthorse');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('HistoryOfThought — appendEvent + listEvents', () => {\n  beforeEach(async () => { lockSession(); await unlockWithPassphrase('testpass'); });\n\n  test('appendEvent persists an encrypted event', async () => {\n    await appendEvent({ type: 'text_edit', userId: 'u1', payload: { section: 'intro' } });\n    const events = await listEvents({ userId: 'u1' });\n    expect(events).toHaveLength(1);\n    expect(events[0].type).toBe('text_edit');\n  });\n\n  test('appendEvent silently drops when vault is locked', async () => {\n    lockSession();\n    await expect(appendEvent({ type: 'text_edit', userId: 'u1', payload: {} })).resolves.not.toThrow();\n    // no throw — silent drop\n  });\n\n  test('appendEvent rejects unknown event types', async () => {\n    await expect(appendEvent({ type: 'INVALID_TYPE', userId: 'u1', payload: {} })).rejects.toThrow();\n  });\n\n  test('listEvents returns [] when locked', async () => {\n    lockSession();\n    const events = await listEvents({ userId: 'u1' });\n    expect(events).toEqual([]);\n  });\n\n  test('events encrypted with different passphrase are not readable', async () => {\n    await appendEvent({ type: 'text_edit', userId: 'u1', payload: { data: 'secret' } });\n    lockSession();\n    await unlockWithPassphrase('wrongpass');\n    const events = await listEvents({ userId: 'u1' });\n    expect(events).toHaveLength(0); // decrypt failure = empty\n  });\n\n  test('generateAuthenticityReport includes all event types', async () => {\n    await appendEvent({ type: 'focus_session_start', userId: 'u1', payload: {} });\n    await appendEvent({ type: 'text_edit', userId: 'u1', payload: { chars: 50 } });\n    const report = await generateAuthenticityReport({ userId: 'u1' });\n    expect(report.events).toHaveLength(2);\n    expect(report.deviceSignature).toBeTruthy();\n  });\n});\n```\n\n---\n\n## Priority 2: ExecutiveSpine.js\n\nState persistence and event dispatch are untested for all 5 sub-systems.\n\n```javascript\n// tests/core/ExecutiveSpine.test.js\nimport {\n  configureSpine, startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  startIdleDetection, stopIdleDetection,\n  getSectionHealth, setSectionHealth,\n  grantPlayTime, isPlayTimeActive,\n  getCredits, earnCredits, spendCredits\n} from '../../src/core/ExecutiveSpine';\n\nbeforeEach(() => {\n  localStorage.clear();\n  jest.useFakeTimers();\n});\nafterEach(() => jest.useRealTimers());\n\ndescribe('FocusSession', () => {\n  test('isFocusActive() is false before start', () => {\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('startFocusSession() activates session', () => {\n    startFocusSession({ durationMs: 25 * 60_000, userId: 'u1' });\n    expect(isFocusActive()).toBe(true);\n  });\n\n  test('endFocusSession() deactivates and dispatches event', () => {\n    const listener = jest.fn();\n    window.addEventListener('simplifii:focus_end', listener);\n    startFocusSession({ durationMs: 25 * 60_000, userId: 'u1' });\n    endFocusSession({ userId: 'u1' });\n    expect(isFocusActive()).toBe(false);\n    expect(listener).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:focus_end', listener);\n  });\n\n  test('session auto-expires after durationMs', () => {\n    startFocusSession({ durationMs: 1000, userId: 'u1' });\n    jest.advanceTimersByTime(1001);\n    expect(isFocusActive()).toBe(false);\n  });\n});\n\ndescribe('SectionHealth', () => {\n  test('getSectionHealth returns 0 for unknown section', () => {\n    expect(getSectionHealth('unknown')).toBe(0);\n  });\n\n  test('setSectionHealth clamps to 0-5', () => {\n    setSectionHealth('intro', 10);\n    expect(getSectionHealth('intro')).toBe(5);\n    setSectionHealth('intro', -3);\n    expect(getSectionHealth('intro')).toBe(0);\n  });\n\n  test('setSectionHealth dispatches section_health_change event', () => {\n    const listener = jest.fn();\n    window.addEventListener('simplifii:section_health_change', listener);\n    setSectionHealth('intro', 3);\n    expect(listener).toHaveBeenCalledTimes(1);\n    window.removeEventListener('simplifii:section_health_change', listener);\n  });\n\n  test('reaching unlock threshold grants PlayTime automatically', () => {\n    configureSpine({ unlockThreshold: 3 });\n    setSectionHealth('intro', 3);\n    expect(isPlayTimeActive()).toBe(true);\n  });\n});\n\ndescribe('SovereignCredits', () => {\n  test('earnCredits increases balance', () => {\n    earnCredits(10, 'test');\n    expect(getCredits()).toBe(10);\n  });\n\n  test('spendCredits decreases balance', () => {\n    earnCredits(20, 'setup');\n    spendCredits(5, 'test');\n    expect(getCredits()).toBe(15);\n  });\n\n  test('spendCredits cannot go below zero', () => {\n    spendCredits(9999, 'test');\n    expect(getCredits()).toBe(0);\n  });\n});\n\ndescribe('IdleDetection', () => {\n  test('startIdleDetection fires simplifii:idle after threshold', () => {\n    const listener = jest.fn();\n    window.addEventListener('simplifii:idle', listener);\n    startIdleDetection({ thresholdMs: 180_000 });\n    jest.advanceTimersByTime(181_000);\n    expect(listener).toHaveBeenCalled();\n    stopIdleDetection();\n    window.removeEventListener('simplifii:idle', listener);\n  });\n});\n```\n\n---\n\n## Priority 3: EventBus.js\n\nSilent vault-locked drops are unverified; listener lifecycle has no tests.\n\n```javascript\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation, pickSafePayload } from '../../src/core/EventBus';\n\nconst makeContext = (locked = false) => () => ({ isUnlocked: !locked, userId: 'u1' });\n\ndescribe('pickSafePayload', () => {\n  test('text_edit strips raw content field', () => {\n    const result = pickSafePayload('text_edit', { chars: 50, rawContent: 'secret' });\n    expect(result).not.toHaveProperty('rawContent');\n    expect(result.chars).toBe(50);\n  });\n\n  test('returns empty object for unknown event type', () => {\n    const result = pickSafePayload('UNKNOWN', { data: 'x' });\n    expect(result).toEqual({});\n  });\n});\n\ndescribe('EventBus lifecycle', () => {\n  afterEach(() => stopEventBus());\n\n  test('startEventBus does not throw', () => {\n    expect(() => startEventBus(makeContext())).not.toThrow();\n  });\n\n  test('calling startEventBus twice does not double-register', () => {\n    const appendSpy = jest.fn();\n    startEventBus(makeContext());\n    startEventBus(makeContext()); // second call should be idempotent\n    window.dispatchEvent(new CustomEvent('simplifii:text_edit', { detail: { chars: 5 } }));\n    // verify appendSpy called once, not twice — mock HistoryOfThought.appendEvent\n  });\n\n  test('stops listening after stopEventBus()', () => {\n    startEventBus(makeContext());\n    stopEventBus();\n    // dispatching after stop should not trigger processing\n    expect(() => window.dispatchEvent(new CustomEvent('simplifii:text_edit', { detail: {} }))).not.toThrow();\n  });\n});\n\ndescribe('EventBus vault-locked behaviour', () => {\n  test('events are silently dropped when vault is locked', async () => {\n    // mock HistoryOfThought.appendEvent and check it's NOT called when locked\n    startEventBus(makeContext(true)); // locked context\n    window.dispatchEvent(new CustomEvent('simplifii:text_edit', { detail: { chars: 10 } }));\n    // assert appendEvent mock was not called\n  });\n});\n```\n\n---\n\n## Priority 4: SovereignRouter.js\n\n```javascript\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, __internals } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test.each([\n    ['undergraduate', 'tertiary'],\n    ['highschool', 'secondary'],\n    ['primary', 'primary'],\n    ['tafe', 'tafe'],\n    ['homeschool', 'homeschool'],\n  ])('maps %s → %s', (input, expected) => {\n    expect(streamFromLevel(input)).toBe(expected);\n  });\n\n  test('returns \"tertiary\" for unknown level (safe default)', () => {\n    expect(streamFromLevel('bogus')).toBe('tertiary');\n  });\n\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('UNDERGRADUATE')).toBe('tertiary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test.each(['primary','secondary','tertiary','tafe','homeschool'])('%s is valid', (id) => {\n    expect(isValidStream(id)).toBe(true);\n  });\n\n  test('rejects unknown stream id', () => {\n    expect(isValidStream('invalid')).toBe(false);\n  });\n\n  test('rejects null/undefined', () => {\n    expect(isValidStream(null)).toBe(false);\n    expect(isValidStream(undefined)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('merges stream profile into session', () => {\n    const result = hydrate({ level: 'undergraduate', userId: 'u1' });\n    expect(result.stream).toBe('tertiary');\n    expect(result.userId).toBe('u1');\n  });\n\n  test('handles missing level (falls back to tertiary)', () => {\n    const result = hydrate({ userId: 'u2' });\n    expect(result.stream).toBe('tertiary');\n  });\n\n  test('handles null session gracefully', () => {\n    expect(() => hydrate(null)).not.toThrow();\n  });\n});\n```\n\n---\n\n## Priority 5: LiteralMode.js\n\n```javascript\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../../src/core/LiteralMode';\nconst { PATTERNS, sanitiseDashes } = __internals;\n\ndescribe('literalise', () => {\n  test('returns empty string for empty input', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  test('returns input unchanged when no patterns match', () => {\n    const plain = 'the cat sat on the mat';\n    expect(literalise(plain)).toBe(plain);\n  });\n\n  test('replaces academic phrases with plain English', () => {\n    const out = literalise('It is imperative that students submit by Friday.');\n    expect(out).not.toContain('It is imperative');\n  });\n\n  test('sanitiseDashes converts em-dash to comma', () => {\n    expect(sanitiseDashes('this — that')).toBe('this, that');\n  });\n\n  test('handles null input without throwing', () => {\n    expect(() => literalise(null)).not.toThrow();\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('returns true when userPreference is literal', () => {\n    expect(shouldLiteralise({}, 'literal')).toBe(true);\n  });\n\n  test('returns false when userPreference is academic', () => {\n    expect(shouldLiteralise({}, 'academic')).toBe(false);\n  });\n});\n\ndescribe('PATTERNS array', () => {\n  test('each pattern has regex and replacement', () => {\n    PATTERNS.forEach((p, i) => {\n      expect(p.pattern).toBeInstanceOf(RegExp);\n      expect(typeof p.replacement).toBe('string');\n    });\n  });\n});\n```\n\n---\n\n## Priority 6: SovereignReconciler.js (Integration Gap)\n\n```javascript\n// tests/services/SovereignReconciler.test.js\nimport { normaliseTitle, tokenSimilarity, reconcile } from '../../src/services/SovereignReconciler';\n\ndescribe('normaliseTitle', () => {\n  test.each([\n    ['Part A: Introduction', 'introduction'],\n    ['Section II - Methods', 'methods'],\n    ['CHAPTER 3: Results', 'results'],\n    ['  Extra   Spaces  ', 'extra spaces'],\n  ])('normalises %s', (input, expected) => {\n    expect(normaliseTitle(input)).toBe(expected);\n  });\n});\n\ndescribe('tokenSimilarity', () => {\n  test('identical strings = 1.0', () => expect(tokenSimilarity('abc', 'abc')).toBe(1));\n  test('disjoint strings = 0.0', () => expect(tokenSimilarity('abc', 'xyz')).toBe(0));\n  test('partial overlap between 0 and 1', () => {\n    const sim = tokenSimilarity('literature review', 'lit review');\n    expect(sim).toBeGreaterThan(0);\n    expect(sim).toBeLessThan(1);\n  });\n});\n\ndescribe('reconcile', () => {\n  test('deduplicates sections with similarity > 0.6', () => {\n    const input = [\n      { title: 'Literature Review', source: 'rubric' },\n      { title: 'Lit Review', source: 'brief' },\n    ];\n    const result = reconcile(input);\n    expect(result).toHaveLength(1);\n    expect(result[0].source).toBe('rubric'); // rubric wins\n  });\n\n  test('preserves distinct sections', () => {\n    const input = [\n      { title: 'Introduction', source: 'rubric' },\n      { title: 'Conclusion', source: 'rubric' },\n    ];\n    expect(reconcile(input)).toHaveLength(2);\n  });\n\n  test('assigns canonical GREEK IDs', () => {\n    const input = [{ title: 'Methods', source: 'outline' }];\n    const result = reconcile(input);\n    expect(result[0].id).toMatch(/^[A-Z]+$/); // ALPHA, BETA, etc.\n  });\n});\n```\n\n---\n\n## Priority 7: Integration Test Gaps\n\nThe entire onboarding-to-vault flow has zero integration tests:\n\n```javascript\n// tests/integration/onboarding-flow.test.js\n// Requires: jest-environment-jsdom, fake-indexeddb\nimport { render, screen, fireEvent, waitFor } from '@testing-library/react';\nimport App from '../../src/App';\n\ndescribe('Onboarding → Vault unlock flow', () => {\n  test('new user can complete onboarding and create vault', async () => {\n    render(<App />);\n    // Step 1: onboarding renders\n    expect(screen.getByText(/Welcome/i)).toBeInTheDocument();\n    // Step 2: user selects level\n    fireEvent.click(screen.getByText(/Undergraduate/i));\n    // Step 3: user sets passphrase\n    fireEvent.change(screen.getByLabelText(/Passphrase/i), { target: { value: 'testpass123' } });\n    fireEvent.click(screen.getByText(/Unlock Vault/i));\n    // Step 4: vault unlocks, cockpit renders\n    await waitFor(() => expect(screen.getByTestId('master-dashboard')).toBeInTheDocument());\n  });\n\n  test('wrong passphrase shows error, does not unlock', async () => {\n    // ... setup with existing vault ...\n    // attempt unlock with wrong pass\n    // assert vault remains locked\n  });\n});\n```\n\n---\n\n## Setup Required\n\nNo testing infrastructure exists. Add this to get started:\n\n```bash\n# Add to package.json devDependencies\nnpm install --save-dev jest @testing-library/react @testing-library/jest-dom\nnpm install --save-dev fake-indexeddb jest-environment-jsdom\n```\n\n```json\n// package.json additions\n{\n  \"jest\": {\n    \"testEnvironment\": \"jsdom\",\n    \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\"],\n    \"coverageThreshold\": {\n      \"global\": { \"branches\": 70, \"functions\": 70, \"lines\": 70 }\n    }\n  }\n}\n```\n\n---\n\n## Gap Summary\n\n| Layer | Files | Key Risk |\n|---|---|---|\n| Crypto (HistoryOfThought) | 1 | Silent data loss, wrong-key decryption |\n| State (ExecutiveSpine) | 1 | Credit/health clamping bugs, timer leaks |\n| Events (EventBus) | 1 | Double-listener, dropped events unverified |\n| Routing (SovereignRouter) | 1 | Bad stream fallback corrupts sessio