        "content": "\n```javascript\n// tests/core/SovereignRouter.test.js\nimport { streamFromLevel, isValidStream, hydrate, __internals } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test.each([\n    ['undergraduate', 'tertiary'],\n    ['highschool', 'secondary'],\n    ['primary', 'primary'],\n    ['tafe', 'tafe'],\n    ['homeschool', 'homeschool'],\n  ])('maps %s → %s', (input, expected) => {\n    expect(streamFromLevel(input)).toBe(expected);\n  });\n\n  test('returns \"tertiary\" for unknown level (safe default)', () => {\n    expect(streamFromLevel('bogus')).toBe('tertiary');\n  });\n\n  test('is case-insensitive', () => {\n    expect(streamFromLevel('UNDERGRADUATE')).toBe('tertiary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test.each(['primary','secondary','tertiary','tafe','homeschool'])('%s is valid', (id) => {\n    expect(isValidStream(id)).toBe(true);\n  });\n\n  test('rejects unknown stream id', () => {\n    expect(isValidStream('invalid')).toBe(false);\n  });\n\n  test('rejects null/undefined', () => {\n    expect(isValidStream(null)).toBe(false);\n    expect(isValidStream(undefined)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('merges stream profile into session', () => {\n    const result = hydrate({ level: 'undergraduate', userId: 'u1' });\n    expect(result.stream).toBe('tertiary');\n    expect(result.userId).toBe('u1');\n  });\n\n  test('handles missing level (falls back to tertiary)', () => {\n    const result = hydrate({ userId: 'u2' });\n    expect(result.stream).toBe('tertiary');\n  });\n\n  test('handles null session gracefully', () => {\n    expect(() => hydrate(null)).not.toThrow();\n  });\n});\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "Priority 5: LiteralMode.js",
        "content": "\n```javascript\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../../src/core/LiteralMode';\nconst { PATTERNS, sanitiseDashes } = __internals;\n\ndescribe('literalise', () => {\n  test('returns empty string for empty input', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  test('returns input unchanged when no patterns match', () => {\n    const plain = 'the cat sat on the mat';\n    expect(literalise(plain)).toBe(plain);\n  });\n\n  test('replaces academic phrases with plain English', () => {\n    const out = literalise('It is imperative that students submit by Friday.');\n    expect(out).not.toContain('It is imperative');\n  });\n\n  test('sanitiseDashes converts em-dash to comma', () => {\n    expect(sanitiseDashes('this — that')).toBe('this, that');\n  });\n\n  test('handles null input without throwing', () => {\n    expect(() => literalise(null)).not.toThrow();\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('returns true when userPreference is literal', () => {\n    expect(shouldLiteralise({}, 'literal')).toBe(true);\n  });\n\n  test('returns false when userPreference is academic', () => {\n    expect(shouldLiteralise({}, 'academic')).toBe(false);\n  });\n});\n\ndescribe('PATTERNS array', () => {\n  test('each pattern has regex and replacement', () => {\n    PATTERNS.forEach((p, i) => {\n      expect(p.pattern).toBeInstanceOf(RegExp);\n      expect(typeof p.replacement).toBe('string');\n    });\n  });\n});\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "Priority 6: SovereignReconciler.js (Integration Gap)",
        "content": "\n```javascript\n// tests/services/SovereignReconciler.test.js\nimport { normaliseTitle, tokenSimilarity, reconcile } from '../../src/services/SovereignReconciler';\n\ndescribe('normaliseTitle', () => {\n  test.each([\n    ['Part A: Introduction', 'introduction'],\n    ['Section II - Methods', 'methods'],\n    ['CHAPTER 3: Results', 'results'],\n    ['  Extra   Spaces  ', 'extra spaces'],\n  ])('normalises %s', (input, expected) => {\n    expect(normaliseTitle(input)).toBe(expected);\n  });\n});\n\ndescribe('tokenSimilarity', () => {\n  test('identical strings = 1.0', () => expect(tokenSimilarity('abc', 'abc')).toBe(1));\n  test('disjoint strings = 0.0', () => expect(tokenSimilarity('abc', 'xyz')).toBe(0));\n  test('partial overlap between 0 and 1', () => {\n    const sim = tokenSimilarity('literature review', 'lit review');\n    expect(sim).toBeGreaterThan(0);\n    expect(sim).toBeLessThan(1);\n  });\n});\n\ndescribe('reconcile', () => {\n  test('deduplicates sections with similarity > 0.6', () => {\n    const input = [\n      { title: 'Literature Review', source: 'rubric' },\n      { title: 'Lit Review', source: 'brief' },\n    ];\n    const result = reconcile(input);\n    expect(result).toHaveLength(1);\n    expect(result[0].source).toBe('rubric'); // rubric wins\n  });\n\n  test('preserves distinct sections', () => {\n    const input = [\n      { title: 'Introduction', source: 'rubric' },\n      { title: 'Conclusion', source: 'rubric' },\n    ];\n    expect(reconcile(input)).toHaveLength(2);\n  });\n\n  test('assigns canonical GREEK IDs', () => {\n    const input = [{ title: 'Methods', source: 'outline' }];\n    const result = reconcile(input);\n    expect(result[0].id).toMatch(/^[A-Z]+$/); // ALPHA, BETA, etc.\n  });\n});\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "Priority 7: Integration Test Gaps",
        "content": "\nThe entire onboarding-to-vault flow has zero integration tests:\n\n```javascript\n// tests/integration/onboarding-flow.test.js\n// Requires: jest-environment-jsdom, fake-indexeddb\nimport { render, screen, fireEvent, waitFor } from '@testing-library/react';\nimport App from '../../src/App';\n\ndescribe('Onboarding → Vault unlock flow', () => {\n  test('new user can complete onboarding and create vault', async () => {\n    render(<App />);\n    // Step 1: onboarding renders\n    expect(screen.getByText(/Welcome/i)).toBeInTheDocument();\n    // Step 2: user selects level\n    fireEvent.click(screen.getByText(/Undergraduate/i));\n    // Step 3: user sets passphrase\n    fireEvent.change(screen.getByLabelText(/Passphrase/i), { target: { value: 'testpass123' } });\n    fireEvent.click(screen.getByText(/Unlock Vault/i));\n    // Step 4: vault unlocks, cockpit renders\n    await waitFor(() => expect(screen.getByTestId('master-dashboard')).toBeInTheDocument());\n  });\n\n  test('wrong passphrase shows error, does not unlock', async () => {\n    // ... setup with existing vault ...\n    // attempt unlock with wrong pass\n    // assert vault remains locked\n  });\n});\n```\n\n---\n\n",
