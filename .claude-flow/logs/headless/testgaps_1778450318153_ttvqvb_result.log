        "code": "// tests/core/HistoryOfThought.test.js\nimport 'fake-indexeddb/auto';\nimport { unlockWithPassphrase, appendEvent, listEvents, isUnlocked, lockSession } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought', () => {\n  beforeEach(() => lockSession());\n\n  test('rejects passphrases under 4 chars', async () => {\n    await expect(unlockWithPassphrase('abc')).rejects.toThrow();\n  });\n\n  test('unlocks with valid passphrase', async () => {\n    await unlockWithPassphrase('correct-passphrase');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('silently drops events when vault is locked', async () => {\n    await appendEvent({ type: 'focus_session_start', ts: Date.now() });\n    const events = await listEvents();\n    expect(events).toHaveLength(0); // must drop, never throw\n  });\n\n  test('appends and decrypts event when unlocked', async () => {\n    await unlockWithPassphrase('testpass');\n    await appendEvent({ type: 'text_edit', payload: { blockId: 'b1' } });\n    const events = await listEvents();\n    expect(events[0].type).toBe('text_edit');\n  });\n\n  test('handles corrupted encrypted blob without throwing', async () => {\n    await unlockWithPassphrase('testpass');\n    // manually corrupt a record via fake-indexeddb, then listEvents\n    // expect graceful skip or error event, not unhandled rejection\n  });\n\n  test('nonces are unique across concurrent appends', async () => {\n    await unlockWithPassphrase('testpass');\n    await Promise.all([\n      appendEvent({ type: 'a' }),\n      appendEvent({ type: 'b' }),\n      appendEvent({ type: 'c' }),\n    ]);\n    const events = await listEvents();\n    const nonces = events.map(e => e._nonce);\n    expect(new Set(nonces).size).toBe(nonces.length);\n  });\n});"
