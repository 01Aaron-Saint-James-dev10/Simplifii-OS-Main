  "output": "## Test Coverage Analysis: Simplifii-OS\n\n**Current coverage: 0%** — No test files, no test framework configured, 76 untested source files.\n\n---\n\n## Priority 1: Cryptographic & Data Integrity\n\n### `src/core/HistoryOfThought.js` — Critical (AES-GCM + PBKDF2)\n\n```js\n// tests/core/HistoryOfThought.test.js\nimport 'fake-indexeddb/auto';\nimport { unlockWithPassphrase, appendEvent, listEvents, isUnlocked, lockSession } from '../../src/core/HistoryOfThought';\n\ndescribe('HistoryOfThought', () => {\n  beforeEach(() => lockSession());\n\n  test('rejects passphrases under 4 chars', async () => {\n    await expect(unlockWithPassphrase('abc')).rejects.toThrow();\n  });\n\n  test('unlocks with valid passphrase', async () => {\n    await unlockWithPassphrase('correct-passphrase');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('silently drops events when vault is locked', async () => {\n    await appendEvent({ type: 'focus_session_start', ts: Date.now() });\n    const events = await listEvents();\n    expect(events).toHaveLength(0); // must drop, never throw\n  });\n\n  test('appends and decrypts event when unlocked', async () => {\n    await unlockWithPassphrase('testpass');\n    await appendEvent({ type: 'text_edit', payload: { blockId: 'b1' } });\n    const events = await listEvents();\n    expect(events[0].type).toBe('text_edit');\n  });\n\n  test('handles corrupted encrypted blob without throwing', async () => {\n    await unlockWithPassphrase('testpass');\n    // manually corrupt a record via fake-indexeddb, then listEvents\n    // expect graceful skip or error event, not unhandled rejection\n  });\n\n  test('nonces are unique across concurrent appends', async () => {\n    await unlockWithPassphrase('testpass');\n    await Promise.all([\n      appendEvent({ type: 'a' }),\n      appendEvent({ type: 'b' }),\n      appendEvent({ type: 'c' }),\n    ]);\n    const events = await listEvents();\n    const nonces = events.map(e => e._nonce);\n    expect(new Set(nonces).size).toBe(nonces.length);\n  });\n});\n```\n\n---\n\n### `src/core/ExecutiveSpine.js` — Focus sessions, localStorage failure\n\n```js\n// tests/core/ExecutiveSpine.test.js\nimport 'jest-localstorage-mock';\nimport {\n  startFocusSession, endFocusSession, isFocusActive,\n  setSectionHealth, getSectionHealth,\n  earnCredits, spendCredits, getCredits,\n} from '../../src/core/ExecutiveSpine';\n\ndescribe('FocusSession', () => {\n  beforeEach(() => { endFocusSession('reset'); jest.useFakeTimers(); });\n  afterEach(() => jest.useRealTimers());\n\n  test('starts and reports active session', () => {\n    startFocusSession({ durationMinutes: 25 });\n    expect(isFocusActive()).toBe(true);\n  });\n\n  test('auto-expires after configured duration', () => {\n    startFocusSession({ durationMinutes: 1 });\n    jest.advanceTimersByTime(60_001);\n    expect(isFocusActive()).toBe(false);\n  });\n\n  test('ignores concurrent startFocusSession calls', () => {\n    startFocusSession({ durationMinutes: 25 });\n    expect(() => startFocusSession({ durationMinutes: 10 })).not.toThrow();\n    expect(isFocusActive()).toBe(true);\n  });\n});\n\ndescribe('SectionHealth', () => {\n  test('clamps dots to [0, 5]', () => {\n    setSectionHealth('s1', -3);\n    expect(getSectionHealth('s1')).toBe(0);\n    setSectionHealth('s1', 99);\n    expect(getSectionHealth('s1')).toBe(5);\n  });\n\n  test('survives localStorage failure', () => {\n    localStorage.setItem.mockImplementationOnce(() => { throw new Error('QuotaExceeded'); });\n    expect(() => setSectionHealth('s1', 3)).not.toThrow();\n  });\n});\n\ndescribe('SovereignCredits', () => {\n  test('cannot go below zero', () => {\n    spendCredits(9999, 'test');\n    expect(getCredits()).toBeGreaterThanOrEqual(0);\n  });\n});\n```\n\n---\n\n## Priority 2: Text Transformation\n\n### `src/core/LiteralMode.js` — 26 regex patterns\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('literalise()', () => {\n  const cases = [\n    ['consider revising your argument', 'change your argument'],\n    ['you should synthesize the literature', 'you should combine ideas from the literature'],\n    ['this demonstrates the concept', 'this shows the concept'],\n    ['moreover, the evidence', 'also, the evidence'],\n  ];\n\n  test.each(cases)('transforms \"%s\"', (input, expected) => {\n    expect(literalise(input)).toBe(expected);\n  });\n\n  test('returns empty string for empty input', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  test('handles null input without throwing', () => {\n    expect(() => literalise(null)).not.toThrow();\n  });\n\n  test('normalises em-dashes to hyphens', () => {\n    expect(literalise('word\\u2014word')).toContain('word-word');\n  });\n\n  test('does not transform when shouldLiteralise returns false', () => {\n    const text = 'consider revising';\n    expect(literalise(text, { force: false, streamProfile: { literalMode: false } }))\n      .toBe(text);\n  });\n});\n```\n\n---\n\n### `src/services/BriefService.js` — Regex extraction\n\n```js\n// tests/services/BriefService.test.js\nimport { extractDeepCourseData, mapToWorkspace } from '../../src/services/BriefService';\n\ndescribe('extractDeepCourseData()', () => {\n  test('extracts learning outcomes with LO prefix', () => {\n    const text = 'LO1: Analyse the key concepts of research methodology.';\n    const result = extractDeepCourseData(text);\n    expect(result.learningOutcomes).toContain('Analyse the key concepts of research methodology');\n  });\n\n  test('ignores LO outcome under 10 chars', () => {\n    const text = 'LO1: Short.';\n    const result = extractDeepCourseData(text);\n    expect(result.learningOutcomes).toHaveLength(0);\n  });\n\n  test('detects Harvard referencing', () => {\n    const result = extractDeepCourseData('You must use Harvard referencing style.');\n    expect(result.referencingStyle).toBe('Harvard');\n  });\n\n  test('parses evidence formula word numbers', () => {\n    const result = extractDeepCourseData('You need two primary articles.');\n    expect(result.evidenceFormula?.primaryCount).toBe(2);\n  });\n\n  test('returns empty arrays for missing fields on blank input', () => {\n    const result = extractDeepCourseData('');\n    expect(result.learningOutcomes).toEqual([]);\n  });\n});\n\ndescribe('mapToWorkspace()', () => {\n  test('generates 7 sections for tertiary level', () => {\n    const ws = mapToWorkspace('some brief text', 'tertiary');\n    expect(ws.sections).toHaveLength(7);\n  });\n});\n```\n\n---\n\n## Priority 3: EventBus — Silent Drop Rule\n\n```js\n// tests/core/EventBus.test.js\nimport 'fake-indexeddb/auto';\nimport { startEventBus, stopEventBus } from '../../src/core/EventBus';\nimport { listEvents, isUnlocked } from '../../src/core/HistoryOfThought';\n\ndescribe('EventBus silent drop', () => {\n  beforeEach(() => startEventBus(() => ({ userId: 'u1' })));\n  afterEach(() => stopEventBus());\n\n  test('drops focus-start event when vault is locked', async () => {\n    // vault is locked by default\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { duration: 25 } }));\n    await new Promise(r => setTimeout(r, 50));\n    const events = await listEvents();\n    expect(events).toHaveLength(0);\n  });\n\n  test('records focus-start event when vault is unlocked', async () => {\n    const { unlockWithPassphrase } = await import('../../src/core/HistoryOfThought');\n    await unlockWithPassphrase('testpass');\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { duration: 25 } }));\n    await new Promise(r => setTimeout(r, 50));\n    const events = await listEvents();\n    expect(events.some(e => e.type === 'focus_session_start')).toBe(true);\n  });\n});\n```\n\n---\n\n## Priority 4: PDF Extraction\n\n```js\n// tests/services/DocumentAIService.test.js\nimport { processDocumentWithGCP } from '../../src/services/DocumentAIService';\n\ndescribe('processDocumentWithGCP()', () => {\n  test('rejects mock tokens', async () => {\n    const blob = new Blob(['%PDF-1.4'], { type: 'application/pdf' });\n    await expect(processDocumentWithGCP(blob, 'mock-token-123')).rejects.toThrow();\n  });\n\n  test('falls back to pdf.js when GCP returns 401', async () => {\n    global.fetch = jest.fn().mockResolvedValue({ ok: false, status: 401 });\n    const blob = new Blob(['%PDF-1.4'], { type: 'application/pdf' });\n    // expect local extraction attempt, not unhandled rejection\n    await expect(processDocumentWithGCP(blob, 'real-token')).rejects.toThrow(/PdfExtraction/);\n  });\n\n  test('handles password-protected PDF gracefully', async () => {\n    // pdfjs PasswordException path\n    // mock pdfjs to throw PasswordException, expect PdfExtractionError\n  });\n});\n```\n\n---\n\n## Priority 5: MicroStepService — Ollama failure modes\n\n```js\n// tests/services/MicroStepService.test.js\nimport { generateMicroSteps } from '../../src/services/MicroStepService';\n\ndescribe('generateMicroSteps()', () => {\n  test('throws when brief.title is missing', async () => {\n    await expect(generateMicroSteps({}, {}, [])).rejects.toThrow();\n  });\n\n  test('handles Ollama network timeout', async () => {\n    global.fetch = jest.fn().mockRejectedValue(new DOMException('Aborted', 'AbortError'));\n    await expect(generateMicroSteps({ title: 'Essay' }, {}, [])).rejects.toThrow();\n  });\n\n  test('safeParseSteps handles markdown-fenced JSON', () => {\n    const raw = '```json\\n[{\"action\":\"Write intro\",\"why\":\"Sets context\"}]\\n```';\n    const { safeParseSteps } = require('../../src/services/MicroStepService');\n    expect(safeParseSteps(raw, 3)).toEqual(\n      expect.arrayContaining([expect.objectContaining({ action: 'Write intro' })])\n    );\n  });\n\n  test('stepCountFor returns 3 for unknown scaffolding level', () => {\n    const { stepCountFor } = require('../../src/services/MicroStepService');\n    expect(stepCountFor('bogus')).toBe(3);\n  });\n});\n```\n\n---\n\n## Setup Required\n\nNo test infrastructure exists yet. Add to `package.json`:\n\n```json\n{\n  \"devDependencies\": {\n    \"jest\": \"^29\",\n    \"@testing-library/react\": \"^14\",\n    \"@testing-library/jest-dom\": \"^6\",\n    \"jest-environment-jsdom\": \"^29\",\n    \"fake-indexeddb\": \"^5\",\n    \"jest-localstorage-mock\": \"^2\"\n  },\n  \"scripts\": {\n    \"test\": \"jest --testEnvironment jsdom\"\n  },\n  \"jest\": {\n    \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\", \"jest-localstorage-mock\"]\n  }\n}\n```\n\n---\n\n## Gap Summary Table\n\n| Module | Functions | Tested | Gap | Priority |\n|--------|-----------|--------|-----|----------|\n| `HistoryOfThought.js` | 7 | 0 | Crypto, nonce uniqueness, silent drop, IndexedDB quota | **Critical** |\n| `ExecutiveSpine.js` | 14 | 0 | Timer expiry, localStorage failure, clamping, concurrency | **Critical** |\n| `EventBus.js` | 4 | 0 | Silent drop rule, payload filtering, debounce | **Critical** |\n| `LiteralMode.js` | 2 (26 patterns) | 0 | All 26 regex patterns, null input, clause splitting | High |\n| `BriefService.js` | 4 (26 regexes) | 0 | LO boundary (10-240 chars), word-number parsing | High |\n| `DocumentAIService.js` | 4 | 0 | Y-delta heuristic, PasswordException, worker probe | High |\n| `MicroStepService.js` | 6 | 0 | Ollama timeout, JSON fallback chain, em-dash sanitise | High |\n| `SovereignRouter.js` | 6 | 0 | Invalid stream fallback, null session, missing vocab | Medium |\n| `ProjectContext.js` | 5+ | 0 | Legacy purge, course CRUD, sprint drafts | Medium |\n| `LandingPage.js` | 3 | 0 | Passphrase < 4 chars, unlock exception, disabled state | Medium |\n| 66 other files | — | 0 | Everything | Low–High |\n\nThe **most urgent** gap is the `HistoryOfThought` / `EventBus` pair — the silent-drop-when-locked rule is a load-bearing security invariant with zero verification.\n",
