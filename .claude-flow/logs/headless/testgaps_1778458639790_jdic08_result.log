  "output": "## Test Coverage Analysis\n\n**Critical finding: Zero tests exist.** No test framework is configured. Here's the full gap analysis with skeletons.\n\n---\n\n## 1. Setup Required First\n\n```bash\nnpm install --save-dev jest @testing-library/react @testing-library/jest-dom @testing-library/user-event jest-environment-jsdom\n```\n\nAdd to `package.json`:\n```json\n\"jest\": {\n  \"testEnvironment\": \"jsdom\",\n  \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\"]\n}\n```\n\n---\n\n## 2. Critical Priority — Crypto & Storage\n\n### `HistoryOfThought.js` — PBKDF2 + AES-GCM (zero coverage)\n\n```js\n// tests/core/HistoryOfThought.test.js\nimport {\n  unlockWithPassphrase, lockSession, isUnlocked,\n  appendEvent, listEvents, generateAuthenticityReport, EVENT_TYPES\n} from '../../src/core/HistoryOfThought';\n\n// Mock IndexedDB\nbeforeEach(() => { /* use fake-indexeddb */ });\n\ndescribe('unlockWithPassphrase', () => {\n  test('returns false for passphrase under 4 chars', async () => {\n    await expect(unlockWithPassphrase('abc')).resolves.toBe(false);\n  });\n\n  test('derives key and sets unlocked state', async () => {\n    const result = await unlockWithPassphrase('correcthorsebatterystaple');\n    expect(result).toBe(true);\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('fails gracefully when Web Crypto unavailable', async () => {\n    const orig = global.crypto.subtle;\n    delete global.crypto.subtle;\n    await expect(unlockWithPassphrase('validpass')).resolves.toBe(false);\n    global.crypto.subtle = orig;\n  });\n\n  // EDGE: second unlock with same passphrase should succeed\n  test('re-unlock after lockSession() succeeds', async () => {\n    await unlockWithPassphrase('pass1234');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n    const result = await unlockWithPassphrase('pass1234');\n    expect(result).toBe(true);\n  });\n});\n\ndescribe('appendEvent', () => {\n  beforeEach(async () => { await unlockWithPassphrase('testpass'); });\n\n  test('rejects when vault locked', async () => {\n    lockSession();\n    await expect(\n      appendEvent({ user_id: 'u1', stream_id: 's1', event_type: 'text_edit', payload: {} })\n    ).rejects.toThrow();\n  });\n\n  test('rejects unknown event_type', async () => {\n    await expect(\n      appendEvent({ user_id: 'u1', stream_id: 's1', event_type: 'INVALID', payload: {} })\n    ).rejects.toThrow();\n  });\n\n  test('round-trips — appended event is decryptable via listEvents', async () => {\n    await appendEvent({ user_id: 'u1', stream_id: 'tertiary', event_type: 'text_edit', payload: { words: 50 } });\n    const events = await listEvents({ user_id: 'u1', limit: 10 });\n    expect(events[0].event_type).toBe('text_edit');\n    expect(events[0].payload.words).toBe(50);\n  });\n\n  // EDGE: concurrent writes (race condition)\n  test('concurrent appendEvent calls do not corrupt store', async () => {\n    await Promise.all([\n      appendEvent({ user_id: 'u2', stream_id: 's', event_type: 'text_edit', payload: {} }),\n      appendEvent({ user_id: 'u2', stream_id: 's', event_type: 'citation_added', payload: {} }),\n    ]);\n    const events = await listEvents({ user_id: 'u2', limit: 10 });\n    expect(events).toHaveLength(2);\n  });\n});\n\ndescribe('generateAuthenticityReport', () => {\n  test('returns empty report for user with no events', async () => {\n    await unlockWithPassphrase('testpass');\n    const report = await generateAuthenticityReport({ user_id: 'nobody' });\n    expect(report.events).toHaveLength(0);\n  });\n});\n```\n\n---\n\n## 3. Critical Priority — ExecutiveSpine\n\n```js\n// tests/core/ExecutiveSpine.test.js\nimport {\n  startFocusSession, endFocusSession, getFocusSession, isFocusActive,\n  setSectionHealth, getSectionHealth, grantPlayTime, isPlayTimeActive,\n  earnCredits, spendCredits, getCredits, configureSpine\n} from '../../src/core/ExecutiveSpine';\n\nbeforeEach(() => {\n  localStorage.clear();\n  jest.useFakeTimers();\n});\nafterEach(() => jest.useRealTimers());\n\ndescribe('focus session', () => {\n  test('starts and sets isFocusActive true', () => {\n    startFocusSession({ taskId: 't1', durationMinutes: 25 });\n    expect(isFocusActive()).toBe(true);\n    expect(getFocusSession().taskId).toBe('t1');\n  });\n\n  test('endFocusSession clears active session', () => {\n    startFocusSession({ taskId: 't1', durationMinutes: 25 });\n    endFocusSession({ reason: 'completed' });\n    expect(isFocusActive()).toBe(false);\n    expect(getFocusSession()).toBeNull();\n  });\n\n  // EDGE: end when no session active\n  test('endFocusSession with no active session does not throw', () => {\n    expect(() => endFocusSession({ reason: 'manual' })).not.toThrow();\n  });\n\n  // EDGE: calling start twice (should replace or throw — verify behavior)\n  test('second startFocusSession replaces first without crashing', () => {\n    startFocusSession({ taskId: 't1', durationMinutes: 10 });\n    startFocusSession({ taskId: 't2', durationMinutes: 20 });\n    expect(getFocusSession().taskId).toBe('t2');\n  });\n});\n\ndescribe('section health + playtime', () => {\n  test('setSectionHealth persists value', () => {\n    setSectionHealth('intro', 3);\n    expect(getSectionHealth('intro')).toBe(3);\n  });\n\n  test('setSectionHealth clamps to 0-5', () => {\n    setSectionHealth('sec', 10);\n    expect(getSectionHealth('sec')).toBeLessThanOrEqual(5);\n    setSectionHealth('sec', -1);\n    expect(getSectionHealth('sec')).toBeGreaterThanOrEqual(0);\n  });\n\n  test('full health (5) auto-grants playtime', () => {\n    setSectionHealth('s1', 5);\n    expect(isPlayTimeActive()).toBe(true);\n  });\n\n  test('grantPlayTime expires after configured duration', () => {\n    grantPlayTime({ minutes: 1, reason: 'test' });\n    expect(isPlayTimeActive()).toBe(true);\n    jest.advanceTimersByTime(61_000);\n    expect(isPlayTimeActive()).toBe(false);\n  });\n});\n\ndescribe('sovereign credits', () => {\n  test('initial credits are 0', () => {\n    expect(getCredits()).toBe(0);\n  });\n\n  test('earnCredits adds to balance', () => {\n    earnCredits(10, 'test');\n    expect(getCredits()).toBe(10);\n  });\n\n  test('spendCredits deducts from balance', () => {\n    earnCredits(20, 'setup');\n    spendCredits(5, 'test');\n    expect(getCredits()).toBe(15);\n  });\n\n  // EDGE: spend more than balance\n  test('spendCredits throws or returns false when balance insufficient', () => {\n    expect(() => spendCredits(999, 'overdraft')).toThrow();\n    // OR: expect(spendCredits(999, 'overdraft')).toBe(false);\n  });\n});\n```\n\n---\n\n## 4. High Priority — SovereignRouter\n\n```js\n// tests/core/SovereignRouter.test.js\nimport { hydrate, isValidStream, streamFromLevel, applyTheme } from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test.each([\n    ['Year 3', 'primary'],\n    ['Year 10', 'secondary'],\n    ['University', 'tertiary'],\n    ['TAFE Diploma', 'tafe'],\n    ['Home School', 'homeschool'],\n  ])('%s maps to %s', (level, expected) => {\n    expect(streamFromLevel(level)).toBe(expected);\n  });\n\n  // EDGE: unknown level\n  test('unknown level returns null or default', () => {\n    const result = streamFromLevel('Mars Academy');\n    expect(['tertiary', null, undefined]).toContain(result);\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('valid stream IDs return true', () => {\n    ['primary', 'secondary', 'tertiary', 'tafe', 'homeschool'].forEach(id => {\n      expect(isValidStream(id)).toBe(true);\n    });\n  });\n\n  test('invalid IDs return false', () => {\n    expect(isValidStream('postgrad')).toBe(false);\n    expect(isValidStream('')).toBe(false);\n    expect(isValidStream(null)).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('returns merged profile with stream and theme', () => {\n    const profile = hydrate({ academicLevel: 'University', userId: 'u1' });\n    expect(profile.stream).toBe('tertiary');\n    expect(profile).toHaveProperty('theme');\n  });\n\n  // EDGE: missing session fields\n  test('hydrate with empty session returns safe defaults', () => {\n    expect(() => hydrate({})).not.toThrow();\n  });\n\n  test('hydrate with null throws or returns default', () => {\n    expect(() => hydrate(null)).not.toThrow();\n  });\n});\n\ndescribe('applyTheme', () => {\n  test('writes CSS custom properties to document root', () => {\n    applyTheme('tertiary');\n    const style = document.documentElement.style.getPropertyValue('--color-primary');\n    expect(style).not.toBe('');\n  });\n});\n```\n\n---\n\n## 5. High Priority — SovereignReconciler (Fuzzy Matching)\n\n```js\n// tests/services/SovereignReconciler.test.js\nimport { reconcile, reconcileTitles } from '../../src/services/SovereignReconciler';\n\ndescribe('reconcileTitles', () => {\n  test('groups identical titles', () => {\n    const result = reconcileTitles(['Essay 1', 'Essay 1', 'Essay 1']);\n    expect(result).toHaveLength(1);\n  });\n\n  test('clusters similar titles (Part A / Part 1 / Part One)', () => {\n    const result = reconcileTitles(['Research Essay Part A', 'Research Essay Part 1', 'Research Essay Part One']);\n    expect(result).toHaveLength(1);\n  });\n\n  test('keeps dissimilar titles separate', () => {\n    const result = reconcileTitles(['Final Exam', 'Lab Report', 'Tutorial Quiz']);\n    expect(result).toHaveLength(3);\n  });\n\n  // EDGE: empty input\n  test('empty array returns empty', () => {\n    expect(reconcileTitles([])).toEqual([]);\n  });\n\n  // EDGE: single item\n  test('single title returns one cluster', () => {\n    expect(reconcileTitles(['Capstone Project'])).toHaveLength(1);\n  });\n\n  // EDGE: Unicode / emoji in titles\n  test('handles emoji in title without crashing', () => {\n    expect(() => reconcileTitles(['Essay \\uD83D\\uDCDD', 'Essay'])).not.toThrow();\n  });\n});\n\ndescribe('reconcile (full briefs)', () => {\n  const brief = (title, source = 'rubric') => ({ title, source, weight: 100 });\n\n  test('prefers rubric source over outline when clustering', () => {\n    const result = reconcile([brief('Research Essay', 'outline'), brief('Research Essay', 'rubric')]);\n    expect(result[0].source).toBe('rubric');\n  });\n\n  test('returns canonical brief per cluster', () => {\n    const result = reconcile([brief('Lab Report Part A'), brief('Lab Report Part 1')]);\n    expect(result).toHaveLength(1);\n    expect(result[0]).toHaveProperty('title');\n  });\n});\n```\n\n---\n\n## 6. High Priority — LiteralMode (22 Regex Patterns)\n\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise } from '../../src/core/LiteralMode';\n\ndescribe('literalise', () => {\n  test.each([\n    ['consider revising', 'change'],\n    ['synthesise', 'combine ideas from'],\n    ['analyse', 'break down'],\n    ['it is important to note', ''],\n    ['in order to', 'to'],\n  ])('transforms \"%s\" correctly', (input, expected) => {\n    expect(literalise(input)).toContain(expected);\n  });\n\n  // EDGE: empty string\n  test('empty string returns empty string', () => {\n    expect(literalise('')).toBe('');\n  });\n\n  // EDGE: null/undefined input\n  test('null input does not throw', () => {\n    expect(() => literalise(null)).not.toThrow();\n  });\n\n  // EDGE: special regex characters in input\n  test('handles regex special chars in text', () => {\n    expect(() => literalise('consider $100 in order to (analyse) [this]')).not.toThrow();\n  });\n\n  // EDGE: splitClauses option\n  test('splitClauses splits on semicolons', () => {\n    const result = literalise('do this; do that', { splitClauses: true });\n    expect(Array.isArray(result) || result.includes('\\n')).toBe(true);\n  });\n\n  // EDGE: dropEmpty option removes empty lines after substitution\n  test('dropEmpty removes blank lines', () => {\n    const result = literalise('it is important to note', { dropEmpty: true });\n    expect(result.trim()).toBe('');\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('returns true for literal stream profile + user preference', () => {\n    expect(shouldLiteralise({ stream: 'primary' }, 'literal')).toBe(true);\n  });\n\n  test('returns false for academic preference regardless of stream', () => {\n    expect(shouldLiteralise({ stream: 'primary' }, 'academic')).toBe(false);\n  });\n});\n```\n\n---\n\n## 7. High Priority — EventBus\n\n```js\n// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit } from '../../src/core/EventBus';\n\nconst mockContext = () => ({ userId: 'u1', streamId: 'tertiary' });\n\nafterEach(() => stopEventBus());\n\ndescribe('startEventBus / stopEventBus', () => {\n  test('attaches listeners without throwing', () => {\n    expect(() => startEventBus(mockContext)).not.toThrow();\n  });\n\n  // EDGE: double-start should not double-attach\n  test('calling startEventBus twice does not duplicate listeners', () => {\n    startEventBus(mockContext);\n    const spy = jest.spyOn(window, 'addEventListener');\n    startEventBus(mockContext);\n    // Should call stopEventBus first or be idempotent\n    expect(spy).not.toHaveBeenCalledWith('simplifii:focus-start', expect.any(Function));\n  });\n\n  test('stopEventBus removes all listeners', () => {\n    startEventBus(mockContext);\n    const spy = jest.spyOn(window, 'removeEventListener');\n    stopEventBus();\n    expect(spy).toHaveBeenCalled();\n  });\n});\n\ndescribe('spine events forwarded to HistoryOfThought', () => {\n  test('simplifii:focus-start fires appendEvent with focus_session_start', async () => {\n    // Unlock vault first\n    // Mock appendEvent\n    startEventBus(mockContext);\n    window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 't1' } }));\n    // Assert appendEvent was called with event_type: 'focus_session_start'\n  });\n});\n```\n\n---\n\n## 8. Integration Test Gaps\n\n```js\n// tests/integration/FocusSession.integration.test.js\n// Covers: ExecutiveSpine → EventBus → HistoryOfThought pipeline\n\ntest('full focus session round-trip is encrypted and retrievable', async () => {\n  await unlockWithPassphrase('integrationpass');\n  startEventBus(() => ({ userId: 'u_int', streamId: 'tertiary' }));\n\n  startFocusSession({ taskId: 'task_1', durationMinutes: 25 });\n  window.dispatchEvent(new CustomEvent('simplifii:focus-start', { detail: { taskId: 'task_1' } }));\n\n  const events = await listEvents({ user_id: 'u_int', limit: 5 });\n  expect(events.some(e => e.event_type === 'focus_session_start')).toBe(true);\n\n  stopEventBus();\n});\n```\n\n```js\n// tests/integration/StreamSwitch.integration.test.js\n// Covers: SovereignRouter.hydrate() → ExecutiveSpine.configureSpine() → EventBus restart\n\ntest('switching stream reconfigures spine without memory leak', () => {\n  const profile1 = hydrate({ academicLevel: 'University' });\n  configureSpine({ sectionHealthUnlockThreshold: 4 });\n  startEventBus(() => ({ userId: 'u1', streamId: profile1.stream }));\n\n  const profile2 = hydrate({ academicLevel: 'TAFE Diploma' });\n  stopEventBus();\n  configureSpine({ sectionHealthUnlockThreshold: 3 });\n  startEventBus(() => ({ userId: 'u1', streamId: profile2.stream }));\n\n  expect(() => startFocusSession({ taskId: 't2', durationMinutes: 10 })).not.toThrow();\n});\n```\n\n---\n\n## 9. Missing Error Handling Tests\n\n| Scenario | Where | Test Pattern |\n|---|---|---|\n| `localStorage` unavailable (sandboxed iframe) | `ExecutiveSpine.safeWriteLS` | Mock `localStorage.setItem` to throw `SecurityError` |\n| `IndexedDB` quota exceeded | `HistoryOfThought.appendEvent` | Mock `IDBTransaction` to fire `error` event |\n| Ollama endpoint timeout (>30s) | `ChatService.askAura` | `jest.useFakeTimers()` + mock `fetch` to never resolve |\n| Corrupted AES-GCM ciphertext | `HistoryOfThought` decrypt path | Pass tampered base64 as `ct` field |\n| `Web Crypto` unavailable | `HistoryOfThought.deriveKey` | `delete global.crypto.subtle` |\n| SectionHealth with `null` sectionId | `ExecutiveSpine.setSectionHealth` | `setSectionHealth(null, 3)` — should not throw |\n| `reconcile([])` with empty array | `SovereignReconciler` | Assert returns `[]`, not crash |\n| `generateMicroSteps` with empty brief | `MicroStepService` | Assert graceful empty response |\n\n---\n\n## Summary\n\n| Layer | Files | Functions | Coverage |\n|---|---|---|---|\n| Core modules | 5 | ~40 | **0%** |\n| Services | 14 | ~60 | **0%** |\n| Frontend | 37 | ~200+ | **0%** |\n| Integration | — | — | **0%** |\n\n**Top 3 highest-risk gaps:**\n1. `HistoryOfThought` crypto (PBKDF2 + AES-GCM) — security-critical, zero tests\n2. `ExecutiveSpine` credit/session state — core engagement loop, zero tests\n3. `SovereignReconciler` fuzzy clustering — algorithmic complexity with no validation\n",
