        "language": "js",
        "code": "// tests/services/BriefService.test.js\nimport {\n  mapToWorkspace, extractDynamicThemes, extractEvidenceFormula,\n  detectAcademicTier, extractDeepCourseData,\n  mergeExtractionData, deriveRoadmapFromAssessments\n} from '../../src/services/BriefService';\n\ndescribe('mapToWorkspace — level layouts', () => {\n  test('Tertiary returns 7 sections', () => {\n    const ws = mapToWorkspace('some text', 'Tertiary');\n    expect(ws).toHaveLength(7);\n  });\n\n  test('Undergrad returns 3 sections', () => {\n    expect(mapToWorkspace('text', 'Undergrad')).toHaveLength(3);\n  });\n\n  test('PhD returns 2 sections', () => {\n    expect(mapToWorkspace('text', 'PhD')).toHaveLength(2);\n  });\n\n  test('unknown level falls back to Tertiary layout', () => {\n    const ws = mapToWorkspace('text', 'UNKNOWN');\n    expect(ws).toHaveLength(7);\n  });\n});\n\ndescribe('extractDynamicThemes', () => {\n  test('returns max 3 keywords', () => {\n    const themes = extractDynamicThemes('Biology ecology evolution genetics taxonomy morphology');\n    expect(themes.length).toBeLessThanOrEqual(3);\n  });\n\n  test('filters stop-words like \"The\" and \"A\"', () => {\n    const themes = extractDynamicThemes('The A An biology The biology');\n    expect(themes).not.toContain('The');\n    expect(themes).not.toContain('A');\n  });\n\n  test('returns empty array for empty input', () => {\n    expect(extractDynamicThemes('')).toEqual([]);\n  });\n});\n\ndescribe('extractEvidenceFormula', () => {\n  test('detects \"10 peer-reviewed sources\"', () => {\n    const formula = extractEvidenceFormula('Use a minimum of 10 peer-reviewed sources.');\n    expect(formula.find(f => f.type === 'primary')?.count).toBe(10);\n  });\n\n  test('returns empty array for text with no source requirements', () => {\n    expect(extractEvidenceFormula('Write an essay.')).toEqual([]);\n  });\n});\n\ndescribe('detectAcademicTier', () => {\n  test('returns \"Lab\" for lab-report keyword', () => {\n    expect(detectAcademicTier('Submit a formal lab report with results.')).toBe('Lab');\n  });\n\n  test('returns \"General\" for generic text', () => {\n    expect(detectAcademicTier('Write 500 words.')).toBe('General');\n  });\n});\n\ndescribe('extractDeepCourseData — assessment extraction', () => {\n  const SAMPLE = `\n    Assessment 1: Literature Review 20%  Due: 2026-03-15\n    Assessment 2: Final Exam 40%         Due: 2026-06-01\n    Lab Report 30%  Due: 2026-04-20\n  `;\n\n  test('extracts numbered assessments (pass 1)', () => {\n    const data = extractDeepCourseData(SAMPLE);\n    expect(data.assessmentTitles).toContain('Literature Review');\n    expect(data.assessmentTitles).toContain('Final Exam');\n  });\n\n  test('extracts named assessments (pass 2)', () => {\n    const data = extractDeepCourseData(SAMPLE);\n    expect(data.assessmentTitles).toContain('Lab Report');\n  });\n\n  test('extracts weighting values', () => {\n    const data = extractDeepCourseData(SAMPLE);\n    expect(data.weighting).toContain(20);\n    expect(data.weighting).toContain(40);\n  });\n\n  test('does not include lectures or tutorials as assessments', () => {\n    const noisy = 'Lecture 1: Intro. Tutorial: Week 2. Assessment: Essay 30%.';\n    const data = extractDeepCourseData(noisy);\n    expect(data.assessmentTitles).not.toContain('Lecture 1: Intro');\n  });\n\n  test('returns empty arrays for blank input', () => {\n    const data = extractDeepCourseData('');\n    expect(data.assessmentTitles).toEqual([]);\n    expect(data.weighting).toEqual([]);\n  });\n});\n\ndescribe('mergeExtractionData', () => {\n  test('unions arrays without duplicates', () => {\n    const prev = { assessmentTitles: ['Essay'], weighting: [30] };\n    const next = { assessmentTitles: ['Essay', 'Exam'], weighting: [40] };\n    const merged = mergeExtractionData(prev, next);\n    expect(merged.assessmentTitles).toEqual(['Essay', 'Exam']);\n  });\n});\n\ndescribe('deriveRoadmapFromAssessments', () => {\n  test('returns null for empty input', () => {\n    expect(deriveRoadmapFromAssessments([])).toBeNull();\n  });\n\n  test('returns roadmap with currentTask, nextAssessment, finalMilestone', () => {\n    const titles = ['Literature Review', 'Essay', 'Final Exam'];\n    const roadmap = deriveRoadmapFromAssessments(titles);\n    expect(roadmap).toHaveProperty('currentTask');\n    expect(roadmap).toHaveProperty('nextAssessment');\n    expect(roadmap).toHaveProperty('finalMilestone');\n  });\n});"
      },
