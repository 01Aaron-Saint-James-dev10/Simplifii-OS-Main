ssmentBriefs('some syllabus text');\n    expect(result[0].title).toBe('Lab Report');\n  });\n\n  test('accepts \"weightage\" alias for weight', async () => {\n    const raw = `[{\"title\": \"Essay\", \"weightage\": 40, \"wordCountGoal\": 2000, \"dueDate\": null}]`;\n    global.fetch = jest.fn().mockResolvedValue({ ok: true, json: () => ({ message: { content: raw } }) });\n    const result = await extractAssessmentBriefs('some syllabus text');\n    expect(result[0].weight).toBe(40);\n  });\n});\n\ndescribe('extractAssessmentsWithOllama — noise filtering', () => {\n  test('does not include lectures or tutorials in assessment list', async () => {\n    const syllabus = 'Weekly lectures 3h. Tutorials 1h. Assessment: Essay 40%.';\n    global.fetch = jest.fn().mockResolvedValue({\n      ok: true,\n      json: () => ({ message: { content: '[\"Essay\"]' } })\n    });\n    const result = await extractAssessmentsWithOllama(syllabus);\n    expect(result).not.toContain('lectures');\n    expect(result).not.toContain('Tutorials');\n  });\n});\n\ndescribe('pingOllama', () => {\n  test('returns false when Ollama unreachable', async () => {\n    global.fetch = jest.fn().mockRejectedValue(new Error('Connection refused'));\n    const alive = await pingOllama();\n    expect(alive).toBe(false);\n  });\n});\n\ndescribe('SYSTEM_PROMPT contract', () => {\n  test('SYSTEM_PROMPT does not contain em-dashes', () => {\n    expect(__internals.SYSTEM_PROMPT).not.toMatch(/—/);\n  });\n\n  test('SYSTEM_PROMPT references Australian English', () => {\n    expect(__internals.SYSTEM_PROMPT.toLowerCase()).toMatch(/australian/);\n  });\n});\n```\n\n---\n\n",
