        "code": "// tests/core/EventBus.test.js\nimport { startEventBus, stopEventBus, recordTextEdit, recordCitation } from '../../src/core/EventBus';\n\ndescribe('EventBus — vault-locked silent drop', () => {\n  test('recordTextEdit does not throw when vault is locked', async () => {\n    // vault locked by default\n    await expect(recordTextEdit({ sectionId: 's1', wordsAfter: 100 })).resolves.not.toThrow();\n  });\n\n  test('recordCitation does not throw when vault is locked', async () => {\n    await expect(recordCitation({ added: true, source: 'Smith 2024' })).resolves.not.toThrow();\n  });\n});\n\ndescribe('EventBus — listener lifecycle', () => {\n  test('startEventBus attaches listeners; stopEventBus removes them', () => {\n    const addSpy = jest.spyOn(window, 'addEventListener');\n    const removeSpy = jest.spyOn(window, 'removeEventListener');\n    startEventBus(() => ({}));\n    expect(addSpy).toHaveBeenCalled();\n    stopEventBus();\n    expect(removeSpy).toHaveBeenCalled();\n  });\n});"
