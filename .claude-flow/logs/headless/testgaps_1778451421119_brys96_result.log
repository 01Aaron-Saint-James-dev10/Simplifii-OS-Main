      {
        "title": "6. SovereignReconciler.js — Jaccard Clustering",
        "content": "\n```js\n// tests/services/SovereignReconciler.test.js\nimport { reconcile, reconcileTitles, __internals } from '../../src/services/SovereignReconciler';\nconst { normaliseTitle, tokenSimilarity } = __internals;\n\ndescribe('normaliseTitle', () => {\n  test('lowercases and strips stop-words', () => {\n    const result = normaliseTitle('The Final Essay');\n    expect(result).not.toContain('The');\n    expect(result).toContain('final');\n    expect(result).toContain('essay');\n  });\n\n  test('converts Roman numerals: \"Assessment II\" → \"Assessment 2\"', () => {\n    const result = normaliseTitle('Assessment II');\n    expect(result).toContain('2');\n    expect(result).not.toMatch(/\\bii\\b/i);\n  });\n\n  test('expands known aliases: \"Lit Review\" → includes \"literature\"', () => {\n    const result = normaliseTitle('Lit Review');\n    expect(result).toContain('literature');\n  });\n});\n\ndescribe('tokenSimilarity — Jaccard', () => {\n  test('identical strings → 1.0', () => {\n    expect(tokenSimilarity('essay report', 'essay report')).toBe(1.0);\n  });\n\n  test('completely different strings → 0.0', () => {\n    expect(tokenSimilarity('alpha beta', 'gamma delta')).toBe(0.0);\n  });\n\n  test('50% overlap → ~0.33 Jaccard', () => {\n    const score = tokenSimilarity('a b', 'a c');\n    expect(score).toBeGreaterThan(0);\n    expect(score).toBeLessThan(1);\n  });\n});\n\ndescribe('reconcile — clustering & conflict detection', () => {\n  test('clusters near-duplicate titles into one canonical entry', () => {\n    const briefs = [\n      { title: 'Literature Review', weight: 30, dueDate: '2026-03-15', source: 'brief' },\n      { title: 'Lit Review', weight: 25, dueDate: '2026-03-15', source: 'outline' },\n    ];\n    const result = reconcile(briefs);\n    expect(result).toHaveLength(1);\n    expect(result[0].reconciled.memberCount).toBe(2);\n  });\n\n  test('flags weight conflict', () => {\n    const briefs = [\n      { title: 'Essay', weight: 30, source: 'brief' },\n      { title: 'Essay', weight: 40, source: 'outline' },\n    ];\n    const result = reconcile(briefs);\n    expect(result[0].reconciled.conflicts).toContain('weight');\n  });\n\n  test('distinct titles remain separate clusters', () => {\n    const briefs = [\n      { title: 'Literature Review', weight: 30 },\n      { title: 'Final Exam', weight: 40 },\n    ];\n    expect(reconcile(briefs)).toHaveLength(2);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "7. LiteralMode.js — Pattern Table",
        "content": "\n```js\n// tests/core/LiteralMode.test.js\nimport { literalise, shouldLiteralise, __internals } from '../../src/core/LiteralMode';\n\ndescribe('literalise — pattern replacements', () => {\n  const cases = [\n    ['It is evident that X occurred.', 'X occurred'],\n    ['The results demonstrate that Y is true.', 'Y is true'],\n    ['In order to achieve Z', 'To achieve Z'],\n    ['utilise', 'use'],\n    ['subsequently', /then|after/i],\n  ];\n\n  test.each(cases)('\"%s\" → contains \"%s\"', (input, expected) => {\n    const result = literalise(input);\n    if (typeof expected === 'string') {\n      expect(result.toLowerCase()).toContain(expected.toLowerCase());\n    } else {\n      expect(result).toMatch(expected);\n    }\n  });\n\n  test('returns input unchanged for non-string', () => {\n    expect(literalise(null)).toBeNull();\n    expect(literalise(42)).toBe(42);\n  });\n\n  test('does not generate new content', () => {\n    const input = 'The cat sat on the mat.';\n    const result = literalise(input);\n    // Every word in output must appear (in some form) in input\n    // Basic: result length should be <= 2x input\n    expect(result.length).toBeLessThanOrEqual(input.length * 2);\n  });\n});\n\ndescribe('shouldLiteralise', () => {\n  test('stream profile \"literal\" → true', () => {\n    expect(shouldLiteralise({ mode: 'literal' }, null)).toBe(true);\n  });\n\n  test('user preference overrides stream when both present', () => {\n    expect(shouldLiteralise({ mode: 'academic' }, 'literal')).toBe(true);\n  });\n\n  test('default is false when no preference', () => {\n    expect(shouldLiteralise({}, null)).toBe(false);\n  });\n});\n\ndescribe('sanitiseDashes', () => {\n  const { sanitiseDashes } = __internals;\n\n  test('replaces em-dash with comma-space', () => {\n    expect(sanitiseDashes('results — significant')).toBe('results, significant');\n  });\n\n  test('replaces en-dash with comma-space', () => {\n    expect(sanitiseDashes('results \\u2013 significant')).toBe('results, significant');\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "Priority 3 — MEDIUM",
        "content": "\n",
        "level": 2
      },
      {
        "title": "8. KnowledgeGraphService.js",
        "content": "\n```js\n// tests/services/KnowledgeGraphService.test.js\nimport { extractSemanticEntities } from '../../src/services/KnowledgeGraphService';\n\ndescribe('extractSemanticEntities', () => {\n  test('extracts capitalised phrases', async () => {\n    const entities = await extractSemanticEntities('Natural Language Processing is a field of Artificial Intelligence.');\n    const labels = entities.map(e => e.label);\n    expect(labels).toContain('Natural Language Processing');\n  });\n\n  test('extracts acronyms', async () => {\n    const entities = await extractSemanticEntities('Use NLP and AI for semantic analysis.');\n    const labels = entities.map(e => e.label);\n    expect(labels).toContain('NLP');\n    expect(labels).toContain('AI');\n  });\n\n  test('caps phrases at 6', async () => {\n    const text = 'Alpha Beta Gamma Delta Epsilon Zeta Eta Theta Iota Kappa.';\n    const entities = await extractSemanticEntities(text);\n    expect(entities.filter(e => e.type === 'phrase').length).toBeLessThanOrEqual(6);\n  });\n\n  test('caps acronyms at 4', async () => {\n    const text = 'ABC DEF GHI JKL MNO PQR.';\n    const entities = await extractSemanticEntities(text);\n    expect(entities.filter(e => e.type === 'acronym').length).toBeLessThanOrEqual(4);\n  });\n\n  test('filters stop-words like \"The\"', async () => {\n    const entities = await extractSemanticEntities('The University of Science.');\n    const labels = entities.map(e => e.label);\n    expect(labels).not.toContain('The');\n    expect(labels).not.toContain('University');\n  });\n\n  test('returns empty array for empty string', async () => {\n    expect(await extractSemanticEntities('')).toEqual([]);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
      {
        "title": "9. SovereignRouter.js",
        "content": "\n```js\n// tests/core/SovereignRouter.test.js\nimport {\n  streamFromLevel, isValidStream, hydrate, __internals\n} from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test('maps known levels to stream IDs', () => {\n    expect(streamFromLevel('undergraduate')).toBe('tertiary');\n    expect(streamFromLevel('highschool')).toBe('highschool');\n  });\n\n  test('returns \"tertiary\" for unknown level', () => {\n    expect(streamFromLevel('alien')).toBe('tertiary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('returns true for all built-in streams', () => {\n    __internals.VALID_STREAM_IDS.forEach(id => {\n      expect(isValidStream(id)).toBe(true);\n    });\n  });\n\n  test('returns false for unknown stream', () => {\n    expect(isValidStream('nonexistent')).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('returns streamId, profile, capabilities', () => {\n    const result = hydrate({ level: 'undergraduate' });\n    expect(result).toHaveProperty('streamId');\n    expect(result).toHaveProperty('profile');\n    expect(result).toHaveProperty('capabilities');\n  });\n\n  test('canAccess returns false for unauthorised capability', () => {\n    const result = hydrate({ level: 'highschool' });\n    // PhD-only capabilities should not be accessible for highschool\n    expect(result.canAccess('phd_only_feature')).toBe(false);\n  });\n\n  test('getDefaultLanding returns a non-empty string', () => {\n    const result = hydrate({ level: 'undergraduate' });\n    expect(typeof result.getDefaultLanding()).toBe('string');\n    expect(result.getDefaultLanding().length).toBeGreaterThan(0);\n  });\n});\n```\n\n---\n\n",
        "level": 3
      },
