        "title": "Missing Test Infrastructure",
        "content": "\nBefore any of the above runs, add to `package.json`:\n\n```json\n{\n  \"scripts\": {\n    \"test\": \"jest --coverage\",\n    \"test:watch\": \"jest --watch\"\n  },\n  \"devDependencies\": {\n    \"jest\": \"^29\",\n    \"jest-environment-jsdom\": \"^29\",\n    \"@testing-library/jest-dom\": \"^6\",\n    \"fake-indexeddb\": \"^5\",\n    \"msw\": \"^2\"\n  },\n  \"jest\": {\n    \"testEnvironment\": \"jsdom\",\n    \"setupFilesAfterFramework\": [\"@testing-library/jest-dom\"],\n    \"moduleNameMapper\": {\n      \"\\\\.(css|less)$\": \"<rootDir>/tests/__mocks__/fileMock.js\"\n    }\n  }\n}\n```\n\n---\n\n",
        "level": 2
      },
      {
        "title": "Edge Cases Across All Services (Not Covered Anywhere)",
        "content": "| Category | Edge Case |\n|----------|-----------|\n| Crypto | Wrong passphrase on second unlock attempt |\n| Crypto | AES-GCM auth tag tampered — expect rejection |\n| Storage | `localStorage.getItem` throws `SecurityError` (iframe) |\n| Network | Ollama responds with 200 but empty body |\n| Network | Ollama responds with truncated JSON |\n| Regex | Input containing regex metacharacters (`(`, `[`, `*`) |\n| Regex | Input >100k characters (ReDoS risk in BriefService) |\n| Unicode | Em-dash variants (U+2014, U+2013, U+2212) across all services |\n| Concurrency | Two `appendEvent` calls in parallel (race on IndexedDB tx) |\n| Concurrency | `startFocusSession` called while one is already active |\n| Boundary | Credits at exactly 0 before `spendCredits` |\n| Boundary | Section health at 5, then `setSectionHealth(id, 6)` |\n\n---\n\n**Recommended first step:** Install Jest + `fake-indexeddb`, then tackle `HistoryOfThought` and `ExecutiveSpine` — these are the security-critical paths with the most production risk.",
        "level": 2
      }
    ],
    "codeBlocks": [
      {
        "language": "js",
        "code": "// tests/core/HistoryOfThought.test.js\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport,\n  enableCloudSync, EVENT_TYPES\n} from '../../src/core/HistoryOfThought';\n\n// Requires: fake-indexeddb, crypto available in jsdom\ndescribe('HistoryOfThought — vault lifecycle', () => {\n  beforeEach(() => lockSession());\n\n  test('starts locked', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlocks with correct passphrase', async () => {\n    await unlockWithPassphrase('correct-horse-battery');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('lockSession clears derived key', async () => {\n    await unlockWithPassphrase('pass');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('HistoryOfThought — encrypt / decrypt round-trip', () => {\n  beforeEach(async () => {\n    lockSession();\n    await unlockWithPassphrase('test-passphrase');\n  });\n\n  test('appendEvent stores encrypted event retrievable by listEvents', async () => {\n    await appendEvent({ user_id: 'u1', stream_id: 'tertiary', event_type: 'text_edit', payload: { words: 50 } });\n    const events = await listEvents({ user_id: 'u1', limit: 10 });\n    expect(events).toHaveLength(1);\n    expect(events[0].event_type).toBe('text_edit');\n  });\n\n  test('events are inaccessible after lockSession', async () => {\n    await appendEvent({ user_id: 'u1', stream_id: 'tertiary', event_type: 'text_edit', payload: {} });\n    lockSession();\n    // Expect rejection or empty list when locked\n    await expect(listEvents({ user_id: 'u1' })).rejects.toThrow();\n  });\n});\n\ndescribe('HistoryOfThought — silent drop when locked', () => {\n  test('appendEvent does NOT throw when vault is locked', async () => {\n    // Must not throw — soft drop\n    await expect(appendEvent({ user_id: 'u1', stream_id: 's', event_type: 'text_edit', payload: {} }))\n      .resolves.not.toThrow();\n  });\n\n  test('appendEvent when locked does not persist event', async () => {\n    await appendEvent({ user_id: 'u1', stream_id: 's', event_type: 'text_edit', payload: {} });\n    await unlockWithPassphrase('pass');\n    const events = await listEvents({ user_id: 'u1' });\n    expect(events).toHaveLength(0); // dropped, not queued\n  });\n});\n\ndescribe('HistoryOfThought — validation', () => {\n  beforeEach(async () => { lockSession(); await unlockWithPassphrase('pass'); });\n\n  test('rejects unknown event_type', async () => {\n    await expect(appendEvent({ user_id: 'u1', stream_id: 's', event_type: 'INVALID_TYPE', payload: {} }))\n      .rejects.toThrow();\n  });\n\n  test('EVENT_TYPES is frozen and non-empty', () => {\n    expect(Object.isFrozen(EVENT_TYPES)).toBe(true);\n    expect(EVENT_TYPES.length).toBeGreaterThan(0);\n  });\n});\n\ndescribe('HistoryOfThought — cloud sync stub', () => {\n  test('enableCloudSync throws NotImplementedError', () => {\n    expect(() => enableCloudSync()).toThrow();\n  });\n});"
      },
      {
        "language": "js",
        "code": "// tests/core/ExecutiveSpine.test.js\nimport {\n  configureSpine, startFocusSession, endFocusSession,\n  getFocusSession, isFocusActive, getSectionHealth,\n  setSectionHealth, grantPlayTime, isPlayTimeActive,\n  getCredits, earnCredits, spendCredits\n} from '../../src/core/ExecutiveSpine';\n\nbeforeEach(() => {\n  localStorage.clear();\n  endFocusSession({ reason: 'reset' });\n});\n\ndescribe('focus session', () => {\n  test('startFocusSession sets active session', () => {\n    startFocusSession({ taskId: 'task-1', durationMinutes: 25 });\n    expect(isFocusActive()).toBe(true);\n    expect(getFocusSession().taskId).toBe('task-1');\n  });\n\n  test('endFocusSession deactivates session', () => {\n    startFocusSession({ taskId: 't', durationMinutes: 25 });\n    endFocusSession({ reason: 'manual' });\n    expect(isFocusActive()).toBe(false);\n    expect(getFocusSession()).toBeNull();\n  });\n\n  test('starting a second session replaces the first', () => {\n    startFocusSession({ taskId: 'a', durationMinutes: 10 });\n    startFocusSession({ taskId: 'b', durationMinutes: 20 });\n    expect(getFocusSession().taskId).toBe('b');\n  });\n});\n\ndescribe('section health', () => {\n  test('setSectionHealth clamps to 0–5', () => {\n    setSectionHealth('s1', 10);\n    expect(getSectionHealth('s1')).toBe(5);\n    setSectionHealth('s1', -3);\n    expect(getSectionHealth('s1')).toBe(0);\n  });\n\n  test('getSectionHealth returns 0 for unknown section', () => {\n    expect(getSectionHealth('nonexistent')).toBe(0);\n  });\n\n  test('crossing unlock threshold auto-grants playtime', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 4, defaultPlaytimeMinutes: 5 });\n    setSectionHealth('s1', 4); // threshold\n    expect(isPlayTimeActive()).toBe(true);\n  });\n\n  test('below threshold does not grant playtime', () => {\n    configureSpine({ sectionHealthUnlockThreshold: 4, defaultPlaytimeMinutes: 5 });\n    setSectionHealth('s1', 3);\n    expect(isPlayTimeActive()).toBe(false);\n  });\n});\n\ndescribe('sovereign credits', () => {\n  test('earnCredits increases balance', () => {\n    const before = getCredits();\n    earnCredits(10, 'test');\n    expect(getCredits()).toBe(before + 10);\n  });\n\n  test('spendCredits decreases balance', () => {\n    earnCredits(20, 'seed');\n    const before = getCredits();\n    spendCredits(10, 'test');\n    expect(getCredits()).toBe(before - 10);\n  });\n\n  test('credits cannot go below 0', () => {\n    spendCredits(99999, 'overdraft');\n    expect(getCredits()).toBeGreaterThanOrEqual(0);\n  });\n\n  test('credit balance persists in localStorage', () => {\n    earnCredits(5, 'persist-test');\n    const saved = Number(localStorage.getItem('simplifii_spine_credits'));\n    expect(saved).toBe(getCredits());\n  });\n});"
      },
      {
        "language": "js",
        "code": "// tests/services/RewriteService.test.js\nimport {\n  elevateRigour, synthesise, applyLogicMode,\n  nameCourse, extractAssessmentBriefs,\n  extractAssessmentsWithOllama, pingOllama,\n  getProviderName, __internals\n} from '../../src/services/RewriteService';\n\n// Force local-mock provider to avoid Ollama dependency\njest.mock('/* fetch */', ...); // or intercept via MSW\n\ndescribe('local-mock provider', () => {\n  beforeEach(() => {\n    // Force local-mock via env or module config\n    process.env.REWRITE_PROVIDER = 'local-mock';\n  });\n\n  test('elevateRigour returns transformed text synchronously (after delay)', async () => {\n    const result = await elevateRigour('The results show that X happened.');\n    expect(typeof result).toBe('string');\n    expect(result.length).toBeGreaterThan(0);\n  });\n\n  test('synthesise compresses text', async () => {\n    const long = 'A. B. C. D. E. F.';\n    const result = await synthesise(long);\n    expect(result.length).toBeLessThanOrEqual(long.length * 1.2);\n  });\n\n  test('applyLogicMode returns reframed text', async () => {\n    const result = await applyLogicMode('This happened because X.', 'cause-effect');\n    expect(result).toBeTruthy();\n  });\n});\n\ndescribe('extractAssessmentBriefs — field aliasing', () => {\n  // Test with field aliases that the extractor must normalise\n  test('accepts \"id\" alias for title', async () => {\n    const raw = `[{\"id\": \"Lab Report\", \"weight\": 30, \"wordCountGoal\": 1500, \"dueDate\": \"2026-04-10\"}]`;\n    global.fetch = jest.fn().mockResolvedValue({ ok: true, json: () => ({ message: { content: raw } }) });\n    const result = await extractAssessmentBriefs('some syllabus text');\n    expect(result[0].title).toBe('Lab Report');\n  });\n\n  test('accepts \"weightage\" alias for weight', async () => {\n    const raw = `[{\"title\": \"Essay\", \"weightage\": 40, \"wordCountGoal\": 2000, \"dueDate\": null}]`;\n    global.fetch = jest.fn().mockResolvedValue({ ok: true, json: () => ({ message: { content: raw } }) });\n    const result = await extractAssessmentBriefs('some syllabus text');\n    expect(result[0].weight).toBe(40);\n  });\n});\n\ndescribe('extractAssessmentsWithOllama — noise filtering', () => {\n  test('does not include lectures or tutorials in assessment list', async () => {\n    const syllabus = 'Weekly lectures 3h. Tutorials 1h. Assessment: Essay 40%.';\n    global.fetch = jest.fn().mockResolvedValue({\n      ok: true,\n      json: () => ({ message: { content: '[\"Essay\"]' } })\n    });\n    const result = await extractAssessmentsWithOllama(syllabus);\n    expect(result).not.toContain('lectures');\n    expect(result).not.toContain('Tutorials');\n  });\n});\n\ndescribe('pingOllama', () => {\n  test('returns false when Ollama unreachable', async () => {\n    global.fetch = jest.fn().mockRejectedValue(new Error('Connection refused'));\n    const alive = await pingOllama();\n    expect(alive).toBe(false);\n  });\n});\n\ndescribe('SYSTEM_PROMPT contract', () => {\n  test('SYSTEM_PROMPT does not contain em-dashes', () => {\n    expect(__internals.SYSTEM_PROMPT).not.toMatch(/—/);\n  });\n\n  test('SYSTEM_PROMPT references Australian English', () => {\n    expect(__internals.SYSTEM_PROMPT.toLowerCase()).toMatch(/australian/);\n  });\n});"
      },
