        "code": "// tests/core/SovereignRouter.test.js\nimport {\n  streamFromLevel, isValidStream, hydrate, __internals\n} from '../../src/core/SovereignRouter';\n\ndescribe('streamFromLevel', () => {\n  test('maps known levels to stream IDs', () => {\n    expect(streamFromLevel('undergraduate')).toBe('tertiary');\n    expect(streamFromLevel('highschool')).toBe('highschool');\n  });\n\n  test('returns \"tertiary\" for unknown level', () => {\n    expect(streamFromLevel('alien')).toBe('tertiary');\n  });\n});\n\ndescribe('isValidStream', () => {\n  test('returns true for all built-in streams', () => {\n    __internals.VALID_STREAM_IDS.forEach(id => {\n      expect(isValidStream(id)).toBe(true);\n    });\n  });\n\n  test('returns false for unknown stream', () => {\n    expect(isValidStream('nonexistent')).toBe(false);\n  });\n});\n\ndescribe('hydrate', () => {\n  test('returns streamId, profile, capabilities', () => {\n    const result = hydrate({ level: 'undergraduate' });\n    expect(result).toHaveProperty('streamId');\n    expect(result).toHaveProperty('profile');\n    expect(result).toHaveProperty('capabilities');\n  });\n\n  test('canAccess returns false for unauthorised capability', () => {\n    const result = hydrate({ level: 'highschool' });\n    // PhD-only capabilities should not be accessible for highschool\n    expect(result.canAccess('phd_only_feature')).toBe(false);\n  });\n\n  test('getDefaultLanding returns a non-empty string', () => {\n    const result = hydrate({ level: 'undergraduate' });\n    expect(typeof result.getDefaultLanding()).toBe('string');\n    expect(result.getDefaultLanding().length).toBeGreaterThan(0);\n  });\n});"
