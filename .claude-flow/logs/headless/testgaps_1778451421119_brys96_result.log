        "content": "\n**Gaps:**\n- AES-GCM encrypt/decrypt round-trip never tested\n- Silent drop when vault locked (could silently lose events in production)\n- PBKDF2 key derivation with 600k iterations\n- `enableCloudSync()` should throw — never asserted\n- Device signature SHA256 generation\n\n```js\n// tests/core/HistoryOfThought.test.js\nimport {\n  isUnlocked, unlockWithPassphrase, lockSession,\n  appendEvent, listEvents, generateAuthenticityReport,\n  enableCloudSync, EVENT_TYPES\n} from '../../src/core/HistoryOfThought';\n\n// Requires: fake-indexeddb, crypto available in jsdom\ndescribe('HistoryOfThought — vault lifecycle', () => {\n  beforeEach(() => lockSession());\n\n  test('starts locked', () => {\n    expect(isUnlocked()).toBe(false);\n  });\n\n  test('unlocks with correct passphrase', async () => {\n    await unlockWithPassphrase('correct-horse-battery');\n    expect(isUnlocked()).toBe(true);\n  });\n\n  test('lockSession clears derived key', async () => {\n    await unlockWithPassphrase('pass');\n    lockSession();\n    expect(isUnlocked()).toBe(false);\n  });\n});\n\ndescribe('HistoryOfThought — encrypt / decrypt round-trip', () => {\n  beforeEach(async () => {\n    lockSession();\n    await unlockWithPassphrase('test-passphrase');\n  });\n\n  test('appendEvent stores encrypted event retrievable by listEvents', async () => {\n    await appendEvent({ user_id: 'u1', stream_id: 'tertiary', event_type: 'text_edit', payload: { words: 50 } });\n    const events = await listEvents({ user_id: 'u1', limit: 10 });\n    expect(events).toHaveLength(1);\n    expect(events[0].event_type).toBe('text_edit');\n  });\n\n  test('events are inaccessible after lockSession', async () => {\n    await appendEvent({ user_id: 'u1', stream_id: 'tertiary', event_type: 'text_edit', payload: {} });\n    lockSession();\n    // Expect rejection or empty list when locked\n    await expect(listEvents({ user_id: 'u1' })).rejects.toThrow();\n  });\n});\n\ndescribe('HistoryOfThought —